<https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali/1> a <https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali>,
        ns2:Concept ;
    rdfs:label "Livello 1"@it ;
    ns2:prefLabel "Livello 1"@it ;
    ns2:inScheme <https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali> ;
    ns2:notation "1" ;
    ns5:description "A livello base e con l’aiuto di qualcuno, si è in grado di: individuare come organizzare, archiviare e recuperare con facilità dati, informazioni e contenuti negli ambienti digitali; riconoscere dove organizzarli in modo semplice in un ambiente strutturato" ;
    ns5:identifier "1" ;
    ns6:hasRankOrder "1" .

<https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali/2> a <https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali>,
        ns2:Concept ;
    rdfs:label "Livello 2"@it ;
    ns2:prefLabel "Livello 2"@it ;
    ns2:inScheme <https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali> ;
    ns2:notation "2" ;
    ns5:description "A livello base, in autonomia e con un supporto adeguato, laddove necessario, si è in grado di: individuare come organizzare, archiviare e recuperare con facilità dati, informazioni e contenuti negli ambienti digitali; riconoscere dove organizzarli in modo semplice in un ambiente strutturato" ;
    ns5:identifier "2" ;
    ns6:hasRankOrder "1" .

<https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali/3> a <https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali>,
        ns2:Concept ;
    rdfs:label "Livello 3"@it ;
    ns2:prefLabel "Livello 3"@it ;
    ns2:inScheme <https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali> ;
    ns2:notation "3" ;
    ns5:description "Da soli e risolvendo problemi diretti, si è in grado di: selezionare dati, informazioni e contenuti allo scopo di organizzarli, archiviarli e recuperarli in maniera sistematica all’interno di ambienti digitali; organizzarli in modo sistematico in un ambiente strutturato" ;
    ns5:identifier "3" ;
    ns6:hasRankOrder "1" .

<https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali/4> a <https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali>,
        ns2:Concept ;
    rdfs:label "Livello 4"@it ;
    ns2:prefLabel "Livello 4"@it ;
    ns2:inScheme <https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali> ;
    ns2:notation "4" ;
    ns5:description "In modo indipendente, secondo i propri fabbisogni e risolvendo problemi ben definiti e non sistematici, si è in grado di: organizzare informazioni, dati e contenuti affinché possano essere facilmente archiviati e recuperati; organizzare informazioni, dati e contenuti in un ambiente strutturato" ;
    ns5:identifier "4" ;
    ns6:hasRankOrder "1" .

<https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali/5> a <https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali>,
        ns2:Concept ;
    rdfs:label "Livello 5"@it ;
    ns2:prefLabel "Livello 5"@it ;
    ns2:inScheme <https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali> ;
    ns2:notation "5" ;
    ns5:description "Oltre a fornire supporto agli altri, si è in grado di: manipolare informazioni, dati e contenuti per facilitarne l’organizzazione, l’archiviazione e il recupero; organizzarli ed elaborarli in un ambiente strutturato" ;
    ns5:identifier "5" ;
    ns6:hasRankOrder "1" .

<https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali/6> a <https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali>,
        ns2:Concept ;
    rdfs:label "Livello 6"@it ;
    ns2:prefLabel "Livello 6"@it ;
    ns2:inScheme <https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali> ;
    ns2:notation "6" ;
    ns5:description "A un livello avanzato, secondo i propri fabbisogni e quelli degli altri, all’interno di contesti complessi, si è in grado di: adeguare la gestione di informazioni, dati e contenuti affinché vengano recuperati e archiviati nel modo più facile e opportuno; adeguarli affinché vengano organizzati ed elaborati nell’ambiente strutturato più adatto" ;
    ns5:identifier "6" ;
    ns6:hasRankOrder "1" .

<https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali/7> a <https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali>,
        ns2:Concept ;
    rdfs:label "Livello 7"@it ;
    ns2:prefLabel "Livello 7"@it ;
    ns2:inScheme <https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali> ;
    ns2:notation "7" ;
    ns5:description "A un livello altamente specializzato, si è in grado di: creare soluzioni per problemi complessi con definizione limitata inerenti la gestione dei dati, delle informazioni e dei contenuti affinché vengano organizzati, archiviati e recuperati in un ambiente digitale strutturato; integrare le proprie conoscenze per fornire un contributo alle prassi e alle conoscenze professionali e fornire supporto ad altri per gestire dati, informazioni e contenuti digitali in un ambiente digitale strutturato" ;
    ns5:identifier "7" ;
    ns6:hasRankOrder "1" .

<https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali/8> a <https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali>,
        ns2:Concept ;
    rdfs:label "Livello 8"@it ;
    ns2:prefLabel "Livello 8"@it ;
    ns2:inScheme <https://w3id.org/italia/labour-social-policies/controlled-vocabulary/data/tipo_livello_competenze_digitali> ;
    ns2:notation "8" ;
    ns5:description "A un livello avanzatissimo e super specializzato, si è in grado di: creare soluzioni per risolvere problemi complessi con molti fattori di interazione inerenti la gestione dei dati, delle informazioni e dei contenuti, affinché vengano organizzati, archiviati e recuperati in un ambiente digitale strutturato; proporre nuove idee e processi nell’ambito specifico" ;
    ns5:identifier "8" ;
    ns6:hasRankOrder "1" .

