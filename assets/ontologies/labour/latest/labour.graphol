              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/MicroCategoriaAttestatoCorso</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Micro categoria attestato corso</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/MicroCategoriaAttestatoCorso</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Sottoclasse più specifica della macro-categoria attestato. Serve a dettagliare il tipo di attestato.</lexicalForm>
