            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Livello competenze digitali</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Livello DIGCOMP delle competenze digitali fornite da un corso di formazione (0, 1, 2, 3, 4, 5, 6, 7, 8). Per i corsi con tipologiaCorso ≠ Digitale il Livello competenze digitali è sempre valorizzato con 0.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/MacroCategoriaAttestatoCorso</value>
