        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/StatoOffertaDiLavoro</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/StatoOffertaDiLavoro</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Stato offerta di lavoro</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/StatoOffertaDiLavoro</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Stato dell'offerta di lavoro: In bozza (compilata ma non ancora pubblicata), Pubblicata (visibile all'interno del catalogo da parte dei cittadini), Archiviata (non più visibile all'interno del catalogo a fronte di archiviazione manuale oppure automatica al sopraggiungere della data di fine pubblicazione), Importata (importata tramite file excel ma non ancora pubblicata)</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiAttestazione</value>
