              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Soggetto accreditato nell'ambito di percorsi di inclusione lavorativa e sociale che organizza ed eroga corsi di formazione, certificato da autorità pubblica per qualità, affidabilità e capacità di svolgere corsi validi e conformi a specifici standard.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/EsperienzaLavorativa</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/EsperienzaLavorativa</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Esperienza lavorativa</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/EsperienzaLavorativa</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Attività professionale svolta dal cittadino nel corso della sua carriera presso uno specifico datore di lavoro referenziata nel CV. Include qualifica professionale, durata, luogo e mansioni e responsabilità.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/GradoDiConoscenzaLinguistica</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/GradoDiConoscenzaLinguistica</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Grado di conoscenza linguistica</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/GradoDiConoscenzaLinguistica</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Livello di padronanza di una lingua conosciuta (es. A1–C2). È distinto per lettura, scrittura e parlato.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/IscrizioneEdizioneOffertaFormativa</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/IscrizioneEdizioneOffertaFormativa</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Iscrizione edizione offerta formativa</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/IscrizioneEdizioneOffertaFormativa</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Azione con cui l'ente formatore iscrive un cittadino a un’edizione di un corso di formazone. Contiene lo stato dell'iscrizione e i riferimenti temporali. Le iscrizioni ai corsi effettuate per il tramite del SIISL sono inviate a SIU per la registrazione all'interno della SAP.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/LinguaConosciuta</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/LinguaConosciuta</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Lingua conosciuta</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/LinguaConosciuta</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Lingua per la quale il cittadino possiede competenze oppure lingua richiesta da un'offerta di lavoro pubblicata</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
