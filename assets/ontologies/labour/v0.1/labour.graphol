              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Macro categoria attestato corso</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/MacroCategoriaAttestatoCorso</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Raggruppamento di alto livello degli attestati (es. qualificzione professionale, titolo, certificazione delle competenze...). Agevola classificazione e reporting.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaDiLavoro</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaDiLavoro</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Manifestazione interesse offerta di lavoro</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaDiLavoro</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Azione con cui un cittadino esprime interesse verso un'offerta di lavoro pubblicata da un'azienda o da un'agenzia per il lavoro. La manifestazione di interesse è quindi visibile all'azienda o all'agenzia per il lavoro che ha pubblicato l'annuncio.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaFormativa</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaFormativa</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Manifestazione interesse offerta formativa</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaFormativa</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Azione con cui un cittadino esprime interesse verso un corso di formazione pubblicato da un ente formatore. La manifestazione di interesse è quindi visibile all'ente formatore che ha pubblicato l'annuncio.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/MicroCategoriaAttestatoCorso</value>
