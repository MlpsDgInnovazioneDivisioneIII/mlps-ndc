        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Adesione offerta di lavoro</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Analisi del match tra CF assunto, offerta di lavoro e Comunicazione Obbligatoria (CO) a fronte del confronto tra le seguenti caratteristiche: CF datore di lavoro o agenzia somministrazione, qualifica professionale (CP2021 oppure CP2011 se assunzione prima del 02/04/2025) e Codice tipo contratto.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/labour/AlboProfessionale</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/AlboProfessionale</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Albo professionale</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/labour/AlboProfessionale</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Albo al quale sono iscritti i professionisti abilitati a esercitare una determinata attività referenziato nel curriculum vitae</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
