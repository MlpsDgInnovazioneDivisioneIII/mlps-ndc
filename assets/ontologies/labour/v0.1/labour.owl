    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoAttivazioneDigitaleIndividuale"/>
    <rdfs:comment xml:lang="it">Lega un Patto di servizio personalizzato al PAD che lo ha abilitato.</rdfs:comment>
    <rdfs:label xml:lang="it">ha PAD abilitante</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haPADIndividuale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoAttivazioneDigitaleIndividuale"/>
    <rdfs:comment xml:lang="it">Lega una Prestazione di sostegno al relativo PAD sottoscritto dal beneficiario della prestazione.</rdfs:comment>
    <rdfs:label xml:lang="it">ha PAD individuale</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haPatenteDiGuida">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CurriculumVitaeDelCittadiino"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/PatenteDiGuida">
        <rdfs:subClassOf>
          <owl:Restriction>
            <owl:onProperty>
              <rdf:Description>
                <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haPatenteDiGuida"/>
              </rdf:Description>
            </owl:onProperty>

            <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
          </owl:Restriction>
        </rdfs:subClassOf>

        <rdfs:comment xml:lang="it">Titolo abilitante alla conduzione di veicoli che contiene la categoria di patente posseduta dal cittadino (es. B, C)</rdfs:comment>
        <rdfs:label xml:lang="it">Patente di guida</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega il CV del cittadino ad una Patente di guida posseduta.</rdfs:comment>
    <rdfs:label xml:lang="it">ha patente di guida</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haPattoServizioPersonalizzato">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoServizioPersonalizzato"/>
    <rdfs:comment xml:lang="it">Lega una Prestazione di sostegno ad un Patto di servizio personalizzato.</rdfs:comment>
    <rdfs:label xml:lang="it">ha patto servizio personalizzato</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haProfessioneDesiderata">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CurriculumVitaeDelCittadiino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata"/>
    <rdfs:comment xml:lang="it">Lega il CV del cittadino ad una sua sezione riguardante una professione desiderata.</rdfs:comment>
    <rdfs:label xml:lang="it">ha professione desiderata</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haRegioneOrganizatriceCorso">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf>
          <rdf:Description>
            <rdf:first>
              <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/ProvinciaAutonomaItaliana">
              </owl:Class>
            </rdf:first>

            <rdf:rest>
              <rdf:Description>
                <rdf:first>
                  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/RegioneItaliana">
                  </owl:Class>
                </rdf:first>

                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </rdf:rest>

          </rdf:Description>
        </owl:unionOf>

      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una Offerta formativa a una Regione o Provincia autonoma che lo organizza.</rdfs:comment>
    <rdfs:label xml:lang="it">ha regione organizatrice corso</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haSedeErogazione">
    <rdfs:subPropertyOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/CLV/hasAddress">
      </owl:ObjectProperty>
    </rdfs:subPropertyOf>

    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneOffertaFormativa"/>
    <rdfs:comment xml:lang="it">Lega una Edizione offerta formativa al luogo fisico in cui viene erogata, nel caso in cui è prevista la modalitò di erogazione in presenza. È una specializzazione di CLV: hasAddress.</rdfs:comment>
    <rdfs:label xml:lang="it">ha sede erogazione</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haSettoreDiInteresse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/SettoreEconomicoProfessionale">
        <rdfs:comment xml:lang="it">Settore associato al corso di formazione, scelto dalla lista SEP (1 livello)</rdfs:comment>
        <rdfs:label xml:lang="it">Settore economico professionale</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una Offerta formativa al relativo Settore economico professionale.</rdfs:comment>
    <rdfs:label xml:lang="it">ha settore di interesse</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haStatoDiCVDelCittadino">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CurriculumVitaeDelCittadiino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/StatoDiCVDelCittadino"/>
    <rdfs:comment xml:lang="it">Lega un CV del cittadino al suo stato di completamento e consultabilità.</rdfs:comment>
    <rdfs:label xml:lang="it">ha stato di CV del cittadino</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haStatoIscrizioneEdizioneOffertaFormativa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/IscrizioneEdizioneOffertaFormativa"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/StatoIscrizioneEdizioneOffertaFormativa"/>
    <rdfs:comment xml:lang="it">Lega l'iscrizione di un cittadino ad una edizione di offerta formativa con il suo stato o condizione.</rdfs:comment>
    <rdfs:label xml:lang="it">ha stato iscrizione edizione offerta formativa</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haStatoOffertaDiLavoro">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaDiLavoro"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/StatoOffertaDiLavoro"/>
    <rdfs:comment xml:lang="it">Lega una Offerta di lavoro al suo stato di completamento e disponibilità.</rdfs:comment>
    <rdfs:label xml:lang="it">ha stato offerta di lavoro</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiAttestazioneCorsoDiFormazione">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CorsoDiFormazione"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiAttestazione">
        <rdfs:comment xml:lang="it">Classificazione delle attestazioni conseguite in ambito formazione (qualifica professionale, certificazione competenze, specializzazione, frequenza...). Determina valore legale e spendibilità.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di attestazione</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una sezione del CV del cittadino riguardante un Corso di formazione frequentato con il Tipo di attestazione rilasciata da tale corso.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo di attestazione corso di formazione</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiContrattoDiLavoro">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EsperienzaLavorativa"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiContrattoDiLavoro"/>
    <rdfs:comment xml:lang="it">Lega una sezione del CV del cittadino riguardante una Esperianza lavorativa con il Tipo di contratto di lavoro con cui è stata svolta tale esperienza.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo di contratto di lavoro</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiContrattoPreferito">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiContrattoDiLavoro"/>
    <rdfs:comment xml:lang="it">Lega una sezione del CV del cittadino riguardante una Professione desiderata con il Tipo di contratto di lavoro con cui si vorrebbe svolgere tale professione.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo di contratto preferito</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiModalitàFormativa">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiModalitàFormativa">
        <rdfs:comment xml:lang="it">Tipologia di modalità di erogazione del corso di formazione (es. in presenza, a distanza, ibrida…)</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di modalità formativa</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega un'offerta formativa con un Tipo di modalità con cui può essere erogata tale formazione.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo di modalità formativa</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiProfessioneDesiderata">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiQualificaProfessionale"/>
    <rdfs:comment xml:lang="it">Lega una sezione del CV del cittadino riguardante una Professione desiderata con il Tipo di qualifica professionale con cui si vorrebbe svolgere tale professione.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo di professione desiderata</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiQualificaCorsoDiFormazione">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CorsoDiFormazione"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiQualificaProfessionale"/>
    <rdfs:comment xml:lang="it">Lega una sezione del CV del cittadino riguardante un Corso di formazione frequentato con il Tipo di qualifica professionale conseguita con tale corso.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo di qualifica corso di formazione</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiQualificaEsperienzaLavorativa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EsperienzaLavorativa"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiQualificaProfessionale"/>
    <rdfs:comment xml:lang="it">Lega una sezione del CV del cittadino riguardante una Esperianza lavorativa con il Tipo di qualifica professionale con cui è stata svolta tale esperienza.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo di qualifica esperienza lavorativa</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoPercorsoPSP">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoPercorsoPSP">
        <rdfs:comment xml:lang="it">Tipologia del percorso personalizzato previsto dal Patto di Servizio Personalizzato (PSP) come ad es: Lavoro e inclusione, Upskilling, Reskilling, Reinserimento lavorativo etc.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo percorso PSP</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una Offerta formativa ad un percorso personalizzato indicato nel PSP.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo percorso PSP</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoProgrammaAttivazioneCorso">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoProgrammaAttivazioneCorso">
        <rdfs:comment xml:lang="it">Categoria del programma di attivazione collegato al corso (es. GOL). Allinea il corso a misure o linee di intervento. </rdfs:comment>
        <rdfs:label xml:lang="it">Tipo programma attivazione corso</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una Offerta formativa ad un programma di attivazione o linea d'intervento.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipo programma attivazione corso</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipologiaOffertaFormativa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipologiaOffertaFormativa">
        <rdfs:comment xml:lang="it">Macro tipologia del corso (Green, Digitale, Linguistico…). Rilevante per i requisiti e gli attestati.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipologia offerta formativa</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una Offerta formativa ad una tipologia o ambito formativo.</rdfs:comment>
    <rdfs:label xml:lang="it">ha tipologia offerta formativa</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTitoloDiStudio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TitoloDiStudioConseguito"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TitoloDiStudio">
        <rdfs:comment xml:lang="it">Categoria del titolo di studio posseduto (es. diploma superiore, laurea triennale, master etc.)</rdfs:comment>
        <rdfs:label xml:lang="it">Titolo di studio</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una sezione del CV del cittadino riguardante un Titolo di studio conseguito con il Titolo di studio oggetto di conseguimento.</rdfs:comment>
    <rdfs:label xml:lang="it">ha titolo di studio</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haUnitàDiMisuraDurata">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/UnitàDiMisuraDurata">
        <rdfs:comment xml:lang="it">Unità per esprimere la durata (ore, giorni, settimane). Normalizza la rendicontazione. L'attributo risulta deprecato.</rdfs:comment>
        <rdfs:label xml:lang="it">Unità di misura durata</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una Offerta formativa con l'Unità di misura della sua durata.</rdfs:comment>
    <rdfs:label xml:lang="it">ha unità di misura durata</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/proponeOffertaDiLavoro">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf>
          <rdf:Description>
            <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AgenziaPerIlLavoro"/>
            <rdf:rest>
              <rdf:Description>
                <rdf:first>
                  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/DatoreDiLavoro">
                  </owl:Class>
                </rdf:first>

                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </rdf:rest>

          </rdf:Description>
        </owl:unionOf>

      </owl:Class>
    </rdfs:domain>

    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaDiLavoro"/>
    <rdfs:comment xml:lang="it">Lega un Datore di lavoro o una Agenzia per il lavoro ad una Offerta di lavoro da quello proposta.</rdfs:comment>
    <rdfs:label xml:lang="it">propone offerta di lavoro</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/riferisceCurriculumVitaeCittadino">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoAttivazioneDigitaleIndividuale"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CurriculumVitaeDelCittadiino"/>
    <rdfs:comment xml:lang="it">Lega un PAD individuale di un Cittadino ad un CV del Cittadino stesso.</rdfs:comment>
    <rdfs:label xml:lang="it">riferisce curriculum vitae cittadino</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscriveDID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/DichiarazioneImmediataDisponibilità"/>
    <rdfs:comment xml:lang="it">Lega un Cittadino residente con una sua Dichiarazione di immediata disponibilità da lui sottoscritta.</rdfs:comment>
    <rdfs:label xml:lang="it">sottoscrive DID</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscrivePADIndividuale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
    <rdfs:domain>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscriveDID"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:domain>

    <rdfs:domain>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/RO/holdsRoleInTime">
          </owl:ObjectProperty>
        </owl:onProperty>

        <owl:someValuesFrom>
          <owl:Restriction>
            <owl:onProperty>
              <rdf:Description>
                <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haBeneficiarioPrestazioneDiSostegno"/>
              </rdf:Description>
            </owl:onProperty>

            <owl:someValuesFrom>
              <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haPADIndividuale"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
              </owl:Restriction>
            </owl:someValuesFrom>

          </owl:Restriction>
        </owl:someValuesFrom>

      </owl:Restriction>
    </rdfs:domain>

    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoAttivazioneDigitaleIndividuale"/>
    <rdfs:comment xml:lang="it">Lega un Cittadino residente con una sua Patto di attivazione digitale individuale da lui sottoscritto.</rdfs:comment>
    <rdfs:label xml:lang="it">sottoscrive PAD individuale</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscrivePSP">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CittadinoResidenteSottoscrittorePSP"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
    <rdfs:domain>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscrivePADIndividuale"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:domain>

    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoServizioPersonalizzato"/>
    <rdfs:comment xml:lang="it">Lega un Cittadino residente con un suo Patto di servizo personalizzato da lui sottoscritto.</rdfs:comment>
    <rdfs:label xml:lang="it">sottoscrive PSP</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/hasOnlineContactPoint">
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/TI/atTime">
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoAttivitaEnteErogatore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:comment xml:lang="it">Booleano che indica l'attività dell'ente erogatore</rdfs:comment>
    <rdfs:label xml:lang="it">avviso attività ente erogatore</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoCorsoRegionale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:comment xml:lang="it">Indicatore booleano che segnala un corso riconosciuto o finanziato a livello regionale. Associato a codice Regione.</rdfs:comment>
    <rdfs:label xml:lang="it">avviso corso regionale</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoDisponibilitàMezzoProprio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata"/>
    <rdfs:comment xml:lang="it">Indicatore booleano che segnala se il cittadino può usare un mezzo proprio. Utile per mobilità e idoneità all'offerta.</rdfs:comment>
    <rdfs:label xml:lang="it">avviso disponibilità mezzo proprio</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoDisponibilitàTrasferte">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata"/>
    <rdfs:comment xml:lang="it">Indicatore booleano sulla disponibilità a trasferte. Impatta il matching con offerte che prevedono mobilità.</rdfs:comment>
    <rdfs:label xml:lang="it">avviso disponibilità trasferte</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoEnteFormatoreCPIA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EnteFormativoAccreditato"/>
    <rdfs:comment xml:lang="it">Indicatore booleano che segnala che l'ente formatore è un CPIA. Rilevante per percorsi di istruzione per adulti.</rdfs:comment>
    <rdfs:label xml:lang="it">avviso ente formatore CPIA</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoEsperienzaNelSettore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata"/>
    <rdfs:comment xml:lang="it">Indicatore booleano che segnala se è richiesta esperienza pregressa</rdfs:comment>
    <rdfs:label xml:lang="it">avviso esperienza nel settore</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoManifestazioneInteresseFormazione">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaFormativa"/>
    <rdfs:comment xml:lang="it">Indicatore booleano che segnala che il cittadino ha manifestato interesse per un corso di formazione</rdfs:comment>
    <rdfs:label xml:lang="it">avviso manifestazione interesse formazione</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoModalitaFormativaInSede">
