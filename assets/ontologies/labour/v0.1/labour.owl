  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haEdizioneOffertaFormativa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneOffertaFormativa"/>
    <rdfs:comment xml:lang="it">Lega una Offerta formativa ad una sua edizione ovvero una erogazione del corso di formazione collocata nel tempo.</rdfs:comment>
    <rdfs:label xml:lang="it">ha edizione offerta formativa</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haEdizioneOffertaFormativaDiIscrizione">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/IscrizioneEdizioneOffertaFormativa"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneOffertaFormativa"/>
    <rdfs:comment xml:lang="it">Lega l'iscrizione di un cittadino ad una edizione di offerta formativa all'edizione stessa.</rdfs:comment>
    <rdfs:label xml:lang="it">ha edizione offerta formativa di iscrizione</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haEnteErogatore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EnteFormativoAccreditato"/>
    <rdfs:comment xml:lang="it">Lega una Offerta formativa con l'Ente formativo accreditato che l'ha pubblicata.</rdfs:comment>
    <rdfs:label xml:lang="it">ha ente erogatore</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haEsperienzaLavorativa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CurriculumVitaeDelCittadiino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EsperienzaLavorativa"/>
    <rdfs:comment xml:lang="it">Lega il CV del cittadino ad una sua sezione riguardante una sua Esperienza lavorativa.</rdfs:comment>
    <rdfs:label xml:lang="it">ha esperienza lavorativa</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haGradoDiConoscenzaLinguistica">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ConoscenzaLinguistica"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/GradoDiConoscenzaLinguistica">
        <rdfs:comment xml:lang="it">Livello di padronanza di una lingua conosciuta (es. A1–C2). È distinto per lettura, scrittura e parlato.</rdfs:comment>
        <rdfs:label xml:lang="it">Grado di conoscenza linguistica</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una Conoscenza linguistica con il livello di padronanza (grado) posseduto.</rdfs:comment>
    <rdfs:label xml:lang="it">ha grado di conoscenza linguistica</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haGradoDiConoscenzaLinguisticaLetta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haGradoDiConoscenzaLinguistica"/>
    <rdfs:comment xml:lang="it">Specializzazione del grado di conoscenza linguistica riguardante la lettura.</rdfs:comment>
    <rdfs:label xml:lang="it">ha grado di conoscenza linguistica letta</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haGradoDiConoscenzaLinguisticaParlata">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haGradoDiConoscenzaLinguistica"/>
    <rdfs:comment xml:lang="it">Specializzazione del grado di conoscenza linguistica riguardante il parlato.</rdfs:comment>
    <rdfs:label xml:lang="it">ha grado di conoscenza linguistica parlata</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haGradoDiConoscenzaLinguisticaScritta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haGradoDiConoscenzaLinguistica"/>
    <rdfs:comment xml:lang="it">Specializzazione del grado di conoscenza linguistica riguardante la scrittura.</rdfs:comment>
    <rdfs:label xml:lang="it">ha grado di conoscenza linguistica scritta</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haIscrizioneAlboProfessionale">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CurriculumVitaeDelCittadiino"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/AlboProfessionale">
        <rdfs:comment xml:lang="it">Albo al quale sono iscritti i professionisti abilitati a esercitare una determinata attività referenziato nel curriculum vitae</rdfs:comment>
        <rdfs:label xml:lang="it">Albo professionale</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega il CV del cittadino a un Albo professionale a cui èiscritto.</rdfs:comment>
    <rdfs:label xml:lang="it">ha iscrizione albo professionale</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haIscrizioneEdizioneOffertaFormativa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CittadinoResidenteSottoscrittorePSP"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/IscrizioneEdizioneOffertaFormativa"/>
    <rdfs:comment xml:lang="it">Lega un cittadino abilitato ad una sua iscrizione ad una edizione di un'offerta formativa.</rdfs:comment>
    <rdfs:label xml:lang="it">ha iscrizione edizione offerta formativa</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haLinguaConosciuta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ConoscenzaLinguistica"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/LinguaConosciuta">
        <rdfs:comment xml:lang="it">Lingua per la quale il cittadino possiede competenze oppure lingua richiesta da un'offerta di lavoro pubblicata</rdfs:comment>
        <rdfs:label xml:lang="it">Lingua conosciuta</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega il CV del cittadino ad una sua sezione riguardante la sua cooscenza di una lingua.</rdfs:comment>
    <rdfs:label xml:lang="it">ha lingua conosciuta</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haLivelloCompetenzeDigitali">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali">
        <rdfs:comment xml:lang="it">Livello DIGCOMP delle competenze digitali fornite da un corso di formazione (0, 1, 2, 3, 4, 5, 6, 7, 8). Per i corsi con tipologiaCorso ≠ Digitale il Livello competenze digitali è sempre valorizzato con 0.</rdfs:comment>
        <rdfs:label xml:lang="it">Livello competenze digitali</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega un'Offerta formativa al Livello di competenze digitali che viene acquisito da i suoi discenti.</rdfs:comment>
    <rdfs:label xml:lang="it">ha livello competenze digitali</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haMacroCategoriaAttestatoCorso">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/AttestatoRilasciatoDaCorso"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/MacroCategoriaAttestatoCorso">
        <rdfs:comment xml:lang="it">Raggruppamento di alto livello degli attestati (es. qualificzione professionale, titolo, certificazione delle competenze...). Agevola classificazione e reporting.</rdfs:comment>
        <rdfs:label xml:lang="it">Macro categoria attestato corso</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega un Attestato rilasciato da corso alla sua macro-categoria.</rdfs:comment>
    <rdfs:label xml:lang="it">ha macro categoria attestato corso</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haManifestatoInteresseOffertaFormativa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/CittadinoResidenteSottoscrittorePSP"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaFormativa"/>
    <rdfs:comment xml:lang="it">Lega un cittadino abilitato ad una sua manifestazione d'interesse per un'offerta formativa.</rdfs:comment>
    <rdfs:label xml:lang="it">ha manifestato interesse offerta formativa</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haManifestazioneInteresseOffertaDiLavoro">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
