    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaDiLavoro"/>
    <rdfs:comment xml:lang="it">Lega un cittadino ad una sua manifestazione d'interesse per un'offerta di lavoro.</rdfs:comment>
    <rdfs:label xml:lang="it">ha manifestazione interesse offerta di lavoro</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haMicroCategoriaAttestatoCorso">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/AttestatoRilasciatoDaCorso"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/MicroCategoriaAttestatoCorso">
        <rdfs:comment xml:lang="it">Sottoclasse più specifica della macro-categoria attestato. Serve a dettagliare il tipo di attestato.</rdfs:comment>
        <rdfs:label xml:lang="it">Micro categoria attestato corso</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega un Attestato rilasciato da corso alla sua micro-categoria.</rdfs:comment>
    <rdfs:label xml:lang="it">ha micro categoria attestato corso</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haModelloAttestatoDiCorso">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/AttestatoRilasciatoDaCorso"/>
    <rdfs:comment xml:lang="it">Lega un'Offerta formativa al modello di attestato che verrà rilasciato al termine della sua frequentazione con successo. </rdfs:comment>
    <rdfs:label xml:lang="it">ha modello attestato di corso</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haOffertaDiLavoroDiInteresse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaDiLavoro"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaDiLavoro"/>
    <rdfs:comment xml:lang="it">Lega una manifestazione d'interesse a una offerta di lavoro espressa da un cittadino alla relativa offerta di lavoro.</rdfs:comment>
    <rdfs:label xml:lang="it">ha offerta di lavoro di interesse</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haOffertaFormativaDiInteresse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaFormativa"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
    <rdfs:comment xml:lang="it">Lega una manifestazione d'interesse a una offerta formativa espressa da un cittadino alla relativa Offerta formativa.</rdfs:comment>
    <rdfs:label xml:lang="it">ha offerta formativa di interesse</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haPADAbilitante">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
