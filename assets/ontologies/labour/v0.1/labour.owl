  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/aderisceAdOffertaDiLavoro">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaDiLavoro"/>
    <rdfs:comment xml:lang="it">Lega una candidatura a una offerta di lavoro avanzata da un cittadino alla relativa offerta di lavoro.</rdfs:comment>
    <rdfs:label xml:lang="it">aderisce ad offerta di lavoro</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haAdesioneOffertaDiLavoro">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro"/>
    <rdfs:comment xml:lang="it">Lega un cittadino a una sua risposta di disponibilità per una offerta di lavoro.</rdfs:comment>
    <rdfs:label xml:lang="it">ha adesione offerta di lavoro</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haAgenziaPerIlLavoroDiPAD">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoAttivazioneDigitaleIndividuale"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AgenziaPerIlLavoro"/>
    <rdfs:comment xml:lang="it">Lega un PAD individule a una o più Agenzie per il lavoro indicate nell'ambito del PAD stesso.Nel caso in cui il PAD individuale sia sottoscritto nell'ambito di una prestazione di sostegno dedicata al nucleo familiare di cui fa parte il cittadino sottoscrittore, risultando attivabile al lavoro, come nel caso di un ADI, allora l'indicazione da tre a dieci Agenzie per il lavoro è obbligatoria.</rdfs:comment>
    <rdfs:label xml:lang="it">ha agenzia per il lavoro di PAD</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haCPIReferente">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf>
          <rdf:Description>
            <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/DichiarazioneImmediataDisponibilità"/>
            <rdf:rest>
              <rdf:Description>
                <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoServizioPersonalizzato"/>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </rdf:rest>

          </rdf:Description>
        </owl:unionOf>

      </owl:Class>
    </rdfs:domain>

    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/CentroPerImpiego">
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega un PSP o una DID al Centro per l'impiego con cui è stata sottoscritta.</rdfs:comment>
    <rdfs:label xml:lang="it">ha CPI referente</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haCanaleDiOrigineOffertaDiLavoro">
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaDiLavoro"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipodiCanaleDiOrigineOffertaDiLavoro">
        <rdfs:comment xml:lang="it">Tipo di canale tramite cui l’offerta di lavoro è stata pubblicata sul SIISL (es. inserimento singolo, import massivo, API). Serve per tracciabilità e reporting dei canali di pubblicazione.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di canale di origine offerta di lavoro</rdfs:label>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una Offerta di lavoro ad un Canale di origine o pubblicazione.</rdfs:comment>
    <rdfs:label xml:lang="it">ha canale di origine offerta di lavoro</rdfs:label>
  </owl:ObjectProperty>

