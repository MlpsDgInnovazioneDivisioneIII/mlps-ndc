        <dc:description xml:lang="it">Questa è la distribuzione N-TRIPLES dell'ontologia del Ministero Del Lavoro e delle Politiche Sociali relativa al dominio SIISL  che definisce in modo strutturato e interoperabile dati, relazioni e concetti relativi ai servizi per il lavoro e all’inclusione sociale, garantendo uniformità semantica, integrazione informativa e supporto ai processi digitali della piattaforma.</dc:description>
        <dc:description xml:lang="en">This is the distribution in N-TRIPLES of the Labour and Social Policies Ministry Ontology related to the SIISL domain, which defines in a structured and interoperable way the data, relationships, and concepts concerning employment and social inclusion services, ensuring semantic consistency, informational integration, and support for the digital processes of the platform.</dc:description>
        <dc:format rdf:resource="http://publications.europa.eu/resource/authority/file-type/RDF_N_TRIPLES"/>
        <dc:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
        <dc:title xml:lang="it">Distribuzione N-TRIPLES dell'ontologia dei servizi per il lavoro e l’inclusione sociale del Ministero Del Lavoro e delle Politiche Sociali - SIISL</dc:title>
        <dc:title xml:lang="en">N-TRIPLES distribution of the Labour and Social Policies Ministry ontology of labour and social inclusion services - SIISL</dc:title>
      </ns0:SemanticAssetDistribution>
    </ns0:hasSemanticAssetDistribution>

