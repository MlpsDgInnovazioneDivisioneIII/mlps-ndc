    <ns0:hasSemanticAssetDistribution>
      <ns0:SemanticAssetDistribution rdf:about="https://w3id.org/italia/labour-social-policies/data/labour/distribution/MLPSLABOUR-N-TRIPLES">
        <rdf:type rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
