        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Indicatore booleano che segnala se è richiesta esperienza pregressa</rdfs:comment>
        <rdfs:label xml:lang="it">avviso esperienza nel settore</rdfs:label>
    </owl:DatatypeProperty>



