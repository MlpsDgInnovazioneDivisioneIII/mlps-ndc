        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EnteFormativoAccreditato"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Indicatore booleano che segnala che l&apos;ente formatore è un CPIA. Rilevante per percorsi di istruzione per adulti.</rdfs:comment>
        <rdfs:label xml:lang="it">avviso ente formatore CPIA</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/avvisoEsperienzaNelSettore -->

