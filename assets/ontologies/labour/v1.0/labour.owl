        <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TipoProgrammaAttivazioneCorso"/>
        <rdfs:comment xml:lang="it">Lega una Offerta formativa ad un programma di attivazione o linea d&apos;intervento.</rdfs:comment>
        <rdfs:label xml:lang="it">ha tipo programma attivazione corso</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/haTipologiaOffertaFormativa -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTipologiaOffertaFormativa">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TipologiaOffertaFormativa"/>
        <rdfs:comment xml:lang="it">Lega una Offerta formativa ad una tipologia o ambito formativo.</rdfs:comment>
        <rdfs:label xml:lang="it">ha tipologia offerta formativa</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/haTitoloDiStudio -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haTitoloDiStudio">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TitoloDiStudioConseguito"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/TitoloDiStudio"/>
        <rdfs:comment xml:lang="it">Lega una sezione del CV del cittadino riguardante un Titolo di studio conseguito con il Titolo di studio oggetto di conseguimento.</rdfs:comment>
        <rdfs:label xml:lang="it">ha titolo di studio</rdfs:label>
    </owl:ObjectProperty>



