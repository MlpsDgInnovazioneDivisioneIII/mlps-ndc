    <!-- https://w3id.org/italia/labour-social-policies/onto/core/RegioneItaliana -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/RegioneItaliana"/>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/aderisceAdOffertaDiLavoro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haAdesioneOffertaDiLavoro"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/statusAdesioneOffertaDiLavoro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Analisi del match tra CF assunto, offerta di lavoro e Comunicazione Obbligatoria (CO) a fronte del confronto tra le seguenti caratteristiche: CF datore di lavoro o agenzia somministrazione, qualifica professionale (CP2021 oppure CP2011 se assunzione prima del 02/04/2025) e Codice tipo contratto.</rdfs:comment>
        <rdfs:label xml:lang="it">Adesione offerta di lavoro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/AlboProfessionale -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/AlboProfessionale">
        <rdfs:comment xml:lang="it">Albo al quale sono iscritti i professionisti abilitati a esercitare una determinata attività referenziato nel curriculum vitae</rdfs:comment>
        <rdfs:label xml:lang="it">Albo professionale</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/AttestatoRilasciatoDaCorso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/AttestatoRilasciatoDaCorso">
        <rdfs:comment xml:lang="it">Documento rilasciato al termine di un corso di formazione che certifica il superamento di un corso o la partecipazione con esito e riporta la tipologia di attestazione</rdfs:comment>
        <rdfs:label xml:lang="it">Attestato rilasciato da corso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/CittadinoResidenteSottoscrittorePSP -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/CittadinoResidenteSottoscrittorePSP">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscrivePSP"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Sottoclasse di RPO:RegisteredResidentPerson che raggruppa i cittadini residenti che hanno sottoscritto un Patto di servizio personalizzato ovvero partecipano al dominio della relazione lsp-labour:sottoscrivePSP.</rdfs:comment>
        <rdfs:label xml:lang="it">Cittadino residente sottoscrittore PSP</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/ConoscenzaInformatica -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/ConoscenzaInformatica">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haConoscenzaInformatica"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Insieme delle competenze informatiche dichiarate dal cittadino nel CV</rdfs:comment>
        <rdfs:label xml:lang="it">Conoscenza informatica</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/ConoscenzaLinguistica -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/ConoscenzaLinguistica">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haGradoDiConoscenzaLinguistica"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haLinguaConosciuta"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haConoscenzaLinguistica"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Capacità del cittadino di comprendere e usare una lingua. È articolata per lettura, scrittura e conversazione con relativi gradi.</rdfs:comment>
        <rdfs:label xml:lang="it">Conoscenza linguistica</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/CorsoDiFormazione -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/CorsoDiFormazione">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haCorsoDiFormazione"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/titoloCorsoDiFormazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Percorso strutturato volto a sviluppare conoscenze e abilità in un ambito. Include titolo, sede, durata, programma, finalità etc. </rdfs:comment>
        <rdfs:label xml:lang="it">Corso di formazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/CurriculumVitaeDelCittadino -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/CurriculumVitaeDelCittadino">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haStatoDiCVDelCittadino"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haCurriculumVitaeDelCittadino"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Documento che descrive il profilo curriculare del cittadino (es. esperienze, titoli di studio, competenze, conoscenze, lingue conosciute etc.). Ha uno stato (da completare, in bozza e pubblicato) e una data di aggiornamento.</rdfs:comment>
        <rdfs:label xml:lang="it">Curriculum vitae del cittadino</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/DichiarazioneImmediataDisponibilità -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/DichiarazioneImmediataDisponibilità">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haCPIReferente"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscriveDID"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoServizioPersonalizzato"/>
        <rdfs:comment xml:lang="it">Dichiarazione con cui un cittadino comunica ufficialmente ai servizi per l’impiego di essere immediatamente disponibile a lavorare e a partecipare alle misure di politica attiva.</rdfs:comment>
        <rdfs:label xml:lang="it">Dichiarazione immediata disponibilità</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneArchiviataDiOffertaFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneArchiviataDiOffertaFormativa">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneOffertaFormativa"/>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EdizionePubblicataDiOffertaFormativa"/>
        <rdfs:comment xml:lang="it">Edizione di un’offerta formativa non più attiva e conservata per storico.</rdfs:comment>
        <rdfs:label xml:lang="it">Edizione archiviata di offerta formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneOffertaFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneOffertaFormativa">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PeriodoDiErogazione"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PeriodoDiPubblicazione"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haEdizioneOffertaFormativaDiIscrizione"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Versione specifica di un’offerta formativa con date inizio e fine, posti disponibili e caratteristiche definite</rdfs:comment>
        <rdfs:label xml:lang="it">Edizione offerta formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/EdizionePubblicataDiOffertaFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/EdizionePubblicataDiOffertaFormativa">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/EdizioneOffertaFormativa"/>
        <rdfs:comment xml:lang="it">Edizione di un&apos;offerta formativa attualmente pubblicata a catalogo e consultabile dai cittadini. Avendo un periodo di pubblicazione attivo può accettare manifestazioni di interesse e consente all&apos;ente formatore che ha pubblicato il corso di iscrivere cittadini.</rdfs:comment>
        <rdfs:label xml:lang="it">Edizione pubblicata di offerta formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/EnteFormativoAccreditato -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/EnteFormativoAccreditato">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haAccreditamentoPerFormazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoEnteFormatoreCPIA"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/codiceIntermediario"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Soggetto accreditato nell&apos;ambito di percorsi di inclusione lavorativa e sociale che organizza ed eroga corsi di formazione, certificato da autorità pubblica per qualità, affidabilità e capacità di svolgere corsi validi e conformi a specifici standard.</rdfs:comment>
        <rdfs:label xml:lang="it">Ente formativo accreditato</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/EsperienzaLavorativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/EsperienzaLavorativa">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiContrattoDiLavoro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haEsperienzaLavorativa"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Attività professionale svolta dal cittadino nel corso della sua carriera presso uno specifico datore di lavoro referenziata nel CV. Include qualifica professionale, durata, luogo e mansioni e responsabilità.</rdfs:comment>
        <rdfs:label xml:lang="it">Esperienza lavorativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/GradoDiConoscenzaLinguistica -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/GradoDiConoscenzaLinguistica">
        <rdfs:comment xml:lang="it">Livello di padronanza di una lingua conosciuta (es. A1–C2). È distinto per lettura, scrittura e parlato.</rdfs:comment>
        <rdfs:label xml:lang="it">Grado di conoscenza linguistica</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/IscrizioneEdizioneOffertaFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/IscrizioneEdizioneOffertaFormativa">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haEdizioneOffertaFormativaDiIscrizione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haStatoIscrizioneEdizioneOffertaFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haIscrizioneEdizioneOffertaFormativa"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Azione con cui l&apos;ente formatore iscrive un cittadino a un’edizione di un corso di formazone. Contiene lo stato dell&apos;iscrizione e i riferimenti temporali. Le iscrizioni ai corsi effettuate per il tramite del SIISL sono inviate a SIU per la registrazione all&apos;interno della SAP.</rdfs:comment>
        <rdfs:label xml:lang="it">Iscrizione edizione offerta formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/LinguaConosciuta -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/LinguaConosciuta">
        <rdfs:comment xml:lang="it">Lingua per la quale il cittadino possiede competenze oppure lingua richiesta da un&apos;offerta di lavoro pubblicata</rdfs:comment>
        <rdfs:label xml:lang="it">Lingua conosciuta</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/LivelloCompetenzeDigitali">
        <rdfs:comment xml:lang="it">Livello DIGCOMP delle competenze digitali fornite da un corso di formazione (0, 1, 2, 3, 4, 5, 6, 7, 8). Per i corsi con tipologiaCorso ≠ Digitale il Livello competenze digitali è sempre valorizzato con 0.</rdfs:comment>
        <rdfs:label xml:lang="it">Livello competenze digitali</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/MacroCategoriaAttestatoCorso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/MacroCategoriaAttestatoCorso">
        <rdfs:comment xml:lang="it">Raggruppamento di alto livello degli attestati (es. qualificzione professionale, titolo, certificazione delle competenze...). Agevola classificazione e reporting.</rdfs:comment>
        <rdfs:label xml:lang="it">Macro categoria attestato corso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaDiLavoro -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaDiLavoro">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haOffertaDiLavoroDiInteresse"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haManifestazioneInteresseOffertaDiLavoro"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Azione con cui un cittadino esprime interesse verso un&apos;offerta di lavoro pubblicata da un&apos;azienda o da un&apos;agenzia per il lavoro. La manifestazione di interesse è quindi visibile all&apos;azienda o all&apos;agenzia per il lavoro che ha pubblicato l&apos;annuncio.</rdfs:comment>
        <rdfs:label xml:lang="it">Manifestazione interesse offerta di lavoro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/ManifestazioneInteresseOffertaFormativa">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haOffertaFormativaDiInteresse"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haManifestatoInteresseOffertaFormativa"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Azione con cui un cittadino esprime interesse verso un corso di formazione pubblicato da un ente formatore. La manifestazione di interesse è quindi visibile all&apos;ente formatore che ha pubblicato l&apos;annuncio.</rdfs:comment>
        <rdfs:label xml:lang="it">Manifestazione interesse offerta formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/MicroCategoriaAttestatoCorso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/MicroCategoriaAttestatoCorso">
        <rdfs:comment xml:lang="it">Sottoclasse più specifica della macro-categoria attestato. Serve a dettagliare il tipo di attestato.</rdfs:comment>
        <rdfs:label xml:lang="it">Micro categoria attestato corso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/OffertaDiLavoro -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaDiLavoro">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haStatoOffertaDiLavoro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/proponeOffertaDiLavoro"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/canaleDiOrigineOffertaDiLavoro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/titoloOffertaDiLavoro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Annuncio di lavoro pubblicato da un&apos;azienda o da un&apos;agenzia per il lavoro (APL) con titolo, descrizione, tipo contratto, sede, mansioni e esponsabilità, data di scadenza etc. E&apos; sempre collegata ad uno stato (in bozza, pubblicata, archiviata, importata) e a un canale di origine (inserimento singolo, import massivo, API).</rdfs:comment>
        <rdfs:label xml:lang="it">Offerta di lavoro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaFormativa">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haEdizioneOffertaFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haEnteErogatore"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haLivelloCompetenzeDigitali"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haModelloAttestatoDiCorso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haSettoreDiInteresse"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoDiModalitàFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoPercorsoPSP"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haTipoProgrammaAttivazioneCorso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haTipologiaOffertaFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoCorsoRegionale"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoModalitaFormativaInSede"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/durataOffertaFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/finalitàOffertaFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/programmazioneAttivitàCorso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/requisitoAmmissioneOffertaFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/titoloOffertaFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Corso di formazione pubblicato da un ente formatore. È un percorso strutturato volto a fornire e sviluppare competenze, conoscenze e abilità in un determinato campo o professione. Nell&apos;ambito di percorsi di inclusione lavorativa e sociale, l&apos;attività ha lo scopo di favorire l&apos;acquisizione o il miglioramento delle competenze lavorative e personali al fine di facilitare il (re-)impiego di persone in cerca di lavoro.</rdfs:comment>
        <rdfs:label xml:lang="it">Offerta formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/PatenteDiGuida -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/PatenteDiGuida">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haPatenteDiGuida"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Titolo abilitante alla conduzione di veicoli che contiene la categoria di patente posseduta dal cittadino (es. B, C)</rdfs:comment>
        <rdfs:label xml:lang="it">Patente di guida</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/PattoAttivazioneDigitaleIndividuale -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/PattoAttivazioneDigitaleIndividuale">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/riferisceCurriculumVitaeCittadino"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haPADIndividuale"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscrivePADIndividuale"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Il Patto di Attivazione Digitale (PAD) individuale è un atto ovvero un accordo formale e obbligatorio che viene compilato dai beneficiari che risultano attivabili al lavoro (ADI, SFL, NASPI e DIS-COLL). Nel PAD individuale il sottoscrittore: fornisce e certifica tramite OTP i propri contatti e-mail e cellulare; comunica le informazioni essenziali per la presa in carico e indica, ai fini dell&apos;attivazione al lavoro e della successiva sottoscrizione del patto di servizio personalizzato, le agenzie per il lavoro; si impegna a presentarsi alla convocazione del servizio per il lavoro competente per la stipula del patto di servizio personalizzato.</rdfs:comment>
        <rdfs:label xml:lang="it">Patto attivazione digitale individuale</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/PattoServizioPersonalizzato -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/PattoServizioPersonalizzato">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haCPIReferente"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haPattoServizioPersonalizzato"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/sottoscrivePSP"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Il Patto di Servizio Personalizzato (PSP) è un atto ovvero un accordo che un disoccupato ovvero un cittadino residente in cerca di lavoro sottoscrive con un Centro per l’impiego (CPI) e che regola gli impegni del disoccupato e definisce i servizi che il CPI è chiamato ad erogare, entrambi finalizzati all’obiettivo comune di ricollocazione del cittadino nel mondo del lavoro. Nel PSP sono dettagliati i servizi di accompagnamento al lavoro concordati tra cui, ad esempio, la partecipazione a corsi di riqualificazione professionale o la ricerca attiva di offerte di lavoro. La stipula del patto è obbligatoria per i percettori di indennità o sostegni economici (NASpI, ADI, SFL) che in questo modo assicurano il rispetto degli impegni presi, la cui mancata osservanza, in assenza di giustificato motivo, porterebbe alla sospensione e/o perdita dei benefici economici e l’impossibilità di usufruire di ulteriori servizi presso il CPI. Nell&apos;ambito dell&apos;ADI e della conseguente analisi multidimensionale del nucleo familiare, il PSP è richiesto per tutti i componenti del nucleo familiare attivabili al lavoro.</rdfs:comment>
        <rdfs:label xml:lang="it">Patto servizio personalizzato</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/PeriodoDiErogazione -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/PeriodoDiErogazione">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:comment xml:lang="it">Intervallo temporale durante il quale viene erogata un’offerta formativa</rdfs:comment>
        <rdfs:label xml:lang="it">Periodo di erogazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/PeriodoDiPubblicazione -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/PeriodoDiPubblicazione">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:comment xml:lang="it">Periodo in cui un’offerta di lavoro o di formazione è visibile ai cittadini all&apos;interno del catalogo e quindi disponibile a ricevere manifestazioni di interesse</rdfs:comment>
        <rdfs:label xml:lang="it">Periodo di pubblicazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/ProfessioneDesiderata">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haProfessioneDesiderata"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Qualifica professionale che il cittadino inserisce nel suo CV come aspirazione professionale</rdfs:comment>
        <rdfs:label xml:lang="it">Professione desiderata</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/SettoreEconomicoProfessionale -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/SettoreEconomicoProfessionale">
        <rdfs:comment xml:lang="it">Settore associato al corso di formazione, scelto dalla lista SEP (1 livello)</rdfs:comment>
        <rdfs:label xml:lang="it">Settore economico professionale</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/StatoDiCVDelCittadino -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/StatoDiCVDelCittadino">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haStatoDiCVDelCittadino"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/statusCV"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Stato in cui si trova il CV di un cittadino: Da completare, In compilazione (ovvero in bozza), Pubblicato (ovvero visibile ad aziende e APL). E&apos; sempre integrato dalla data di aggiornamento.</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di CV del cittadino</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/StatoIscrizioneEdizioneOffertaFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/StatoIscrizioneEdizioneOffertaFormativa">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/statusIscrizioneEdizioneOffertaFormativa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Stato dell&apos;iscrizione di un cittadino a un corso di formazione (richiesta, accettata, rifiutata, abbandonato)</rdfs:comment>
        <rdfs:label xml:lang="it">Stato iscrizione edizione offerta formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/StatoOffertaDiLavoro -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/StatoOffertaDiLavoro">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:comment xml:lang="it">Stato dell&apos;offerta di lavoro: In bozza (compilata ma non ancora pubblicata), Pubblicata (visibile all&apos;interno del catalogo da parte dei cittadini), Archiviata (non più visibile all&apos;interno del catalogo a fronte di archiviazione manuale oppure automatica al sopraggiungere della data di fine pubblicazione), Importata (importata tramite file excel ma non ancora pubblicata)</rdfs:comment>
        <rdfs:label xml:lang="it">Stato offerta di lavoro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiAttestazione -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiAttestazione">
        <rdfs:comment xml:lang="it">Classificazione delle attestazioni conseguite in ambito formazione (qualifica professionale, certificazione competenze, specializzazione, frequenza...). Determina valore legale e spendibilità.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di attestazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiContrattoDiLavoro -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiContrattoDiLavoro">
        <rdfs:comment xml:lang="it">Tipologia contrattuale prevista (rapporti di lavoro) che può essere indicata all&apos;interno del CV per un&apos;esperienza lavorativa oppure nell&apos;offerta di lavoro pubblicata (es. tempo indeterminato, apprendistato…)</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di contratto di lavoro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiModalitàFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiModalitàFormativa">
        <rdfs:comment xml:lang="it">Tipologia di modalità di erogazione del corso di formazione (es. in presenza, a distanza, ibrida…)</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di modalità formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiQualificaProfessionale -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoDiQualificaProfessionale">
        <rdfs:comment xml:lang="it">Classificazione standard della qualifica professionale (CP2021). Usata per tassonomie e reporting.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di qualifica professionale</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TipoPercorsoPSP -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoPercorsoPSP">
        <rdfs:comment xml:lang="it">Tipologia del percorso personalizzato previsto dal Patto di Servizio Personalizzato (PSP) come ad es: Lavoro e inclusione, Upskilling, Reskilling, Reinserimento lavorativo etc.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo percorso PSP</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TipoProgrammaAttivazioneCorso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipoProgrammaAttivazioneCorso">
        <rdfs:comment xml:lang="it">Categoria del programma di attivazione collegato al corso (es. GOL). Allinea il corso a misure o linee di intervento. </rdfs:comment>
        <rdfs:label xml:lang="it">Tipo programma attivazione corso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TipodiCanaleDiOrigineOffertaDiLavoro -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipodiCanaleDiOrigineOffertaDiLavoro">
        <rdfs:comment xml:lang="it">Tipo di canale tramite cui l’offerta di lavoro è stata pubblicata sul SIISL (es. inserimento singolo, import massivo, API). Serve per tracciabilità e reporting dei canali di pubblicazione.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di canale di origine offerta di lavoro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TipologiaOffertaFormativa -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TipologiaOffertaFormativa">
        <rdfs:comment xml:lang="it">Macro tipologia del corso (Green, Digitale, Linguistico…). Rilevante per i requisiti e gli attestati.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipologia offerta formativa</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TitoloDiStudio -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TitoloDiStudio">
        <rdfs:comment xml:lang="it">Categoria del titolo di studio posseduto (es. diploma superiore, laurea triennale, master etc.)</rdfs:comment>
        <rdfs:label xml:lang="it">Titolo di studio</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/TitoloDiStudioConseguito -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/TitoloDiStudioConseguito">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haTitoloDiStudio"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/haConseguitoTitoloDiStudio"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/descrizioneTitoloDiStudioConseguito"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Titolo di studio conseguito dal cittadino nel corso della sua carriera (es. diploma superiore, laurea triennale, master etc.). È collegato nel CV a votazione, data di conseguimento e istituto.</rdfs:comment>
        <rdfs:label xml:lang="it">Titolo di studio conseguito</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/UnitàDiMisuraDurata -->

