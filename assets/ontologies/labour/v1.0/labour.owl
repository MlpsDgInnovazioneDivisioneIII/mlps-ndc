        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="it">Stato dell&apos;iscrizione del cittadino ad un corso di formazione (iscrizione, inizio, fine)</rdfs:comment>
        <rdfs:label xml:lang="it">status iscrizione edizione offerta formativa</rdfs:label>
    </owl:DatatypeProperty>



