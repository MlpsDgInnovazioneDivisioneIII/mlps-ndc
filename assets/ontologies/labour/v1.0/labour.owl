        <rdfs:label xml:lang="it">avviso percorso reinserimento lavorativo</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/avvisoPercorsoReskilling -->

