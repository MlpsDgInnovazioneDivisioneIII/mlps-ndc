        <rdfs:comment xml:lang="it">Booleano che indica se il corso fa parte di un percorso di inclusione lavorativa</rdfs:comment>
        <rdfs:label xml:lang="it">avviso percorso lavoro inclusione</rdfs:label>
    </owl:DatatypeProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/avvisoPercorsoReinserimentoLavorativo -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/avvisoPercorsoReinserimentoLavorativo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
