    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haBeneficiarioPrestazioneDiSostegno"/>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/aderisceAdOffertaDiLavoro -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/aderisceAdOffertaDiLavoro">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/OffertaDiLavoro"/>
        <rdfs:comment xml:lang="it">Lega una candidatura a una offerta di lavoro avanzata da un cittadino alla relativa offerta di lavoro.</rdfs:comment>
        <rdfs:label xml:lang="it">aderisce ad offerta di lavoro</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/haAdesioneOffertaDiLavoro -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haAdesioneOffertaDiLavoro">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/AdesioneOffertaDiLavoro"/>
        <rdfs:comment xml:lang="it">Lega un cittadino a una sua risposta di disponibilità per una offerta di lavoro.</rdfs:comment>
        <rdfs:label xml:lang="it">ha adesione offerta di lavoro</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/haAgenziaPerIlLavoroDiPAD -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haAgenziaPerIlLavoroDiPAD">
        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoAttivazioneDigitaleIndividuale"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AgenziaPerIlLavoro"/>
        <rdfs:comment xml:lang="it">Lega un PAD individule a una o più Agenzie per il lavoro indicate nell&apos;ambito del PAD stesso.Nel caso in cui il PAD individuale sia sottoscritto nell&apos;ambito di una prestazione di sostegno dedicata al nucleo familiare di cui fa parte il cittadino sottoscrittore, risultando attivabile al lavoro, come nel caso di un ADI, allora l&apos;indicazione da tre a dieci Agenzie per il lavoro è obbligatoria.</rdfs:comment>
        <rdfs:label xml:lang="it">ha agenzia per il lavoro di PAD</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/haCPIReferente -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/haCPIReferente">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/DichiarazioneImmediataDisponibilità"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/labour-social-policies/onto/labour/PattoServizioPersonalizzato"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/CentroPerImpiego"/>
        <rdfs:comment xml:lang="it">Lega un PSP o una DID al Centro per l&apos;impiego con cui è stata sottoscritta.</rdfs:comment>
        <rdfs:label xml:lang="it">ha CPI referente</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/labour/haCanaleDiOrigineOffertaDiLavoro -->

