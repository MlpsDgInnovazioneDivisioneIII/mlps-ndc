        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/NucleoFamiliare</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/NucleoFamiliare</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Nucleo familiare generico</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/NucleoFamiliare</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Il nucleo familiare generico è l'insieme di persone coabitanti aventi dimora abituale nello stesso comune, legate da vincoli di matrimonio, unione civile, parentela, affinità, adozione o da legami affettivi. Coincide generalmente con la famiglia anagrafica, ma può differire ai fini ISEE o fiscali, includendo anche persone non conviventi.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
