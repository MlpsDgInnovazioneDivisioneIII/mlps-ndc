        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/CoordinatorePAIS</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/CoordinatorePAIS</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
