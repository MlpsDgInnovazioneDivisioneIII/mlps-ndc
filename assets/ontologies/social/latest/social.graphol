        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/AnalisiPreliminareDelCaso</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/AnalisiPreliminareDelCaso</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Analisi preliminare del caso</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/AnalisiPreliminareDelCaso</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>L'Analisi preliminare (AP) consiste in uno o più colloqui, effettuati dagli operatori sociali con il nucleo familiare. Nel corso dell'AP vengono raccolte le informazioni sul nucleo nel suo complesso e sui  suoi singoli componenti necessarie alla eventuale erogazione di servizi, alla definizione del Patto per l’inclusione sociale e all' identificazione dei componenti tenuti a presentarsi ai CPI per l’attivazione lavorativa.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/AssegnazioneCasoDiNucleo</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/AssegnazioneCasoDiNucleo</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Assegnazione caso di nucleo</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/AssegnazioneCasoDiNucleo</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Definisce l'associazione tra un caso di nucleo familiare beneficiario e l'assistente sociale incaricato di gestire il caso (case manager) nel periodo considerato. È sottoclasse di TI:TimeIndexEvent.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/AttoDiAttribuzioneCategoriaObbligoAttivazione</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/AttoDiAttribuzioneCategoriaObbligoAttivazione</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Atto di attribuzione categoria obbligo attivazione</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/AttoDiAttribuzioneCategoriaObbligoAttivazione</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Azione attraverso la quale  si definisce per ciascun componente il nucleo familiare la sussistenza o meno di obblighi di attivazione sulla base dei dati anagrafici e socio-sanitari, ove necessario integrati con le valutazioni dei servizi sociali sulla condizione di attivabile al lavoro.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/AttoDiGiustificatoMotivoDiAssenza</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/AttoDiGiustificatoMotivoDiAssenza</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Atto di giustificato motivo di assenza</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/AttoDiGiustificatoMotivoDiAssenza</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Documentazione attestante un giustificato motivo per mancata presentazione ai servizi nei tempi previsti dalla norma o mancata presentazione alle convocazioni.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
