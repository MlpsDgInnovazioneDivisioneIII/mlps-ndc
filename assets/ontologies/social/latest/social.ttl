lsp-social: a owl:Ontology ;
    owl:versionIRI lsp-social:0.1 ;
    owl:imports CLV:,
        COV:,
        CPV:,
        L0:,
        RO: ;
    rdfs:label "Ontologia della gestione dei patti per l'inclusione sociale (GePI) del Ministero Del Lavoro e delle Politiche Sociali"@it,
        "Ontology for the management of Social Inclusion Pacts (GePI) of the Ministry of Labor and Social Policies"@en ;
    rdfs:comment "Ontologia del Ministero Del Lavoro e delle Politiche Sociali relativa al dominio GePi definisce in modo strutturato e interoperabile dati, relazioni e concetti relativi alla gestione dei Patti per l’Inclusione Sociale, garantendo uniformità semantica, integrazione informativa e supporto ai processi digitali della piattaforma che è parte integrante del Sistema informativo per l'inclusione sociale e lavorativa (SIISL)"@it,
        "Ontology of the Ministry of Labour and Social Policies related to the GePi domain defines in a structured and interoperable way the data, relationships, and concepts concerning the management of Social Inclusion Pacts, ensuring semantic uniformity, information integration, and support for the digital processes of the platform, which is an integral part of the Social and Labour Inclusion Information System (SIISL)."@en ;
    owl:versionInfo "0.1 - Modificata il 26 Febbraio 2026"@it,
        "0.1 - Modified on 26 February 2026"@en ;
    rdfs:isDefinedBy lsp-social: ;
    adms:acronym "lsp" ;
    adms:hasContributor <https://w3id.org/italia/data/organization/public-organization/td> ;
    adms:hasFormalityLevel adms:Formal ;
    adms:hasKeyClass lsp-social:PattoAttivazioneDigitaleNucleo,
        lsp-social:PattoInclusioneSocialeDelCaso ;
    adms:hasOntologyLanguage adms:OWL ;
    adms:hasSemanticAssetDistribution <https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-N-TRIPLES>,
        <https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-RDF-TURTLE>,
        <https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-RDF-XML> ;
    adms:hasTask adms:AnnotationTask,
        adms:QueryFormulationTask,
        adms:SearchTask ;
    adms:last lsp-social:0.1 ;
    adms:officialURI "https://w3id.org/italia/labour-social-policies/onto/social/"^^xsd:anyURI ;
    adms:prefix "lsp-social" ;
    adms:semanticAssetInUse <https://w3id.org/italia/data/project/NDC> ;
    adms:status "draft" ;
    adms:target "Cittadini"@it,
        "Imprese"@it,
        "Pubbliche Amministrazioni"@it ;
    adms:type adms:ServiceOnytology ;
    dcat:contactPoint <https://w3id.org/italia/labour-social-policies/data/organization/DGInnovazioneDiv3> ;
    dcat:keyword "digital core activation agreement"@en,
        "family unit"@en,
        "nucleo familiare"@it,
        "patto di attivazione digitale del nucleo"@it,
        "patto di inclusione sociale del caso"@it,
        "social inclusion pact of the case"@en ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/SOCI> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:creator <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:description "Ontologia del Ministero Del Lavoro e delle Politiche Sociali relativa al dominio GePi definisce in modo strutturato e interoperabile dati, relazioni e concetti relativi alla gestione dei Patti per l’Inclusione Sociale, garantendo uniformità semantica, integrazione informativa e supporto ai processi digitali della piattaforma che è parte integrante del Sistema informativo per l'inclusione sociale e lavorativa (SIISL)"@it,
        "Ontology of the Ministry of Labour and Social Policies related to the GePi domain defines in a structured and interoperable way the data, relationships, and concepts concerning the management of Social Inclusion Pacts, ensuring semantic uniformity, information integration, and support for the digital processes of the platform, which is an integral part of the Social and Labour Inclusion Information System (SIISL)."@en ;
    dct:identifier "https://w3id.org/italia/labour-social-policies/onto/social" ;
    dct:issued "2026-02-26T00:00:00+00:00"^^xsd:dateTime ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG>,
        <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-02-26T00:00:00+00:00"^^xsd:dateTime ;
    dct:publisher <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:rightsHolder <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:title "Ontologia della gestione dei patti per l'inclusione sociale (GePI) del Ministero Del Lavoro e delle Politiche Sociali"@it,
        "Ontology for the management of Social Inclusion Pacts (GePI) of the Ministry of Labor and Social Policies"@en .

### Object Properties

CLV:hasCountry a owl:ObjectProperty .

L0:hasFirstMember a owl:ObjectProperty .

L0:hasMember a owl:ObjectProperty .

L0:precedes a owl:ObjectProperty .

lsp-core:haBeneficiarioPrestazioneDiSostegno a owl:ObjectProperty .

lsp-core:haDomandaPrestazioneDiSostegno a owl:FunctionalProperty,
        owl:ObjectProperty .

lsp-core:presentaDomandaPrestazioneDiSostegno a owl:InverseFunctionalProperty,
        owl:ObjectProperty .

lsp-social:assegnatoCasoAGestoreda a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "assegnato caso a gestore da"@it ;
    rdfs:domain lsp-social:AssegnazioneCasoDiNucleo ;
    rdfs:range lsp-social:CoordinatorePAIS ;
    rdfs:comment "relazione che collega le entità Assegnazione caso di nucleo e Coordinatore PaIS"@it .

lsp-social:generaContributoScalaEquivalenza a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "genera contributo scala equivalenza"@it ;
    rdfs:domain lsp-social:ComponenteNucleoFamiliare ;
    rdfs:range lsp-social:ContributoDiComponenteAScalaDiEquivalenza ;
    rdfs:comment "relazione che collega le entità Componente nucleo familiare e Contributo componente a scala di equivalenza"@it .

lsp-social:gestisceCondizioneDiSvantaggio a owl:ObjectProperty ;
    rdfs:label "gestisce condizione di svantaggio"@it ;
    rdfs:domain lsp-social:CertificatoCondizioneDiSvantaggio ;
    rdfs:range COV:PublicOrganization ;
    rdfs:comment "relazione che collega una Organizzazione con il certificato di condizione di svantaggio"@it .

lsp-social:haAmministrazioneServizioSociale a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha amministrazione servizio sociale"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-core:AmministrazioneServizioSociale ;
    rdfs:comment "relazione che collega il Caso di nucleo fragile o in povertà con l'amministrazione del servizio sociale"@it .

lsp-social:haAnalisiPreliminare a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha analisi preliminare"@it ;
    rdfs:domain lsp-social:StatoDiAnalisiPreliminare ;
    rdfs:range lsp-social:AnalisiPreliminareDelCaso ;
    rdfs:comment "relazione che collega lo Stato di analisi preliminare con l'Analisi preliminare del caso"@it .

lsp-social:haAssegnazioneCasoDiNucleo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha assegnazione caso di nucleo"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-social:AssegnazioneCasoDiNucleo ;
    rdfs:comment "relazione che collega il Caso di nucleo fragile o in povertà con l'assegnazione del caso di nucleo"@it .

lsp-social:haAttoDiAttribuzioneCategoriaObbligo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha atto di attribuzione categoria obbligo"@it ;
    rdfs:domain lsp-social:StatoDiIdentificazioneObbligoDiAttivazione ;
    rdfs:range lsp-social:AttoDiAttribuzioneCategoriaObbligoAttivazione ;
    rdfs:comment "relazione che collega lo Stato di identificazione obbligo di attivazione con l'Atto di attribuzione categoria obbligo di attivazione"@it .

lsp-social:haAttoDiGiustificatoMotivoDiAssenza a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha atto di giustificato motivo di assenza"@it ;
    rdfs:domain lsp-social:PeriodoDiGiustificatoMotivoAssenza ;
    rdfs:range lsp-social:AttoDiGiustificatoMotivoDiAssenza ;
    rdfs:comment "relazione che collega il Periodo di giustificato motivo di assenza con l'Atto di giustificato motivo di assenza"@it .

lsp-social:haCategoriaDiObbligoDiAttivazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha categoria di obbligo di attivazione"@it ;
    rdfs:domain lsp-social:ObbligoComponenteNucleoDelCaso ;
    rdfs:range lsp-social:CategoriaDiObbligo ;
    rdfs:comment "relazione che collega l'obbligo componente nucleo del caso con la Categoria di obbligo"@it .

lsp-social:haComponenteAttivoNelCaso a owl:ObjectProperty ;
    rdfs:label "ha componente attivo nel caso"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-social:ComponenteNucleoAttivoNelCaso ;
    rdfs:comment "relazione che collega il Caso di nucleo fragile o in povertà con il Componente nucleo attivo nel caso"@it .

lsp-social:haComponenteNucleo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha componente nucleo"@it ;
    rdfs:domain lsp-social:NucleoFamiliare ;
    rdfs:range lsp-social:ComponenteNucleoFamiliare ;
    rdfs:comment "relazione che collega il Nucleo familiare socilamente fragile o in povertà con il Componente di nucleo fragile o in povertà"@it .

lsp-social:haComponenteNucleoConCategoriaObbligoAttivazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha componente nucleo con categoria obbligo attivazione"@it ;
    rdfs:domain lsp-social:ObbligoComponenteNucleoDelCaso ;
    rdfs:range lsp-social:ComponenteNucleoAttivoNelCaso ;
    rdfs:comment "relazione che collega l'obbligo componente nucleo del caso con la Componente nucleo attivo nel caso"@it .

lsp-social:haCondizioneDiDisabilità a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha condizione di disabilità"@it ;
    rdfs:domain lsp-social:ComponenteNucleoFamiliare ;
    rdfs:range lsp-social:CertificatoCondizioneDiDisabilità ;
    rdfs:comment "relazione che collega il Componente nucleo familiare con il Certificato di condizione di disabilità"@it .

lsp-social:haCondizioneDiSvantaggio a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha condizione di svantaggio"@it ;
    rdfs:domain lsp-social:ComponenteNucleoFamiliare ;
    rdfs:range lsp-social:CertificatoCondizioneDiSvantaggio ;
    rdfs:comment "relazione che collega il Componente nucleo familiare con il Certificato di condizione di svantaggio"@it .

lsp-social:haContributoScalaDiEquivalenza a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha contributo scala di equivalenza"@it ;
    rdfs:domain lsp-social:ScalaDiEquivalenzaNucleo ;
    rdfs:range lsp-social:ContributoDiComponenteAScalaDiEquivalenza ;
    rdfs:comment "relazione che collega il Contributo di componente a scala di equivalenza con la Scala di equivalenza nucleo"@it .

lsp-social:haDomandaDiPrestazioneDiSostegnoNucleo a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha domanda di prestazione di sostegno nucleo"@it ;
    rdfs:domain lsp-social:GestioneDiDomandaDiCasoDiNucleo ;
    rdfs:range lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare ;
    rdfs:comment "relazione che collega la Gestione di domanda di caso con la Domanda di prestazione di sostegno di nucleo familiare"@it .

lsp-social:haEnteAttuatoreDelSostegno a owl:ObjectProperty ;
    rdfs:label "ha ente attuatore sostegno"@it ;
    rdfs:domain lsp-social:SostegnoPaIS ;
    rdfs:range lsp-core:GestoreServizioSociale ;
    rdfs:comment "relazione che collega il Sostegno PaIS con il Gestore Servizio Sociale"@it .

lsp-social:haEquipeMultidisciplinareDelCaso a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha equipe multidisciplinare del caso"@it ;
    rdfs:domain lsp-social:StatoDiValutazioneMultidimensionale ;
    rdfs:range lsp-social:EquipeMultidisciplinareDelCaso ;
    rdfs:comment "relazione che collega lo Stato di valutazione multidimensionale con l'Equipe multidisciplinare del caso"@it .

lsp-social:haEsitoAnalisiPreliminareCaso a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esito analisi preliminare caso"@it ;
    rdfs:domain lsp-social:AnalisiPreliminareDelCaso ;
    rdfs:range lsp-social:EsitoAnalisiPreliminareCaso ;
    rdfs:comment "relazione che collega l'Analisi preliminare del caso con l'Esito dell'analisi preliminare del caso"@it .

lsp-social:haEsitoAPComponenteNucleo a owl:ObjectProperty ;
    rdfs:label "ha esito AP componente nucleo"@it ;
    rdfs:domain lsp-social:EsitoAnalisiPreliminareCaso ;
    rdfs:range lsp-social:ComponenteNucleoAttivoNelCaso ;
    rdfs:comment "relazione che collega l'Esito analisi preliminare del caso con il Componente nucleo attivo nel caso"@it .

lsp-social:haEsitoImpegnoPaIS a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esito impegno PaIS"@it ;
    rdfs:domain lsp-social:ImpegnoPaIS ;
    rdfs:range lsp-social:EsitoImpegnoPaIS ;
    rdfs:comment "relazione che collega l'Impegno PaIS con l'Esito impegno PaIS"@it .

lsp-social:haEsitoQAComponenteNucleo a owl:ObjectProperty ;
    rdfs:label "ha esito QA componente nucleo"@it ;
    rdfs:domain lsp-social:EsitoQuadroAnalisiCaso ;
    rdfs:range lsp-social:ComponenteNucleoAttivoNelCaso ;
    rdfs:comment "relazione che collega Esito quadro di analisi caso con la Componente nucleo attivo nel caso"@it .

lsp-social:haEsitoQuadroAnalisiCaso a owl:ObjectProperty ;
    rdfs:label "ha esito quadro analisi caso"@it ;
    rdfs:domain lsp-social:QuadroDiAnalisiDelCaso ;
    rdfs:range lsp-social:EsitoQuadroAnalisiCaso ;
    rdfs:comment "relazione che collega il Quadro di analisi del caso con l'Esito del quadro di analisi del caso"@it .

lsp-social:haEsitoRisultatoAttesoObiettivoPaIS a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha esito risultato atteso obiettivo PaIS"@it ;
    rdfs:domain lsp-social:RisultatoAttesoDiObiettivo ;
    rdfs:range lsp-social:EsitoRisultatoAttesoObiettivoPaIS ;
    rdfs:comment "relazione che collega il Risultato atteso di obiettivo con Esito di risultato atteso obiettivo PaIS"@it .

lsp-social:haGestioneDiDomandaDiCasoDiNucleo a owl:ObjectProperty ;
    rdfs:label "ha gestione di domanda di caso di nucleo"@it ;
    rdfs:subPropertyOf L0:hasMember ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-social:GestioneDiDomandaDiCasoDiNucleo ;
    rdfs:comment "relazione che collega il Caso di nucleo fragile o in povertà con la Gestione di domanda di caso di nucleo"@it .

lsp-social:haGestoreCasoDiNucleo a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha gestore caso di nucleo"@it ;
    rdfs:domain lsp-social:AssegnazioneCasoDiNucleo ;
    rdfs:range lsp-social:GestoreCasoInclusioneSociale ;
    rdfs:comment "relazione che collega l'Assegnazione caso di nucleo con il Gestore caso inclusione sociale"@it .

lsp-social:haGiustificatoMotivoAssenzaComponente a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha giustificato motivo assenza componente"@it ;
    rdfs:domain lsp-social:PartecipazioneComponenteAIncontro ;
    rdfs:range lsp-social:PeriodoDiGiustificatoMotivoAssenza ;
    rdfs:comment "relazione che collega la Partecipazione componente a incontro con il Periodo di giustificato motivo di assenza"@it .

lsp-social:haGiustificatoMotivoAssenzaNucleo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha giustificato motivo assenza nucleo"@it ;
    rdfs:domain lsp-social:StatoDiIncontroValutato ;
    rdfs:range lsp-social:PeriodoDiGiustificatoMotivoAssenza ;
    rdfs:comment "relazione che collega lo Stato di incontro valutato con il Periodo di giustificato motivo di assenza"@it .

lsp-social:haImpegnoPaIS a owl:ObjectProperty ;
    rdfs:label "ha impegno PaIS"@it ;
    rdfs:domain lsp-social:PattoInclusioneSocialeDelCaso ;
    rdfs:range lsp-social:ImpegnoPaIS ;
    rdfs:comment "relazione che collega il Patto di inclusione soiale del caso con l'Impegno PaIS"@it .

lsp-social:haIntestatarioCartaDiInclusione a owl:ObjectProperty ;
    rdfs:label "ha intestatario carta di inclusione"@it ;
    rdfs:domain lsp-social:CartaDiInclusione ;
    rdfs:range [ a owl:Class ;
            owl:unionOf (
                    lsp-social:BeneficiarioADI
                    lsp-social:RichiedenteADI ) ] ;
    rdfs:comment "relazione che collega la Carta di inclusione con il Beneficiario o il Richiedente ADI"@it .

lsp-social:haIntestatarioContrattoLocazioneNucleoFamiliare a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha intestatario contratto locazione nucleo familiare"@it ;
    rdfs:domain lsp-social:NucleoFamiliare ;
    rdfs:range lsp-social:IntestatarioContrattoLocazioneNucleoFamiliare ;
    rdfs:comment "relazione che collega il Nucleo familiare con l'Intestatario del contratto di locazione del nucleo familiare"@it .

lsp-social:haMembroEquipeMultidisciplinare a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha membro equipe multidisciplinare"@it ;
    rdfs:domain lsp-social:EquipeMultidisciplinareDelCaso ;
    rdfs:range lsp-social:MembroEquipeMultidisciplinareDelCaso ;
    rdfs:comment "relazione che collega l'Equipe multidisciplinare del caso con il Membro equipe multidisciplinare del caso"@it .

lsp-social:haNucleoFamiliareDiDomandaDiPrestazione a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha nucleo familiare di Domanda di prestazione"@it ;
    rdfs:domain lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare ;
    rdfs:range lsp-social:NucleoFamiliare ;
    rdfs:comment "relazione che collega la Domanda di prestazione di sostegno del nucleo familiare con il Nucleo familiare"@it .

lsp-social:haNucleoFamiliareDiPAD a owl:ObjectProperty ;
    rdfs:label "ha nucleo familiare di PAD"@it ;
    rdfs:domain lsp-social:PattoAttivazioneDigitaleNucleo ;
    rdfs:range lsp-social:NucleoFamiliare ;
    owl:propertyChainAxiom (
            lsp-social:riferisceDomandaDiPrestazione
            lsp-social:haNucleoFamiliareDiDomandaDiPrestazione ) ;
    rdfs:comment "relazione che collega il Patto di attivazione digitale nucleo con il Nucleo familiare"@it .

lsp-social:haNucleoFamiliareFragileOInPovertà a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha nucleo familiare fragile o in povertà"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-social:NucleoFamiliareSocialmenteFragileOInPovertà ;
    rdfs:comment "relazione che collega il Caso di nucleo fragile o in povertà con la il Nucleo familiare socialmente fragile o in povertà"@it .

lsp-social:haObbiettvoDiImpegno a owl:ObjectProperty ;
    rdfs:label "ha obbiettvo di impegno"@it ;
    rdfs:domain lsp-social:ImpegnoPaIS ;
    rdfs:range lsp-social:ObiettivoPaIS ;
    rdfs:comment "relazione che collega l'Impegno PaIS con l'Obiettivo"@it .

lsp-social:haObiettivoPaIS a owl:ObjectProperty ;
    rdfs:label "ha obiettivo PaIS"@it ;
    rdfs:domain lsp-social:PattoInclusioneSocialeDelCaso ;
    rdfs:range lsp-social:ObiettivoPaIS ;
    rdfs:comment "relazione che collega il Patto di inclusione sociale del caso con l'Obiettivo PaIS"@it .

lsp-social:haPADNucleoFamiliare a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha PAD nucleo familiare"@it ;
    rdfs:domain lsp-core:PrestazioneDiSostegnoNucleoFamiliare ;
    rdfs:range lsp-social:PattoAttivazioneDigitaleNucleo ;
    rdfs:comment "relazione che collega la Prestazione di sostegno con il Patto di attivazione digitale"@it .

lsp-social:haPartecipanteIncontro a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha partecipante incontro"@it ;
    rdfs:domain lsp-social:StatoDiIncontroValutato ;
    rdfs:range lsp-social:PartecipazioneComponenteAIncontro ;
    rdfs:comment "relazione che collega lo Stato di incontro valutato con la Partecipazione componente a incontro"@it .

lsp-social:haPartecipantePUC a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha partecipante PUC"@it ;
    rdfs:domain lsp-social:PartecipazionePUC ;
    rdfs:range lsp-social:ComponenteNucleoAttivoNelCaso ;
    rdfs:comment "relazione che collegala Partecipazione PUCa con la Componente nucleo attivo nel caso"@it .

lsp-social:haPartecipazionePUC a owl:ObjectProperty ;
    rdfs:label "ha partecipazione PUC"@it ;
    rdfs:domain lsp-social:StatoDiPartecipazionePUC ;
    rdfs:range lsp-social:PartecipazionePUC ;
    rdfs:comment "relazione che collega lo Stato di partecipazione PUC con la Partecipazione PUC"@it .

lsp-social:haPattoInclusioneSocialeDelCaso a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
