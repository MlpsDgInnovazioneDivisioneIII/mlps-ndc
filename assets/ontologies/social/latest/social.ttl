<https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-N-TRIPLES> a adms:SemanticAssetDistribution,
        dcat:Distribution,
        dcatapit:Distribution,
        owl:NamedIndividual ;
    dcat:accessURL <https://github.com/MlpsDgInnovazioneDivisioneIII/mlps-ndc/tree/main/assets/ontologies/social/latest> ;
