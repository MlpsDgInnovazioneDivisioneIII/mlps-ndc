lsp-social:identificativoQuadroAnalisi a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "identificativo quadro di analisi"@it ;
    rdfs:domain lsp-social:QuadroDiAnalisiDelCaso ;
    rdfs:comment "Identificativo del quadro analisi"@it .

lsp-social:identificatoreGestioneDomandaCaso a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "identificatore gestione domanda caso"@it ;
    rdfs:domain lsp-social:GestioneDiDomandaDiCasoDiNucleo ;
    rdfs:comment "Identificativo del caso che gestisce la misura"@it .

lsp-social:idObiettivo a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "id obiettivo"@it ;
    rdfs:domain lsp-social:ObiettivoPaIS ;
    rdfs:comment "Identificativo dell'obiettivo PaIS"@it .

lsp-social:idRisultatoAttesoObiettivo a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "identificativo risultato atteso obiettivo"@it ;
    rdfs:domain lsp-social:RisultatoAttesoDiObiettivo ;
    rdfs:comment "Identificativo risultato"@it .

lsp-social:idTipologiaSostegnoPaIS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "identificativo tipologia sostegno PaIS"@it ;
    rdfs:domain lsp-social:SostegnoPaIS ;
    rdfs:comment "Identificativo del sostegno PaIS"@it .

lsp-social:motivazioneEsitoImpegnoPaIS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "motivazione esito impegno PaIS"@it ;
    rdfs:domain lsp-social:EsitoImpegnoPaIS ;
    rdfs:range xsd:string ;
    rdfs:comment "indica la motivazione di esito dell'impegno"@it .

lsp-social:motivazioneEsitoRisultatoObiettivoPaIS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "motivazione esito risultato obiettivo PaIS"@it ;
    rdfs:domain lsp-social:EsitoRisultatoAttesoObiettivoPaIS ;
    rdfs:range xsd:string ;
    rdfs:comment "indica la motivazione di esito del risultato degli obiettivi raggiunti"@it .

lsp-social:motivoDisattivazioneDaNucleoFamiliare a owl:DatatypeProperty ;
    rdfs:label "motivo disattivazione da nucleo familiare"@it ;
    rdfs:domain lsp-social:ComponenteNucleoAttivoNelCaso ;
    rdfs:range xsd:string ;
    rdfs:comment "indica il motivo di disattivazione di un componente all'interno di un nucleo familiare"@it .

lsp-social:numeroComponentiConAttivitàDiLavoro a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "numero componenti con attività di lavoro"@it ;
    rdfs:domain lsp-social:NucleoFamiliare ;
    rdfs:range xsd:integer ;
    rdfs:comment "indica il numero di componenti con attività di lavoro"@it .

lsp-social:numeroComponentiConSentenzaDiPena a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "numero componenti con sentenza di pena"@it ;
    rdfs:domain lsp-social:NucleoFamiliare ;
    rdfs:range xsd:integer ;
    rdfs:comment "indica il numero di componenti con sentenza di pena"@it .

lsp-social:obbligoAttivazioneLavorativaComponente a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "obbligo attivazione lavorativa componente"@it ;
    rdfs:domain lsp-social:ComponenteNucleoFamiliare ;
    rdfs:range xsd:string ;
    rdfs:comment "indica l'obbligo di attivazione lavorativa per il comonente del nucleo familiare beneficiario"@it .

lsp-social:progressoImpegnoPaIS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "progresso impegno PaIS"@it ;
    rdfs:domain lsp-social:EsitoImpegnoPaIS ;
    rdfs:range xsd:string ;
    rdfs:comment "indica il progresso relativo all'impegno del PaIS"@it .

lsp-social:progressoRisultatoObiettivoPaIS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "progresso risultato obiettivo PaIS"@it ;
    rdfs:domain lsp-social:EsitoRisultatoAttesoObiettivoPaIS ;
    rdfs:range xsd:string ;
    rdfs:comment "indica il progresso relativo al risultato dell'obiettivo del PaIS"@it .

lsp-social:statoDiGestioneDiDomandaDiCaso a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "stato di gestione di domanda di caso"@it ;
    rdfs:domain lsp-social:StatoDiGestioneDiDomandaDiCaso ;
    rdfs:comment "Indica lo stato di gestione di domanda di caso"@it .

lsp-social:statoDiPUC a owl:DatatypeProperty ;
    rdfs:label "stato di PUC"@it ;
    rdfs:domain lsp-social:PartecipazionePUC ;
    rdfs:comment "Indica lo stato della partecipazione a Progetti Utili alla Collettività"@it .

lsp-social:statusAnalisiPreliminare a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "status analisi preliminare"@it ;
    rdfs:domain lsp-social:AnalisiPreliminareDelCaso ;
    rdfs:range xsd:string ;
    rdfs:comment "Indica lo stato dell'analisi preliminare"@it .

lsp-social:statusDelCaso a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "status del caso"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range xsd:string ;
    rdfs:comment "status del caso"@it .

lsp-social:statusPaIS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "status PaIS"@it ;
    rdfs:domain lsp-social:PattoInclusioneSocialeDelCaso ;
    rdfs:range xsd:string ;
    rdfs:comment "indica lo stato del PaIS"@it .

lsp-social:statusQuadroAnalisi a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "stato quadro analisi"@it ;
    rdfs:domain lsp-social:QuadroDiAnalisiDelCaso ;
    rdfs:range xsd:string ;
    rdfs:comment "indica lo stato del quadro di analisi"@it .

lsp-social:tipologiaImpegnoPaIS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "tipologia impegno PaIS"@it ;
    rdfs:domain lsp-social:ImpegnoPaIS ;
    rdfs:comment "Descrizione tipologia dell'impegno PaIS"@it .

lsp-social:tipologiaPercorso a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "tipologia di percorso intrapreso dal componente del nucleo familiare"@it ;
    rdfs:domain lsp-social:ComponenteNucleoFamiliare ;
    rdfs:comment "tipologia di percorso sociale e lavorativo assegnato al cittadino"@it .

lsp-social:valoreTotaleScalaDiEquivalenza a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "valore totale scala di equivalenza"@it ;
    rdfs:domain lsp-social:ScalaDiEquivalenzaNucleo ;
    rdfs:range xsd:decimal .

lsp-social:versioneAnalisiPreliminare a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "versione analisi preliminare"@it ;
    rdfs:domain lsp-social:AnalisiPreliminareDelCaso ;
    rdfs:range xsd:integer ;
    rdfs:comment "indica la versione dell'analisi preliminare"@it .

lsp-social:versionePaIS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "versione PaIS"@it ;
    rdfs:domain lsp-social:PattoInclusioneSocialeDelCaso ;
    rdfs:comment "indica la versione del PaIS"@it .

lsp-social:versioneQuadroAnalisi a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "versione quadro analisi"@it ;
    rdfs:domain lsp-social:QuadroDiAnalisiDelCaso ;
    rdfs:range xsd:integer ;
    rdfs:comment "indica la versione del quadro di analisi"@it .

lsp-social:versioneRDC a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "versione RDC"@it ;
    rdfs:domain lsp-core:Atto ;
    rdfs:comment "versione RDC"@it .

### Classes

COV:PublicOrganization a owl:Class .

CPV:Alive a owl:Class .

L0:Sequence a owl:Class .

lsp-core:AmministrazioneServizioSociale a owl:Class .

lsp-core:AssegnoDiInclusione a owl:Class .

lsp-core:Atto a owl:Class .

lsp-core:CoordinatoreServizioSociale a owl:Class .

lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:haNucleoFamiliareDiDomandaDiPrestazione ;
            owl:someValuesFrom owl:Thing ] .

lsp-core:GestoreServizioSociale a owl:Class .

lsp-core:PrestazioneDiSostegnoNucleoFamiliare a owl:Class .

lsp-core:ProgettoUtileAllaCollettività a owl:Class .

lsp-core:RichiedentePrestazioneDiSostegnoNucleoFamiliare a owl:Class .

lsp-core:TitolarePrestazioneDiSostegnoNucleoFamiliare a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom lsp-social:ComponenteNucleoFamiliare ] .

lsp-social:AnalisiPreliminareDelCaso a owl:Class ;
    rdfs:label "Analisi preliminare del caso"@it ;
    rdfs:subClassOf lsp-core:Atto,
        lsp-srv:QuestionarioDelRedattore,
        [ a owl:Restriction ;
            owl:onProperty lsp-social:versioneAnalisiPreliminare ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haAnalisiPreliminare ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "L'AP consiste in uno o più colloqui, effettuati dagli operatori sociali, con il nucleo familiare. Nel corso dell'AP vengono raccolte le informazioni sul nucleo nel suo complesso e sui  suoi singoli componenti necessarie alla eventuale erogazione di servizi, alla definizione del Patto per l’inclusione sociale e all' identificazione dei componenti tenuti a presentarsi ai CPI per l’attivazione lavorativa."@it .

lsp-social:AssegnazioneCasoDiNucleo a owl:Class ;
    rdfs:label "Assegnazione caso di nucleo"@it ;
    rdfs:subClassOf TI:TimeIndexedEvent,
        [ a owl:Restriction ;
            owl:onProperty lsp-social:assegnatoCasoAGestoreda ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haGestoreCasoDiNucleo ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haAssegnazioneCasoDiNucleo ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Definisce l'associazione tra un caso di nucleo familiare beneficiario e l'assistente sociale incaricato di gestire il caso (case manager) nel periodo considerato. È sottoclasse di TI:TimeIndexEvent."@it .

lsp-social:AttoDiAttribuzioneCategoriaObbligoAttivazione a owl:Class ;
    rdfs:label "Atto di attribuzione categoria obbligo attivazione"@it ;
    rdfs:subClassOf lsp-core:Atto,
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haAttoDiAttribuzioneCategoriaObbligo ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Azione attraverso la quale  si confermano sulla piattaforma GePI le informazioni fornite da INPS che danno luogo agli obblighi di attivazione"@it .

lsp-social:AttoDiGiustificatoMotivoDiAssenza a owl:Class ;
    rdfs:label "Atto di giustificato motivo di assenza"@it ;
    rdfs:subClassOf lsp-core:Atto ;
    rdfs:comment "Documentazione attestante un giustificato motivo per mancata presentazione o incontro"@it .

lsp-social:BeneficiarioADI a owl:Class ;
    rdfs:label "Beneficiario ADI"@it ;
    rdfs:subClassOf lsp-social:ComponenteDiNucleoFragileOInPovertà,
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haBeneficiarioPrestazioneDiSostegno ] ;
            owl:someValuesFrom lsp-core:AssegnoDiInclusione ] ;
    rdfs:comment "Destinatario di una misura di sostegno economico e di inclusione sociale e professionale introdotta dal decreto-legge 48/2023"@it .

lsp-social:CartaDiInclusione a owl:Class ;
    rdfs:label "Carta di inclusione"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:haIntestatarioCartaDiInclusione ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "La Carta di Inclusione è una carta di pagamento elettronica prepagata, emessa da PostePay in esecuzione del servizio affidato ai sensi dell’art. 81, comma 35, lettera b, del Decreto Legge n. 112/2008, convertito con modificazioni dalla Legge n. 133/2008, conformemente a quanto disposto dall’articolo 4, comma 8, del decreto-legge n. 48/2023, convertito, con modificazioni, dalla Legge n. 85 del 3 luglio 2023. Attraverso la Carta di Inclusione viene erogato, alle condizioni, nei limiti e con le modalità previste dal Decreto, il beneficio economico dell’Assegno di inclusione. Secondo quanto stabilito dall’articolo 5, comma 1, del D.M n. 154/2023, l’Adi può essere erogato suddividendo l’importo spettante tra i componenti maggiorenni del nucleo familiare che esercitano le responsabilità genitoriali o sono considerati nella scala di equivalenza, riconoscendo a ciascuno la quota pro-capite. La Carta,  oltre all’acquisto di beni e servizi presso gli esercizi commerciali in Italia convenzionati con il circuito Mastercard che rientrano nelle categorie di spesa previste dalla normativa di riferimento, consente di effettuare prelievi di contante nei limiti previsti dal Decreto ed effettuare un bonifico SEPA/Postagiro mensile in Ufficio Postale per pagare la rata prevista dal contratto di locazione in favore del locatore indicato nel contratto di locazione (fonte: Poste Italiane)."@it .

lsp-social:CasoDiNucleoFragileOInPovertà a owl:Class ;
    rdfs:label "Caso di nucleo fragile o in povertà"@it ;
    rdfs:subClassOf L0:Sequence,
        [ a owl:Restriction ;
            owl:onProperty lsp-social:dataInizioGestioneCaso ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haComponenteAttivoNelCaso ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haNucleoFamiliareFragileOInPovertà ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haPrestazioneDiSostegno ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:identificativoCasoNucleoFragile ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:statusDelCaso ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Famiglia che versa in condizione di povertà, intesa come deprivazione economica, ed esclusione sociale"@it .

lsp-social:CategoriaDiObbligo a owl:Class ;
    rdfs:label "Categoria di obbligo"@it ;
    rdfs:comment "Descrive le diverse categorie di obbligo derivanti dalla condizione del singolo individuo o del nucleo e dalla definizione degli impegni nel PaIS"@it .

lsp-social:CertificatoCondizioneDiDisabilità a owl:Class ;
    rdfs:label "Certificato condizione di disabilità"@it ;
    rdfs:subClassOf lsp-core:Atto,
        [ a owl:Restriction ;
            owl:onProperty TI:atTime ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Dati del certificato che attesta la condizione di disabilità "@it .

lsp-social:CertificatoCondizioneDiSvantaggio a owl:Class ;
    rdfs:label "Certificato condizione di svantaggio"@it ;
    rdfs:subClassOf lsp-core:Atto,
        [ a owl:Restriction ;
            owl:onProperty TI:atTime ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Certificato che attesta la condizione di svantaggio e la partecipazione in un programma di cura e/o assistenza rilasciato dalle pubbliche amministrazioni competenti, come i Comuni, i Servizi Sanitari o Socio-Sanitari e le strutture giudiziarie."@it .

lsp-social:ComponenteDiNucleoFragileOInPovertà a owl:Class ;
    rdfs:label "Componente di nucleo fragile o in povertà"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haComponenteNucleo ] ;
            owl:someValuesFrom lsp-social:NucleoFamiliareSocialmenteFragileOInPovertà ] .

lsp-social:ComponenteNucleoAttivoNelCaso a owl:Class ;
    rdfs:label "Componente nucleo attivo nel caso"@it ;
    rdfs:subClassOf TI:TimeIndexedEvent,
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haComponenteAttivoNelCaso ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:èComponenteNucleoAttivoDiCaso ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment " Componente del nucleo familiare soggetto a obblighi di attivazione "@it .

lsp-social:ComponenteNucleoFamiliare a owl:Class ;
    rdfs:label "Componente nucleo familiare"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haComponenteNucleo ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Componente del nucleo familiare non  soggetto a obblighi di attivazione"@it .

lsp-social:ComponenteNucleoFamiliareMaggiorenneConMenoDi29Anni a owl:Class ;
    rdfs:label "Componente nucleo familiare maggiorenne con meno di 29 anni"@it ;
    rdfs:subClassOf lsp-social:ComponenteNucleoFamiliare,
        [ a owl:Restriction ;
            owl:onProperty CPV:age ;
            owl:someValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:integer ;
                    owl:withRestrictions (
                            [ xsd:maxInclusive 29 ]
                            [ xsd:minInclusive 18 ] ) ] ] ;
    owl:disjointWith lsp-social:ComponenteNucleoFamiliareMinorenne ;
    rdfs:comment "Beneficiario dell’Assegno di inclusione appartenenti alla fascia di età compresa tra 18 e 28 anni soggetto alla verifica dell'adempimento dell'obbligo di istruzione. In caso di mancato adempimento nel Patto per l'Inclusione Sociale (PaIS) sarà previsto l’impegno all’iscrizione e alla frequenza di percorsi di istruzione degli adulti di primo livello o comunque funzionali all’adempimento del predetto obbligo di istruzione, pena la decadenza dal beneficio."@it .

lsp-social:ComponenteNucleoFamiliareMinorenne a owl:Class ;
    rdfs:label "Componente nucleo familiare minorenne"@it ;
    rdfs:subClassOf lsp-social:ComponenteNucleoFamiliare,
        [ a owl:Restriction ;
            owl:onProperty CPV:age ;
            owl:someValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:integer ;
                    owl:withRestrictions (
                            [ xsd:maxInclusive 18 ]
                            [ xsd:minExclusive 0 ] ) ] ] ;
    rdfs:comment "componente del nucleo familiare di età inferiore a 18 anni"@it .

lsp-social:ContributoDiComponenteAScalaDiEquivalenza a owl:Class ;
    rdfs:label "Contributo scala di equivalenza ADI"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:causaleContributoScalaEquivalenza ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:contributoScalaEquivalenza ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty TI:atTime ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haContributoScalaDiEquivalenza ] ;
            owl:someValuesFrom owl:Thing ] .

lsp-social:CoordinatorePAIS a owl:Class ;
    rdfs:label "Coordinatore PAIS"@it ;
    rdfs:subClassOf lsp-core:CoordinatoreServizioSociale ;
    rdfs:comment "Ruolo di persona che coordina gli operatori (cioè i \"case manager\", ovvero gli assistenti sociali) assegnando loro i nuclei familiari del territorio di competenza da avviare e monitorare nel percorso di inclusione sociale. Approva le segnalazioni di mancati adempimenti inviate dai case manager ai fini dell'invio ad INPS. "@it .

lsp-social:EquipeMultidisciplinareDelCaso a owl:Class ;
    rdfs:label "Equipe multidisciplinare del caso"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:haMembroEquipeMultidisciplinare ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haEquipeMultidisciplinareDelCaso ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Gruppo di professionisti composti da un’assistente sociale e da altri operatori afferenti alla rete dei servizi, individuati, ove necessario, dal  case manager sulla base dei bisogni del nucleo emersi nell’Analisi Preliminare ai fini della  definizione del PaIS e dell'attazione degl interventi di sostegno/accompagnamento del nucleo. "@it .

lsp-social:EsitoAnalisiPreliminareCaso a owl:Class ;
    rdfs:label "Esito analisi preliminare caso"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haEsitoAnalisiPreliminareCaso ] ;
            owl:someValuesFrom owl:Thing ] .

lsp-social:EsitoImpegnoPaIS a owl:Class ;
    rdfs:label "Esito impegno PaIS"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haEsitoImpegnoPaIS ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica gli impegni assunti dal componente del nucleo familiare all'interno del PaIS "@it .

lsp-social:EsitoQuadroAnalisiCaso a owl:Class ;
    rdfs:label "Esito quadro analisi caso"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haEsitoQuadroAnalisiCaso ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica eventuali esiti emersi dal quadro di analisi ulteriori rispetto agli esiti della AP"@it .

lsp-social:EsitoRisultatoAttesoObiettivoPaIS a owl:Class ;
    rdfs:label "Esito risultato atteso obiettivo PaIS"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haEsitoRisultatoAttesoObiettivoPaIS ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica il risultato atteso rispetto all'obiettivo indicato nel PaIS "@it .

lsp-social:GestioneDiDomandaDiCasoDiNucleo a owl:Class ;
    rdfs:label "Gestione di domanda di caso di nucleo"@it ;
    rdfs:subClassOf L0:Sequence,
        TI:TimeIndexedEvent,
        [ a owl:Restriction ;
            owl:onProperty lsp-social:identificatoreGestioneDomandaCaso ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haGestioneDiDomandaDiCasoDiNucleo ] ;
            owl:someValuesFrom owl:Thing ] .

lsp-social:GestoreCasoInclusioneSociale a owl:Class ;
    rdfs:label "Gestore caso inclusione sociale"@it ;
    rdfs:subClassOf lsp-core:GestoreServizioSociale ;
    rdfs:comment "Ruolo di persona attribuito alla figura di riferimento (ovvero il case manager) dei beneficiari dell'Assegno di Inclusione che, oltre a redigere i contenuti relativi all'Analisi preliminare, al Quadro di Analisi e al Patto per l'inclusione sociale, accompagna e monitora il nucleo familiare lungo tutto il percorso di inclusione. In caso di inadempienze da parte dei beneficiari invia le relative segnalazioni al Coordinatore PaIS per l'approvazione. "@it .

lsp-social:ImpegnoPaIS a owl:Class ;
    rdfs:label "Impegno PaIS"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:haTipoDiImpegno ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:èImpegnoPerComponenteNucleo ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haImpegnoPaIS ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "La disponibilità a svolgere determinate attività e a seguire determinate regole di comportamento a cui il beneficio economico è condizionato"@it .

lsp-social:IntestatarioContrattoLocazioneNucleoFamiliare a owl:Class ;
    rdfs:label "Intestatario contratto locazione nucleo familiare"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haIntestatarioContrattoLocazioneNucleoFamiliare ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica il nominativo dell'intestatario del contratto di locazione "@it .

lsp-social:MembroEquipeMultidisciplinareDelCaso a owl:Class ;
    rdfs:label "Membro equipe multidisciplinare del caso"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:avvisoMembroRiferimentoEquipe ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haProfessioneMembroEquipe ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom CPV:Alive ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haMembroEquipeMultidisciplinare ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "La composizione dell’equipe multidisciplinare (EM) varia in funzione delle caratteristiche, della situazione e dei bisogni del nucleo familiare. A titolo esemplificativo può comprendere le seguenti figure: operatori dei centri per l’impiego, operatori dei servizi sanitari e specialistici, operatori dei servizi socio-educativi e della prima infanzia, insegnanti, pediatri, mediatori culturali, ecc. Vista la differenziazione delle forme organizzative degli ATS, è plausibile ipotizzare l’EM come gruppo a geometria variabile composto da uno «zoccolo duro» di operatori (EM base) e operatori che si possono aggregare a seconda della situazione (EM allargata), in esito all’Analisi Preliminare"@it .

lsp-social:NucleoFamiliare a owl:Class ;
    rdfs:label "Nucleo familiare"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:haComponenteNucleo ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Componenti la famiglia anagrafica all'atto di presentazione della domanda ADI"@it .

lsp-social:NucleoFamiliareSocialmenteFragileOInPovertà a owl:Class ;
    rdfs:label "Nucleo familiare in condizione di povertà "@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haNucleoFamiliareDiPAD ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Nucleo familiare in condizione di povertà ed esclusione sociale "@it .

lsp-social:ObbligoComponenteNucleoDelCaso a owl:Class ;
    rdfs:label "Obbligo componente nucleo del caso"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:haCategoriaDiObbligoDiAttivazione ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haComponenteNucleoConCategoriaObbligoAttivazione ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:indicaObbligoComponenteNucleoDelCaso ] ;
            owl:someValuesFrom owl:Thing ] .

lsp-social:ObiettivoPaIS a owl:Class ;
    rdfs:label "Obiettivo PaIS"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:descrizioneObiettivo ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haRisultatoAttesoDiObiettivo ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:idObiettivo ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "cambiamento/miglioramento auspicato er il nucleo familiare e quindi  finalità da perseguire (obiettivi generali) e tappe da raggiungere (risultati attesi)."@it .

lsp-social:PartecipazioneComponenteAIncontro a owl:Class ;
    rdfs:label "Partecipazione componente a incontro"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haPartecipanteIncontro ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:partecipaAIncontro ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica l'avvenuta partecipazione ad un incontro del componente il nucleo familiare"@it .

lsp-social:PartecipazionePUC a owl:Class ;
    rdfs:label "Partecipazione PUC"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:descrizionePUC ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haPartecipantePUC ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haPUC ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:identificativoPUC ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:statoDiPUC ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Nell’ambito del percorso personalizzato può essere previsto l’impegno dei beneficiari alla partecipazione a Progetti Utili alla Collettività (PUC)."@it .

lsp-social:PattoAttivazioneDigitaleNucleo a owl:Class ;
    rdfs:label "Patto attivazione digitale nucleo"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:haNucleoFamiliareDiPAD ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haSottoscrittorePAD ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haPADNucleoFamiliare ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica l'avventua sottoscrizione del PAD nucleo (la data ????) "@it .

lsp-social:PattoInclusioneSocialeDelCaso a owl:Class ;
    rdfs:label "Patto inclusione sociale del caso"@it ;
    rdfs:subClassOf lsp-core:Atto,
        [ a owl:Restriction ;
            owl:onProperty lsp-social:versionePaIS ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haPattoInclusioneSocialeDelCaso ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Patto definito dai servizi sociali e dal nucleo sulla base di una valutazione multidimensionale dei bisogni del nucleo familiare"@it .

lsp-social:PeriodoDiGiustificatoMotivoAssenza a owl:Class ;
    rdfs:label "Periodo di giustificato motivo assenza"@it ;
    rdfs:subClassOf TI:TimeIndexedEvent ;
    rdfs:comment "Indica il periodo in cui è possibile giustificare il mancato adempimento della presentazione come prodotto nel giustificato motivo"@it .

lsp-social:ProfessioneMembroEquipe a owl:Class ;
    rdfs:label "Professione membro equipe"@it ;
    rdfs:comment "Indica la professione del componente dell'equipe multidisciplinare. La composizione dell’equipe multidisciplinare (EM) varia in funzione delle caratteristiche, della situazione e dei bisogni del nucleo familiare. A titolo esemplificativo può comprendere le seguenti figure: operatori dei centri per l’impiego, operatori dei servizi sanitari e specialistici, operatori dei servizi socio-educativi e della prima infanzia, insegnanti, pediatri, mediatori culturali, ecc. Vista la differenziazione delle forme organizzative degli ATS, è plausibile ipotizzare l’EM come gruppo a geometria variabile composto da uno «zoccolo duro» di operatori (EM base) e operatori che si possono aggregare a seconda della situazione (EM allargata), in esito all’Analisi Preliminare"@it .

lsp-social:QuadroDiAnalisiDelCaso a owl:Class ;
    rdfs:label "Quadro di analisi del caso"@it ;
    rdfs:subClassOf lsp-core:Atto,
        lsp-srv:QuestionarioDelRedattore,
        [ a owl:Restriction ;
            owl:onProperty lsp-social:identificativoQuadroAnalisi ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:versioneQuadroAnalisi ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haQuadroDiAnalisi ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica che è necessario procedere con il quadro di analisi"@it .

lsp-social:RichiedenteADI a owl:Class ;
    rdfs:label "Richiedente ADI"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-core:presentaDomandaPrestazioneDiSostegno ;
            owl:someValuesFrom [ a owl:Restriction ;
                    owl:onProperty [ owl:inverseOf lsp-core:haDomandaPrestazioneDiSostegno ] ;
                    owl:someValuesFrom lsp-core:AssegnoDiInclusione ] ] ;
    rdfs:comment "Richiedente la misura di  sostegno economico e di inclusione sociale e professionale introdotta dal decreto-legge 48.2023"@it .

lsp-social:RisultatoAttesoDiObiettivo a owl:Class ;
    rdfs:label "Risultato atteso di obiettivo"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:descrizioneRisultatoAttesoObiettivo ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:idRisultatoAttesoObiettivo ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "tappe e risultati da raggiungere nel percorso di reinserimento sociale e lavorativo progettato"@it .

lsp-social:ScalaDiEquivalenzaNucleo a owl:Class ;
    rdfs:label "Scala di equivalenza nucleo"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:haContributoScalaDiEquivalenza ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:valoreTotaleScalaDiEquivalenza ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty TI:atTime ;
            owl:someValuesFrom owl:Thing ] .

lsp-social:SostegnoPaIS a owl:Class ;
    rdfs:label "Sostegno PaIS"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-social:descrizioneTipologiaSostegnoPaIS ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haTipoDiSostegno ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:idTipologiaSostegnoPaIS ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:èSostegnoPerComponenteNucleo ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica la tipologia di sostegno/intervento di supporto ai favore del nucleo familiare o di un suo componente"@it .

lsp-social:StatoDiAnalisiPreliminare a owl:Class ;
    rdfs:label "Stato di analisi preliminare"@it ;
    rdfs:subClassOf lsp-social:StatoDiValutazioneMultidimensionale,
        [ a owl:Restriction ;
            owl:onProperty L0:precedes ;
            owl:someValuesFrom lsp-social:StatoDiQuadroDiAnalisi ] ;
    owl:disjointWith lsp-social:StatoDiQuadroDiAnalisi ;
    rdfs:comment "Indica se l'AP è in corso o è stata completata"@it .

lsp-social:StatoDiAttesaPrimoIncontro a owl:Class ;
    rdfs:label "Stato di attesa primo incontro"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso,
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf L0:hasFirstMember ] ;
            owl:someValuesFrom lsp-social:GestioneDiDomandaDiCasoDiNucleo ] ;
    rdfs:comment "Indica che il primo incontro con il nucleo beneficiario dell'ADI, previsto entro 120 giorni dalla sottoscrizione del PAD, non è ancora avvenuto"@it .

lsp-social:StatoDiGestioneDiDomandaDiCaso a owl:Class ;
    rdfs:label "Stato di gestione di domanda di caso"@it ;
    rdfs:subClassOf TI:TimeIndexedEvent,
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-social:haStatoDiGestioneDiDomandaDiCaso ] ;
            owl:someValuesFrom owl:Thing ] .

lsp-social:StatoDiIdentificazioneObbligoDiAttivazione a owl:Class ;
    rdfs:label "Stato di identificazione obbligo di attivazione"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso .

lsp-social:StatoDiIncontroDiMonitoraggio a owl:Class ;
    rdfs:label "Stato di incontro di monitoraggio"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso ;
    rdfs:comment "Indica se l'incontro di monitoraggio è stato effettuato, nei tempi previsti, o se ancora non è stato effettuato"@it .

lsp-social:StatoDiIncontroValutato a owl:Class ;
    rdfs:label "Stato di incontro valutato"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso,
        [ a owl:Restriction ;
            owl:onProperty lsp-social:avvisoDiIncontroEffettuato ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-social:haPartecipanteIncontro ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Indica che l'incontro ha portato ad una valutazione/registrazione"@it .

lsp-social:StatoDiPartecipazionePUC a owl:Class ;
    rdfs:label "Stato di partecipazione PUC"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso ;
    rdfs:comment "Indica se il componente sta partecipando ad un PUC"@it .

lsp-social:StatoDiPianificatoIncontroDiMonitoraggio a owl:Class ;
    rdfs:label "Stato di pianificato incontro di monitoraggio"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso,
        [ a owl:Restriction ;
            owl:onProperty L0:precedes ;
            owl:someValuesFrom lsp-social:StatoDiIncontroDiMonitoraggio ] ;
    rdfs:comment "Indica che l'incontro di monitoraggio prevede una data"@it .

lsp-social:StatoDiPianificatoPrimoIncontro a owl:Class ;
    rdfs:label "Stato di pianificato primo incontro"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso ;
    rdfs:comment "Indica che il primo incontro prevede una data"@it .

lsp-social:StatoDiQuadroDiAnalisi a owl:Class ;
    rdfs:label "Stato di quadro di analisi"@it ;
    rdfs:subClassOf lsp-social:StatoDiValutazioneMultidimensionale ;
    rdfs:comment "Indica se il quadro di analisi è completato o in corso"@it .

lsp-social:StatoDiSottoscrizionePaIS a owl:Class ;
    rdfs:label "Stato di sottoscrizione PaIS"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso,
        [ a owl:Restriction ;
            owl:onProperty L0:precedes ;
            owl:someValuesFrom lsp-social:StatoDiIncontroDiMonitoraggio ] ;
    rdfs:comment "Indica se il PaIS è stato sottoscritto"@it .

lsp-social:StatoDiValutazioneMultidimensionale a owl:Class ;
    rdfs:label "Stato di valutazione multidimensionale"@it ;
    rdfs:subClassOf lsp-social:StatoDiGestioneDiDomandaDiCaso,
        [ a owl:Restriction ;
            owl:onProperty L0:precedes ;
            owl:someValuesFrom lsp-social:StatoDiIdentificazioneObbligoDiAttivazione ] ;
    rdfs:comment "Indica se la valutazione multidimensionale è in corso o  chiusa"@it .

lsp-social:TipoDiImpegno a owl:Class ;
    rdfs:label "Tipo di impegno"@it .

lsp-social:TipoDiSostegno a owl:Class ;
    rdfs:label "Tipo di sostegno"@it .

lsp-srv:ModelloDelQuestionario a owl:Class .

lsp-srv:QuestionarioDelRedattore a owl:Class .

TI:TimeIndexedEvent a owl:Class .

[] a owl:Class ;
    rdfs:subClassOf lsp-srv:ModelloDelQuestionario ;
    owl:oneOf (
            lsp-social:QuestionarioDiAnalisiPreliminare
            lsp-social:QuestionarioDiQuadroDiAnalisi ) .

