        "RDF/XML distribution of the Labour and Social Policies Ministry ontology for the management of Social Inclusion Pacts - GePI"@en .

lsp-social:QuestionarioDiAnalisiPreliminare a owl:NamedIndividual ;
    rdfs:label "Questionario di analisi preliminare"@it .

lsp-social:QuestionarioDiQuadroDiAnalisi a owl:NamedIndividual ;
    rdfs:label "Questionario di quadro di analisi"@it .

