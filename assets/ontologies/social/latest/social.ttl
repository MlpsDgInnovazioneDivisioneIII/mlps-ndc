[] a owl:AllDisjointClasses ;
    owl:members (
            lsp-social:StatoDiAttesaPrimoIncontro
            lsp-social:StatoDiIdentificazioneObbligoDiAttivazione
            lsp-social:StatoDiIncontroDiMonitoraggio
            lsp-social:StatoDiIncontroValutato
            lsp-social:StatoDiPartecipazionePUC
            lsp-social:StatoDiPianificatoIncontroDiMonitoraggio
            lsp-social:StatoDiPianificatoPrimoIncontro
            lsp-social:StatoDiSottoscrizionePaIS
            lsp-social:StatoDiValutazioneMultidimensionale ) .

[] a owl:Restriction ;
    owl:onProperty RO:holdsRoleInTime ;
    owl:someValuesFrom lsp-social:IntestatarioContrattoLocazioneNucleoFamiliare ;
    rdfs:subClassOf lsp-social:ComponenteNucleoFamiliare .

[] a owl:Restriction ;
    owl:onProperty [ owl:inverseOf CLV:hasCountry ] ;
    owl:someValuesFrom [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf rpo:residenceInAddress ] ;
            owl:someValuesFrom [ a owl:Restriction ;
                    owl:onProperty [ owl:inverseOf rpo:hasRegisteredResidence ] ;
                    owl:someValuesFrom lsp-social:ComponenteNucleoFamiliare ] ] ;
    rdfs:subClassOf [ a owl:Class ;
            owl:oneOf (
                    countries:Italy ) ] .

[] rdfs:subPropertyOf rpo:belongsToRegisteredFamilyOrCohabitance ;
    owl:inverseOf lsp-social:haComponenteNucleo .

