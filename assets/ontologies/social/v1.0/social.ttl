lsp-social: a owl:Ontology ;
    owl:versionIRI lsp-social:1.0 ;
    owl:imports CLV:,
        COV:,
        CPV:,
        L0:,
        RO: ;
    rdfs:label "Ontologia della gestione dei patti per l'inclusione sociale (GePI) del Ministero Del Lavoro e delle Politiche Sociali"@it,
        "Ontology for the management of Social Inclusion Pacts (GePI) of the Ministry of Labor and Social Policies"@en ;
    rdfs:comment "Ontologia del Ministero Del Lavoro e delle Politiche Sociali relativa al dominio GePi definisce in modo strutturato e interoperabile dati, relazioni e concetti relativi alla gestione dei Patti per l’Inclusione Sociale, garantendo uniformità semantica, integrazione informativa e supporto ai processi digitali della piattaforma che è parte integrante del Sistema informativo per l'inclusione sociale e lavorativa (SIISL)"@it,
        "Ontology of the Ministry of Labour and Social Policies related to the GePi domain defines in a structured and interoperable way the data, relationships, and concepts concerning the management of Social Inclusion Pacts, ensuring semantic uniformity, information integration, and support for the digital processes of the platform, which is an integral part of the Social and Labour Inclusion Information System (SIISL)."@en ;
    owl:versionInfo "1.0 - Modificata il 26 Febbraio 2026"@it,
        "1.0 - Modified on 26 February 2026"@en ;
    rdfs:isDefinedBy lsp-social: ;
    adms:acronym "lsp" ;
    adms:hasContributor <https://w3id.org/italia/data/organization/public-organization/td> ;
    adms:hasFormalityLevel adms:Formal ;
    adms:hasKeyClass lsp-social:PattoAttivazioneDigitaleNucleo,
        lsp-social:PattoInclusioneSocialeDelCaso ;
    adms:hasOntologyLanguage adms:OWL ;
    adms:hasSemanticAssetDistribution <https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-N-TRIPLES>,
        <https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-RDF-TURTLE>,
        <https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-RDF-XML> ;
    adms:hasTask adms:AnnotationTask,
        adms:QueryFormulationTask,
        adms:SearchTask ;
    adms:last lsp-social:1.0 ;
    adms:officialURI "https://w3id.org/italia/labour-social-policies/onto/social/"^^xsd:anyURI ;
    adms:prefix "lsp-social" ;
    adms:semanticAssetInUse <https://w3id.org/italia/data/project/NDC> ;
    adms:status "draft" ;
    adms:target "Cittadini"@it,
        "Imprese"@it,
        "Pubbliche Amministrazioni"@it ;
    adms:type adms:ServiceOnytology ;
    dcat:contactPoint <https://w3id.org/italia/labour-social-policies/data/organization/DGInnovazioneDiv3> ;
    dcat:keyword "digital core activation agreement"@en,
        "family unit"@en,
        "nucleo familiare"@it,
        "patto di attivazione digitale del nucleo"@it,
        "patto di inclusione sociale del caso"@it,
        "social inclusion pact of the case"@en ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/SOCI> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:creator <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:description "Ontologia del Ministero Del Lavoro e delle Politiche Sociali relativa al dominio GePi definisce in modo strutturato e interoperabile dati, relazioni e concetti relativi alla gestione dei Patti per l’Inclusione Sociale, garantendo uniformità semantica, integrazione informativa e supporto ai processi digitali della piattaforma che è parte integrante del Sistema informativo per l'inclusione sociale e lavorativa (SIISL)"@it,
        "Ontology of the Ministry of Labour and Social Policies related to the GePi domain defines in a structured and interoperable way the data, relationships, and concepts concerning the management of Social Inclusion Pacts, ensuring semantic uniformity, information integration, and support for the digital processes of the platform, which is an integral part of the Social and Labour Inclusion Information System (SIISL)."@en ;
    dct:identifier "https://w3id.org/italia/labour-social-policies/onto/social" ;
    dct:issued "2026-02-26T00:00:00+00:00"^^xsd:dateTime ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG>,
        <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-02-26T00:00:00+00:00"^^xsd:dateTime ;
    dct:publisher <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:rightsHolder <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:title "Ontologia della gestione dei patti per l'inclusione sociale (GePI) del Ministero Del Lavoro e delle Politiche Sociali"@it,
        "Ontology for the management of Social Inclusion Pacts (GePI) of the Ministry of Labor and Social Policies"@en .

### Object Properties

CLV:hasCountry a owl:ObjectProperty .

