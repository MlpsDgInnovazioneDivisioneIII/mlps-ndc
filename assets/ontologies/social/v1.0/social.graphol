        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/CartaDiInclusione</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/CartaDiInclusione</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Carta di inclusione</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/CartaDiInclusione</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>La Carta di Inclusione è una carta di pagamento elettronica prepagata, emessa dal gestore conformemente a quanto disposto dall’articolo 4, comma 8, del decreto-legge n. 48/2023, attraverso la quale è erogato il beneficio economico dell’Assegno di inclusione.</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Caso associato ad un nucleo familiare richiedente l'ADI</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Si intende il caso gestito dal servizio sociale attraverso un case manager relativo ad un nucleo in condizione di povertà richiedente l'ADI</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/labour-social-policies/onto/social/CategoriaDiObbligo</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/CategoriaDiObbligo</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Categoria di obbligo</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/CategoriaDiObbligo</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Descrive le diverse categorie di obbligo cui sono tenuti i beneficiai ADI, che determinano  la definizione con i servizi sociali di impegni nel Patto per l'Inclusione sociale (PaIS) e la definizione con centri per l'impiego o i servizi per il lavoro di impegni nel Patto di servizio personalizzato (PSP).</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
