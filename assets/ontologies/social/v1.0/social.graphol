              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Gestore caso inclusione sociale</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/labour-social-policies/onto/social/GestoreCasoInclusioneSociale</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Ruolo di persona attribuito alla figura di riferimento (ovvero il case manager) dei beneficiari dell'Assegno di Inclusione che, oltre a redigere i contenuti relativi all'Analisi preliminare, al Quadro di Analisi e al Patto per l'inclusione sociale, accompagna e monitora il nucleo familiare lungo tutto il percorso di inclusione. In caso di inadempienze da parte dei beneficiari invia le relative segnalazioni al Coordinatore PaIS per l'approvazione. </lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
          </annotations>
        </iri>
