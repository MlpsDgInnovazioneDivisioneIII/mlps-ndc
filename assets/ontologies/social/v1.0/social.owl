    <!-- https://w3id.org/italia/labour-social-policies/onto/core/GestoreServizioSociale -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/GestoreServizioSociale"/>



    <!-- https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegnoNucleoFamiliare -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegnoNucleoFamiliare"/>



    <!-- https://w3id.org/italia/labour-social-policies/onto/core/ProgettoDiUtilitàCollettiva -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/ProgettoDiUtilitàCollettiva"/>



    <!-- https://w3id.org/italia/labour-social-policies/onto/core/RichiedentePrestazioneDiSostegnoNucleoFamiliare -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/RichiedentePrestazioneDiSostegnoNucleoFamiliare"/>



    <!-- https://w3id.org/italia/labour-social-policies/onto/core/TitolarePrestazioneDiSostegnoNucleoFamiliare -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/TitolarePrestazioneDiSostegnoNucleoFamiliare">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliare"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/AnalisiPreliminareDelCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/AnalisiPreliminareDelCaso">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/QuestionarioDelRedattore"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haAnalisiPreliminare"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/versioneAnalisiPreliminare"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">L&apos;Analisi preliminare (AP) consiste in uno o più colloqui, effettuati dagli operatori sociali con il nucleo familiare. Nel corso dell&apos;AP vengono raccolte le informazioni sul nucleo nel suo complesso e sui  suoi singoli componenti necessarie alla eventuale erogazione di servizi, alla definizione del Patto per l’inclusione sociale e all&apos; identificazione dei componenti tenuti a presentarsi ai CPI per l’attivazione lavorativa.</rdfs:comment>
        <rdfs:label xml:lang="it">Analisi preliminare del caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/AssegnazioneCasoDiNucleo -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/AssegnazioneCasoDiNucleo">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/assegnatoCasoAGestoreDa"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haGestoreCasoDiNucleo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haAssegnazioneCasoDiNucleo"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Definisce l&apos;associazione tra un caso di nucleo familiare beneficiario e l&apos;assistente sociale incaricato di gestire il caso (case manager) nel periodo considerato. È sottoclasse di TI:TimeIndexEvent.</rdfs:comment>
        <rdfs:label xml:lang="it">Assegnazione caso di nucleo</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/AttoDiAttribuzioneCategoriaObbligoAttivazione -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/AttoDiAttribuzioneCategoriaObbligoAttivazione">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haAttoDiAttribuzioneCategoriaObbligo"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Azione attraverso la quale  si definisce per ciascun componente il nucleo familiare la sussistenza o meno di obblighi di attivazione sulla base dei dati anagrafici e socio-sanitari, ove necessario integrati con le valutazioni dei servizi sociali sulla condizione di attivabile al lavoro.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto di attribuzione categoria obbligo attivazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/AttoDiGiustificatoMotivoDiAssenza -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/AttoDiGiustificatoMotivoDiAssenza">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:comment xml:lang="it">Documentazione attestante un giustificato motivo per mancata presentazione ai servizi nei tempi previsti dalla norma o mancata presentazione alle convocazioni.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto di giustificato motivo di assenza</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/BeneficiarioADI -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/BeneficiarioADI">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteDiNucleoFragileOInPovertà"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haBeneficiarioPrestazioneDiSostegno"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AssegnoDiInclusione"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Destinatario della misura di sostegno economico e di inclusione sociale e professionale introdotta dal decreto-legge 48/2023</rdfs:comment>
        <rdfs:label xml:lang="it">Beneficiario ADI</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/CartaDiInclusione -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/CartaDiInclusione">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haIntestatarioCartaDiInclusione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">La Carta di Inclusione è una carta di pagamento elettronica prepagata, emessa dal gestore conformemente a quanto disposto dall’articolo 4, comma 8, del decreto-legge n. 48/2023, attraverso la quale è erogato il beneficio economico dell’Assegno di inclusione.</rdfs:comment>
        <rdfs:label xml:lang="it">Carta di inclusione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Sequence"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haComponenteAttivoNelCaso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haNucleoFamiliareFragileOInPovertà"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haPrestazioneDiSostegno"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/dataInizioGestioneCaso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/identificativoCasoNucleoFragile"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/statusDelCaso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Si intende il caso gestito dal servizio sociale attraverso un case manager relativo ad un nucleo in condizione di povertà richiedente l&apos;ADI</rdfs:comment>
        <rdfs:label xml:lang="it">Caso associato ad un nucleo familiare richiedente l&apos;ADI</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/CategoriaDiObbligo -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/CategoriaDiObbligo">
        <rdfs:comment xml:lang="it">Descrive le diverse categorie di obbligo cui sono tenuti i beneficiai ADI, che determinano  la definizione con i servizi sociali di impegni nel Patto per l&apos;Inclusione sociale (PaIS) e la definizione con centri per l&apos;impiego o i servizi per il lavoro di impegni nel Patto di servizio personalizzato (PSP).</rdfs:comment>
        <rdfs:label xml:lang="it">Categoria di obbligo</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/CertificatoCondizioneDiDisabilità -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/CertificatoCondizioneDiDisabilità">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Dati del certificato che attesta la condizione di disabilità </rdfs:comment>
        <rdfs:label xml:lang="it">Certificato condizione di disabilità</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/CertificatoCondizioneDiSvantaggio -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/CertificatoCondizioneDiSvantaggio">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Dati del certificato che attesta la condizione di svantaggio e la partecipazione ad un programma di cura e/o assistenza rilasciato dalle pubbliche amministrazioni competenti, come i Comuni, i Servizi Sanitari o Socio-Sanitari e le strutture giudiziarie.</rdfs:comment>
        <rdfs:label xml:lang="it">Certificato condizione di svantaggio</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ComponenteDiNucleoFragileOInPovertà -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteDiNucleoFragileOInPovertà">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haComponenteNucleo"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/NucleoFamiliareSocialmenteFragileOInPovertà"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Si intendono i componenti di un nucleo familiare in condizione di fragilità/povertà richiedente l&apos;ADI.</rdfs:comment>
        <rdfs:label xml:lang="it">Componente di Nucleo familiare in condizioni di povertà richiedente l&apos;ADI</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoAttivoNelCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoAttivoNelCaso">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haComponenteAttivoNelCaso"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/èComponenteNucleoAttivoDiCaso"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Componente del nucleo familiare soggetto a obblighi di attivazione lavorativa e/o sociale</rdfs:comment>
        <rdfs:label xml:lang="it">Componente nucleo attivo nel caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliare -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliare">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haTipoPercorsoSocialeLavorativo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haComponenteNucleo"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Generico componente di un  nucleo familiare generico</rdfs:comment>
        <rdfs:label xml:lang="it">Componente nucleo familiare</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliareMaggiorenneConMenoDi29Anni -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliareMaggiorenneConMenoDi29Anni">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliare"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CPV/age"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</xsd:minInclusive>
                            </rdf:Description>
                            <rdf:Description>
                                <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">29</xsd:maxInclusive>
                            </rdf:Description>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliareMinorenne"/>
        <rdfs:comment xml:lang="it">Componente del nucleo appartenente alla fascia di età compresa tra 18 e 28 anni</rdfs:comment>
        <rdfs:label xml:lang="it">Componente nucleo familiare maggiorenne con meno di 29 anni</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliareMinorenne -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliareMinorenne">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/ComponenteNucleoFamiliare"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CPV/age"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</xsd:minExclusive>
                            </rdf:Description>
                            <rdf:Description>
                                <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</xsd:maxInclusive>
                            </rdf:Description>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Componente del nucleo familiare di età inferiore a 18 anni</rdfs:comment>
        <rdfs:label xml:lang="it">Componente nucleo familiare minorenne</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ContributoDiComponenteAScalaDiEquivalenza -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ContributoDiComponenteAScalaDiEquivalenza">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haContributoScalaDiEquivalenza"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/causaleContributoScalaEquivalenza"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/contributoScalaEquivalenza"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica il contributo alla scala di equivalenza del nucleo familiare portato da un suo singolo componente.</rdfs:comment>
        <rdfs:label xml:lang="it">Contributo di componente a scala di equivalenza</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/CoordinatorePAIS -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/CoordinatorePAIS">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/CoordinatoreServizioSociale"/>
        <rdfs:comment xml:lang="it">Ruolo di persona che coordina gli operatori (cioè i &quot;case manager&quot;, ovvero gli assistenti sociali) assegnando loro i nuclei familiari del territorio di competenza da avviare e monitorare nel percorso di inclusione sociale. Approva le segnalazioni di mancati adempimenti inviate dai case manager ai fini dell&apos;invio ad INPS. </rdfs:comment>
        <rdfs:label xml:lang="it">Coordinatore PAIS</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/EquipeMultidisciplinareDelCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/EquipeMultidisciplinareDelCaso">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haMembroEquipeMultidisciplinare"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haEquipeMultidisciplinareDelCaso"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Gruppo di professionisti composti da un’assistente sociale e da operatori di altri settori disciplinari afferenti alla rete dei servizi, individuati, ove necessario, dal  case manager sulla base delle caratteristiche, della situazione e dei bisogni del nucleo familiare emersi nell’Analisi Preliminare ai fini della  definizione del PaIS e dell&apos;attazione degli interventi di sostegno/accompagnamento del nucleo.</rdfs:comment>
        <rdfs:label xml:lang="it">Equipe multidisciplinare del caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/EsitoAnalisiPreliminareCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/EsitoAnalisiPreliminareCaso">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haEsitoAnalisiPreliminareCaso"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Si intende il risultato della valutazione multidimensionale effettuata dai servizi sociali al singolo soggetto. Una specifica sezione della AP contiene la sintesi delle indicazioni utili ad orientare il percorso per la successiva definizione del progetto, con particolare riferimento alla presenza di componenti da indirizzare anche ai servizi per il lavoro, alla eventuale presenza di bisogni complessi e alla opportunità di coinvolgere una equipe multidisciplinare o attivare servizi specialistici.</rdfs:comment>
        <rdfs:label xml:lang="it">Esito analisi preliminare caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/EsitoImpegnoPaIS -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/EsitoImpegnoPaIS">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haEsitoImpegnoPaIS"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica l&apos;esito della valutazione degli impegni assunti dal componente del nucleo familiare all&apos;interno del progetto personalizzato (Patto per l&apos;Inclusione Sociale - PaIS) effettuata negli incontri di monitoraggio</rdfs:comment>
        <rdfs:label xml:lang="it">Esito impegno PaIS</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/EsitoQuadroAnalisiCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/EsitoQuadroAnalisiCaso">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haEsitoQuadroAnalisiCaso"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica eventuali esiti emersi dal quadro di analisi ulteriori rispetto agli esiti della AP</rdfs:comment>
        <rdfs:label xml:lang="it">Esito quadro analisi caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/EsitoRisultatoAttesoObiettivoPaIS -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/EsitoRisultatoAttesoObiettivoPaIS">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haEsitoRisultatoAttesoObiettivoPaIS"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica il risultato atteso rispetto all&apos;obiettivo indicato nel PaIS </rdfs:comment>
        <rdfs:label xml:lang="it">Risultato atteso rispetto ad un obiettivo</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/GestioneDiDomandaDiCasoDiNucleo -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/GestioneDiDomandaDiCasoDiNucleo">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Sequence"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haGestioneDiDomandaDiCasoDiNucleo"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/identificatoreGestioneDomandaCaso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Collegamento gestionale di una singola  domanda al relativo caso (nel tempo possono susseguirsi più domande afferenti al medesimo caso)</rdfs:comment>
        <rdfs:label xml:lang="it">Relazione tra la domada e il caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/GestoreCasoInclusioneSociale -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/GestoreCasoInclusioneSociale">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/GestoreServizioSociale"/>
        <rdfs:comment xml:lang="it">Ruolo di persona attribuito alla figura di riferimento (ovvero il case manager) dei beneficiari dell&apos;Assegno di Inclusione che, oltre a redigere i contenuti relativi all&apos;Analisi preliminare, al Quadro di Analisi e al Patto per l&apos;inclusione sociale, accompagna e monitora il nucleo familiare lungo tutto il percorso di inclusione. In caso di inadempienze da parte dei beneficiari invia le relative segnalazioni al Coordinatore PaIS per l&apos;approvazione. </rdfs:comment>
        <rdfs:label xml:lang="it">Gestore caso inclusione sociale</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ImpegnoPaIS -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ImpegnoPaIS">
