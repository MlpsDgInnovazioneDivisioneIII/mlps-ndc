            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/avvisoMembroRiferimentoEquipe"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica il professionista componente della equipe multidisciplinare che ha incarico il nucleo o un suo componente.</rdfs:comment>
        <rdfs:label xml:lang="it">Membro equipe multidisciplinare del caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/NucleoFamiliare -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/NucleoFamiliare">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haComponenteNucleo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Il nucleo familiare generico è l&apos;insieme di persone coabitanti aventi dimora abituale nello stesso comune, legate da vincoli di matrimonio, unione civile, parentela, affinità, adozione o da legami affettivi. Coincide generalmente con la famiglia anagrafica, ma può differire ai fini ISEE o fiscali, includendo anche persone non conviventi.</rdfs:comment>
        <rdfs:label xml:lang="it">Nucleo familiare generico</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/NucleoFamiliareSocialmenteFragileOInPovertà -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/NucleoFamiliareSocialmenteFragileOInPovertà">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haNucleoFamiliareDiPAD"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Nucleo familiare in condizione di povertà ed esclusione sociale richiedente l&apos;ADI come definito ai fini ISEE</rdfs:comment>
        <rdfs:label xml:lang="it">Nucleo familiare in condizione di povertà richiedente l&apos;ADI</rdfs:label>
    </owl:Class>



