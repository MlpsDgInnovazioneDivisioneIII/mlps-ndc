    <!-- https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-N-TRIPLES -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/labour-social-policies/data/social/distribution/MLPSSOCIAL-N-TRIPLES">
        <rdf:type rdf:resource="http://dati.gov.it/onto/dcatapit#Distribution"/>
        <rdf:type rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdf:type rdf:resource="https://w3id.org/italia/onto/ADMS/SemanticAssetDistribution"/>
        <dct:description xml:lang="it">Questa è la distribuzione N-TRIPLES dell&apos;ontologia del Ministero Del Lavoro e delle Politiche Sociali relativa al dominio GePi definisce in modo strutturato e interoperabile dati, relazioni e concetti relativi alla gestione dei Patti per l’Inclusione Sociale, garantendo uniformità semantica, integrazione informativa e supporto ai processi digitali della piattaforma che è parte integrante del Sistema informativo per l&apos;inclusione sociale e lavorativa (SIISL)</dct:description>
        <dct:description xml:lang="en">This is the distribution in N-TRIPLES of the Labour and Social Policies Ministry Ontology related to the GePi domain defines in a structured and interoperable way the data, relationships, and concepts concerning the management of Social Inclusion Pacts, ensuring semantic uniformity, information integration, and support for the digital processes of the platform, which is an integral part of the Social and Labour Inclusion Information System (SIISL)</dct:description>
        <dct:format rdf:resource="http://publications.europa.eu/resource/authority/file-type/RDF_N_TRIPLES"/>
        <dct:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
        <dct:title xml:lang="it">Distribuzione N-TRIPLES dell&apos;ontologia della gestione dei patti per l&apos;inclusione sociale (GePI) del Ministero Del Lavoro e delle Politiche Sociali - GePI</dct:title>
        <dct:title xml:lang="en">N-TRIPLES distribution of the Labour and Social Policies Ministry ontology for the management of Social Inclusion Pacts - GePI</dct:title>
        <dcat:accessURL rdf:resource="https://github.com/MlpsDgInnovazioneDivisioneIII/mlps-ndc/tree/main/assets/ontologies/social/latest"/>
        <dcat:downloadURL rdf:resource="https://raw.githubusercontent.com/MlpsDgInnovazioneDivisioneIII/mlps-ndc/main/assets/ontologies/social/latest/social.n3"/>
    </owl:NamedIndividual>



