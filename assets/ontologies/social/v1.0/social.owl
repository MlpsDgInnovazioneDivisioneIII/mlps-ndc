        <dct:accrualPeriodicity rdf:resource="http://publications.europa.eu/resource/authority/frequency/IRREG"/>
        <dct:creator rdf:resource="https://w3id.org/italia/labour-social-policies/data/organization/mlps"/>
        <dct:description xml:lang="it">Ontologia del Ministero Del Lavoro e delle Politiche Sociali relativa al dominio GePi definisce in modo strutturato e interoperabile dati, relazioni e concetti relativi alla gestione dei Patti per l’Inclusione Sociale, garantendo uniformità semantica, integrazione informativa e supporto ai processi digitali della piattaforma che è parte integrante del Sistema informativo per l&apos;inclusione sociale e lavorativa (SIISL)</dct:description>
        <dct:description xml:lang="en">Ontology of the Ministry of Labour and Social Policies related to the GePi domain defines in a structured and interoperable way the data, relationships, and concepts concerning the management of Social Inclusion Pacts, ensuring semantic uniformity, information integration, and support for the digital processes of the platform, which is an integral part of the Social and Labour Inclusion Information System (SIISL).</dct:description>
        <dct:identifier>https://w3id.org/italia/labour-social-policies/onto/social</dct:identifier>
        <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-26T00:00:00+00:00</dct:issued>
        <dct:language rdf:resource="http://publications.europa.eu/resource/authority/language/ENG"/>
        <dct:language rdf:resource="http://publications.europa.eu/resource/authority/language/ITA"/>
        <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-26T00:00:00+00:00</dct:modified>
        <dct:publisher rdf:resource="https://w3id.org/italia/labour-social-policies/data/organization/mlps"/>
        <dct:rightsHolder rdf:resource="https://w3id.org/italia/labour-social-policies/data/organization/mlps"/>
        <dct:title xml:lang="it">Ontologia della gestione dei patti per l&apos;inclusione sociale (GePI) del Ministero Del Lavoro e delle Politiche Sociali</dct:title>
        <dct:title xml:lang="en">Ontology for the management of Social Inclusion Pacts (GePI) of the Ministry of Labor and Social Policies</dct:title>
        <rdfs:comment xml:lang="it">Ontologia del Ministero Del Lavoro e delle Politiche Sociali relativa al dominio GePi definisce in modo strutturato e interoperabile dati, relazioni e concetti relativi alla gestione dei Patti per l’Inclusione Sociale, garantendo uniformità semantica, integrazione informativa e supporto ai processi digitali della piattaforma che è parte integrante del Sistema informativo per l&apos;inclusione sociale e lavorativa (SIISL)</rdfs:comment>
        <rdfs:comment xml:lang="en">Ontology of the Ministry of Labour and Social Policies related to the GePi domain defines in a structured and interoperable way the data, relationships, and concepts concerning the management of Social Inclusion Pacts, ensuring semantic uniformity, information integration, and support for the digital processes of the platform, which is an integral part of the Social and Labour Inclusion Information System (SIISL).</rdfs:comment>
