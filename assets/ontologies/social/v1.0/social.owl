            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/idObiettivo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Cambiamento/miglioramento auspicato per il nucleo familiare formalizzato nel Patto di Inclusione sociale attraverso l&apos;indicazione della  finalità da perseguire (obiettivo generale), cui vengono collegati risultati attesi</rdfs:comment>
        <rdfs:label xml:lang="it">Obiettivo PaIS</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/PartecipazioneComponenteAIncontro -->

