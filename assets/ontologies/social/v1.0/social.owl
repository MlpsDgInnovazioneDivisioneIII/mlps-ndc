                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica il nominativo dell&apos;intestatario del contratto di locazione </rdfs:comment>
        <rdfs:label xml:lang="it">Intestatario contratto locazione nucleo familiare</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/MembroEquipeMultidisciplinareDelCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/MembroEquipeMultidisciplinareDelCaso">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haProfessioneMembroEquipe"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haMembroEquipeMultidisciplinare"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                    </rdf:Description>
                </owl:onProperty>
