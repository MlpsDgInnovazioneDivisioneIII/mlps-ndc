    <!-- https://w3id.org/italia/labour-social-policies/onto/social/PattoAttivazioneDigitaleNucleo -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/PattoAttivazioneDigitaleNucleo">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haNucleoFamiliareDiPAD"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haSottoscrittorePAD"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haPADNucleoFamiliare"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica l&apos;avventua sottoscrizione del PAD nucleo</rdfs:comment>
        <rdfs:label xml:lang="it">Patto attivazione digitale nucleo</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/PattoInclusioneSocialeDelCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/PattoInclusioneSocialeDelCaso">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haPattoInclusioneSocialeDelCaso"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/identificativoPattoInclusioneSocialeCaso"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/versionePaIS"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Il Patto per l&apos;Inclusione Sociale (PaIS) è progetto personalizzato definito dai servizi sociali e dal nucleo beneficiario delle misura di contrasto alla povertà sulla base di una valutazione multidimensionale dei bisogni del nucleo familiare realizzata attraverso l&apos;analisi preliminare ed eventalmente il quadro di analisi</rdfs:comment>
        <rdfs:label xml:lang="it">Patto inclusione sociale del caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/PeriodoDiGiustificatoMotivoAssenza -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/PeriodoDiGiustificatoMotivoAssenza">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:comment xml:lang="it">Indica il periodo al quale si applica la giustificazione del mancato adempimento della presentazione, come attestato nel giustificato motivo</rdfs:comment>
        <rdfs:label xml:lang="it">Periodo di giustificato motivo assenza</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ProfessioneMembroEquipe -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ProfessioneMembroEquipe">
        <rdfs:comment xml:lang="it">Indica la professione del componente dell&apos;equipe multidisciplinare.</rdfs:comment>
        <rdfs:label xml:lang="it">Professione membro equipe</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/QuadroDiAnalisiDelCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/QuadroDiAnalisiDelCaso">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/QuestionarioDelRedattore"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haQuadroDiAnalisi"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/identificativoQuadroAnalisi"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/versioneQuadroAnalisi"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica che a seguito dell&apos;analisi preliminare, in considerazione delle problematiche emerse, è stato necessario realizzare un quadro di analisi approfondito per completare la valutazione multidimensionale</rdfs:comment>
        <rdfs:label xml:lang="it">Quadro di analisi del caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/RichiedenteADI -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/RichiedenteADI">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/presentaDomandaPrestazioneDiSostegno"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haDomandaPrestazioneDiSostegno"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AssegnoDiInclusione"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Richiedente la misura di  sostegno economico e di inclusione sociale e professionale introdotta dal decreto-legge 48.2023</rdfs:comment>
        <rdfs:label xml:lang="it">Richiedente ADI</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/RisultatoAttesoDiObiettivo -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/RisultatoAttesoDiObiettivo">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/descrizioneRisultatoAttesoObiettivo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/idRisultatoAttesoObiettivo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Tappe e risultati da raggiungere tramite il patto di inclusione sociale</rdfs:comment>
        <rdfs:label xml:lang="it">Risultato atteso di obiettivo PaIS</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ScalaDiEquivalenzaNucleo -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/ScalaDiEquivalenzaNucleo">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haContributoScalaDiEquivalenza"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/valoreTotaleScalaDiEquivalenza"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica il parametro complessivo della scala di equivalenza, utilizzato anche per determinare l&apos;importo dell&apos;assegno di inclusione.</rdfs:comment>
        <rdfs:label xml:lang="it">Scala di equivalenza nucleo ADI</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/SostegnoPaIS -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/SostegnoPaIS">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haTipoDiSostegno"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/èSostegnoPerComponenteNucleo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/descrizioneTipologiaSostegnoPaIS"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/idTipologiaSostegnoPaIS"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica la tipologia di sostegno/intervento di supporto attivato dai servizi sociali in favore del nucleo familiare beneficiario ADI o di un suo componente</rdfs:comment>
        <rdfs:label xml:lang="it">Sostegno PaIS</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiAnalisiPreliminare -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiAnalisiPreliminare">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiValutazioneMultidimensionale"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/precedes"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiQuadroDiAnalisi"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiQuadroDiAnalisi"/>
        <rdfs:comment xml:lang="it">Indica se l&apos;AP è in corso o è stata completata</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di analisi preliminare</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiAttesaPrimoIncontro -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiAttesaPrimoIncontro">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/l0/hasFirstMember"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/GestioneDiDomandaDiCasoDiNucleo"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica che il primo incontro con il nucleo beneficiario dell&apos;ADI, previsto entro 120 giorni dalla sottoscrizione del PAD nucleo, non è ancora avvenuto</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di attesa primo incontro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haStatoDiGestioneDiDomandaDiCaso"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Si intende lo stato in cui può trovarsi la domanda associata al caso</rdfs:comment>
        <rdfs:label xml:lang="it">Stato della domanda ADI</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIdentificazioneObbligoDiAttivazione -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIdentificazioneObbligoDiAttivazione">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:comment xml:lang="it">Indica l&apos;attribuzione dell&apos;obbligo di attivazione ad un componente del nucleo</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di identificazione obbligo di attivazione</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIncontroDiMonitoraggio -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIncontroDiMonitoraggio">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:comment xml:lang="it">Indica se l&apos;incontro di monitoraggio è stato effettuato o meno</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di incontro di monitoraggio</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIncontroValutato -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIncontroValutato">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haPartecipanteIncontro"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/avvisoDiIncontroEffettuato"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica se l&apos;incontro ha avuto luogo o meno</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di incontro valutato</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiPartecipazionePUC -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiPartecipazionePUC">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:comment xml:lang="it">Indica lo stato della partecipazione di un componente ad un PUC</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di partecipazione PUC</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiPianificatoIncontroDiMonitoraggio -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiPianificatoIncontroDiMonitoraggio">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/precedes"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIncontroDiMonitoraggio"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica se l&apos;incontro di monitoraggio è stato pianificato o meno</rdfs:comment>
        <rdfs:label xml:lang="it">Stato della pianificazione dell&apos;incontro di monitoraggio</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiPianificatoPrimoIncontro -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiPianificatoPrimoIncontro">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:comment xml:lang="it">Indica se il primo incontro è stato pianificato o meno</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di pianificazione del primo incontro</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiQuadroDiAnalisi -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiQuadroDiAnalisi">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiValutazioneMultidimensionale"/>
        <rdfs:comment xml:lang="it">Indica se il quadro di analisi è completato o in corso</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di quadro di analisi</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiSottoscrizionePaIS -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiSottoscrizionePaIS">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/precedes"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIncontroDiMonitoraggio"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica se il PaIS è stato sottoscritto</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di sottoscrizione PaIS</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/StatoDiValutazioneMultidimensionale -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiValutazioneMultidimensionale">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiGestioneDiDomandaDiCaso"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/precedes"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/StatoDiIdentificazioneObbligoDiAttivazione"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Indica se la valutazione multidimensionale è in corso o chiusa</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di valutazione multidimensionale</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/TipoDiSostegno -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/TipoDiSostegno">
        <rdfs:comment xml:lang="it">Indica il sostegno erogato al beneficiario sulla base di un  elenco delle tipologie di sostegno associabili ad uno o più componenti del nucleo come indicato nelle linee guida PaIS</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di sostegno</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/TipoPercorsoSocialeLavorativo -->

