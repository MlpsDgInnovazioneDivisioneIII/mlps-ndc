            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haComponenteNucleoConCategoriaObbligoAttivazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/indicaObbligoComponenteNucleoDelCaso"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Gli obblighi a cui è tenuto un componente specifico del nucleo in relazione alla tipologia di percorso a cui è stato assegnato</rdfs:comment>
        <rdfs:label xml:lang="it">Obbligo componente nucleo del caso</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/ObiettivoPaIS -->

