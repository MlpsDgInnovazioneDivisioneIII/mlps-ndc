                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/haImpegnoPaIS"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/descrizioneImpegnoPaIS"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Impegno associato ad un componente del nucleo familiare all&apos;interno del progetto personalizzato (Patto per l&apos;Inclusione Sociale - PaIS)</rdfs:comment>
        <rdfs:label xml:lang="it">Impegno PaIS</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/social/IntestatarioContrattoLocazioneNucleoFamiliare -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/social/IntestatarioContrattoLocazioneNucleoFamiliare">
