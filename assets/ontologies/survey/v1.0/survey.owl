    <!-- https://w3id.org/italia/labour-social-policies/onto/survey/haSoggettoDellaRisposta -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/survey/haSoggettoDellaRisposta">
        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/RispostaDelRedattore"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/l0/Agent"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="it">Lega una risposta al soggetto a cui si riferisce.</rdfs:comment>
        <rdfs:label xml:lang="it">ha soggetto della risposta</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/survey/haSoggettoDellaSezione -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/survey/haSoggettoDellaSezione">
        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/SezioneDelQuestionarioDelRedattore"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/l0/Agent"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="it">Lega una sezione di risposte ad soggetto a cui si riferisce.</rdfs:comment>
        <rdfs:label xml:lang="it">ha soggetto della sezione</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://w3id.org/italia/labour-social-policies/onto/survey/haSottodomanda -->

