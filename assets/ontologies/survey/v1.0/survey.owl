        <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/SezioneDelQuestionarioDelRedattore"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/ModelloDiSezione"/>
        <rdfs:comment xml:lang="it">Lega una sezione del questionario del redattore, contenente le risposte, alla relativa sezione del modello di questionario, contenente le domande.</rdfs:comment>
        <rdfs:label xml:lang="it">ha sezione di modello</rdfs:label>
