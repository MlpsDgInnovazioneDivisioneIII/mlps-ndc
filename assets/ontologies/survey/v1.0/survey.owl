        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/haOpzioneDiRisposta"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/haSubopzione"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/èOpzioneDiRisposta"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Classifica le possibili opzioni di risposta accoppiate ad una domanda di una sezione di un modello di questionario. Una opzione di risposta potrebbe indicare una ulteriore domanda.</rdfs:comment>
        <rdfs:label xml:lang="it">Opzione di risposta</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/survey/QuestionarioDelRedattore -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/survey/QuestionarioDelRedattore">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/haModelloDiQuestionario"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/haQuestionarioDelRedattore"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Classifica i questionari compilati da i redattori. Un questionario compilato è relativo ad un certo modello di questionario.</rdfs:comment>
        <rdfs:label xml:lang="it">Questionario del redattore</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/survey/Redattore -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/survey/Redattore">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/l0/Agent"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">È l&apos;agente, o un suo ruolo, che compila il questionario.</rdfs:comment>
        <rdfs:label xml:lang="it">Redattore</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/survey/RispostaDelRedattore -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/survey/RispostaDelRedattore">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/èOpzioneDiRisposta"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/èRispostaADomanda"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/contieneRispostaDelRedattore"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Classifica le risposte di ciascun redattore ad una specifica domanda. La risposta può essere riferita ad un sogetto diverso dal redattore stesso.</rdfs:comment>
        <rdfs:label xml:lang="it">Risposta del redattore</rdfs:label>
    </owl:Class>



    <!-- https://w3id.org/italia/labour-social-policies/onto/survey/SezioneDelQuestionarioDelRedattore -->

    <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/survey/SezioneDelQuestionarioDelRedattore">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/contieneRispostaDelRedattore"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/survey/haSezioneDiModello"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Classifica le sezioni di un questionario compilate da un redattore, contiene quindi le sue risposte. Tale sezione è definita a partire dalla sezione del modello di questionario che il redattore sta compilando e che contiene le domande a cui il redattore deve rispondere. La sezione compilata potrebbe riferirsi ad un soggetto diverso dal redattore.</rdfs:comment>
        <rdfs:label xml:lang="it">Sezione del questionario del redattore</rdfs:label>
    </owl:Class>



