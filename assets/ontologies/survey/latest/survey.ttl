### Object Properties

lsp-srv:contieneRispostaDelRedattore a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "contiene risposta del redattore"@it ;
    rdfs:domain lsp-srv:SezioneDelQuestionarioDelRedattore ;
    rdfs:range lsp-srv:RispostaDelRedattore ;
    rdfs:comment "Lega una specifica risposta alla relativa sezione che contiene la domanda."@it .

lsp-srv:haDomanda a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha domanda"@it ;
    rdfs:domain lsp-srv:ModelloDiSezione ;
    rdfs:range lsp-srv:Domanda ;
    rdfs:comment "Lega una domanda alla sua sezione."@it .

lsp-srv:haModelloDiQuestionario a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha modello di questionario"@it ;
    rdfs:domain lsp-srv:QuestionarioDelRedattore ;
    rdfs:range lsp-srv:ModelloDiQuestionario ;
    rdfs:comment "Lega un questionario compilato da un redattore al modello del questionario."@it .

lsp-srv:haModelloDiSezione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha modello di sezione"@it ;
    rdfs:domain lsp-srv:ModelloDiQuestionario ;
    rdfs:range lsp-srv:ModelloDiSezione ;
    rdfs:comment "Lega un modello di questionario ai suoi modelli di sezione."@it .

lsp-srv:haOpzioneDiRisposta a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha opzione di risposta"@it ;
    rdfs:domain lsp-srv:Domanda ;
    rdfs:range lsp-srv:OpzioneDiRisposta ;
    rdfs:comment "Lega una domanda alle sue opzioni di risposta."@it .

lsp-srv:haQuestionarioDelRedattore a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha questionario del redattore"@it ;
    rdfs:domain lsp-srv:Redattore ;
    rdfs:range lsp-srv:QuestionarioDelRedattore ;
    rdfs:comment "Lega un redattore ai suoi questionari compilati."@it .

lsp-srv:haSezioneDelQuestionarioDelRedattore a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha sezione del questionario del redattore"@it ;
    rdfs:domain lsp-srv:QuestionarioDelRedattore ;
    rdfs:range lsp-srv:SezioneDelQuestionarioDelRedattore ;
    rdfs:comment "Lega un questionario compilato alle sue sezioni di risposte."@it .

lsp-srv:haSezioneDiModello a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha sezione di modello"@it ;
    rdfs:domain lsp-srv:SezioneDelQuestionarioDelRedattore ;
    rdfs:range lsp-srv:ModelloDiSezione ;
    rdfs:comment "Lega una sezione del questionario del redattore, contenente le risposte, alla relativa sezione del modello di questionario, contenente le domande."@it .

lsp-srv:haSoggettoDellaRisposta a owl:ObjectProperty ;
    rdfs:label "ha soggetto della risposta"@it ;
    rdfs:domain lsp-srv:RispostaDelRedattore ;
    rdfs:range [ a owl:Class ;
            owl:unionOf (
                    L0:Agent
                    [ a owl:Restriction ;
                        owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
                        owl:someValuesFrom L0:Agent ] ) ] ;
    rdfs:comment "Lega una risposta al soggetto a cui si riferisce."@it .

lsp-srv:haSoggettoDellaSezione a owl:ObjectProperty ;
    rdfs:label "ha soggetto della sezione"@it ;
    rdfs:domain lsp-srv:SezioneDelQuestionarioDelRedattore ;
    rdfs:range [ a owl:Class ;
            owl:unionOf (
                    L0:Agent
                    [ a owl:Restriction ;
                        owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
                        owl:someValuesFrom L0:Agent ] ) ] ;
    rdfs:comment "Lega una sezione di risposte ad soggetto a cui si riferisce."@it .

lsp-srv:haSottodomanda a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha sottodomanda"@it ;
    rdfs:domain lsp-srv:OpzioneDiRisposta ;
    rdfs:range lsp-srv:Domanda ;
    rdfs:comment "Lega una domanda ad una sua ulteriore domanda necessaria per fornire la risposta."@it .

lsp-srv:haSottosezione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha sottosezione"@it ;
    rdfs:domain lsp-srv:ModelloDiSezione ;
    rdfs:range lsp-srv:ModelloDiSezione ;
    rdfs:comment "Lega una sezione alle sue sottosezioni."@it .

lsp-srv:haSubopzione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha subopzione"@it ;
    rdfs:domain lsp-srv:OpzioneDiRisposta ;
    rdfs:range lsp-srv:OpzioneDiRisposta ;
    rdfs:comment "Lega una opzione alle sue ulteriori opzioni."@it .

lsp-srv:èOpzioneDiRisposta a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "è opzione di risposta"@it ;
    rdfs:domain lsp-srv:RispostaDelRedattore ;
    rdfs:range lsp-srv:OpzioneDiRisposta ;
    rdfs:comment "Lega una risposta all'opzione prevista dalla domanda."@it .

lsp-srv:èRispostaADomanda a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "è risposta a domanda"@it ;
    rdfs:domain lsp-srv:RispostaDelRedattore ;
    rdfs:range lsp-srv:Domanda ;
    rdfs:comment "Lega una risposta alla relativa domanda."@it .

RO:holdsRoleInTime a owl:ObjectProperty .

### Datatypes

xsd:string a rdfs:Datatype .

### Data Properties

lsp-srv:descrizioneDomanda a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "descrizione domanda"@it ;
    rdfs:domain lsp-srv:Domanda ;
    rdfs:comment "Descrizione della domanda"@it .

lsp-srv:idDomanda a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "id domanda"@it ;
    rdfs:domain lsp-srv:Domanda ;
    rdfs:comment "Identificativo della domanda"@it .

lsp-srv:idSezione a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "id sezione"@it ;
    rdfs:domain lsp-srv:SezioneDelQuestionarioDelRedattore ;
    rdfs:comment "Identificativo del modello di sezione"@it .

lsp-srv:testoDellaRisposta a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "testo della risposta"@it ;
    rdfs:domain lsp-srv:RispostaDelRedattore ;
    rdfs:range xsd:string ;
    rdfs:comment "Contenuto della risposta espresso in formato testuale qualora la domanda lo preveda."@it .

lsp-srv:testoSezione a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "testo sezione"@it ;
    rdfs:domain lsp-srv:SezioneDelQuestionarioDelRedattore ;
    rdfs:comment " Indica il testo della sezione"@it .

lsp-srv:valoreDellaRisposta a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "valore della risposta"@it ;
    rdfs:domain lsp-srv:RispostaDelRedattore ;
    rdfs:range xsd:string ;
    rdfs:comment "Valore attribuito dal redattore alla domanda qualora questa preveda l'indicazione di un valore."@it .

### Classes

L0:Agent a owl:Class ;
    owl:disjointWith [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom L0:Agent ] .

lsp-srv:Domanda a owl:Class ;
    rdfs:label "Domanda"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:haDomanda ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:haSottodomanda ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:èRispostaADomanda ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica le domande presenti nelle sezioni dei modelli di questionario."@it .

lsp-srv:ModelloDiQuestionario a owl:Class ;
    rdfs:label "Modello di questionario"@it ;
    rdfs:comment "Classifica i modelli di questionario ciascuno dei quali è organizzato, secondo una propria logica e un proprio obiettivo, in sezioni e domande."@it .

lsp-srv:ModelloDiSezione a owl:Class ;
    rdfs:label "Modello di sezione"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:haModelloDiSezione ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:haSottosezione ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Rappresenta una specifica sezione di un modello di questionario."@it .

lsp-srv:OpzioneDiRisposta a owl:Class ;
    rdfs:label "Opzione di risposta"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:haOpzioneDiRisposta ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:haSubopzione ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:èOpzioneDiRisposta ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica le possibili opzioni di risposta accoppiate ad una domanda di una sezione di un modello di questionario. Una opzione di risposta potrebbe indicare una ulteriore domanda."@it .

lsp-srv:QuestionarioDelRedattore a owl:Class ;
    rdfs:label "Questionario del redattore"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-srv:haModelloDiQuestionario ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:haQuestionarioDelRedattore ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica i questionari compilati da i redattori. Un questionario compilato è relativo ad un certo modello di questionario."@it .

lsp-srv:Redattore a owl:Class ;
    rdfs:label "Redattore"@it ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf (
                    L0:Agent
                    [ a owl:Restriction ;
                        owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
                        owl:someValuesFrom L0:Agent ] ) ] ;
    rdfs:comment "È l'agente, o un suo ruolo, che compila il questionario."@it .

lsp-srv:RispostaDelRedattore a owl:Class ;
    rdfs:label "Risposta del redattore"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-srv:èOpzioneDiRisposta ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-srv:èRispostaADomanda ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-srv:contieneRispostaDelRedattore ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica le risposte di ciascun redattore ad una specifica domanda. La risposta può essere riferita ad un sogetto diverso dal redattore stesso."@it .

lsp-srv:SezioneDelQuestionarioDelRedattore a owl:Class ;
    rdfs:label "Sezione del questionario del redattore"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-srv:contieneRispostaDelRedattore ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-srv:haSezioneDiModello ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Classifica le sezioni di un questionario compilate da un redattore, contiene quindi le sue risposte. Tale sezione è definita a partire dalla sezione del modello di questionario che il redattore sta compilando e che contiene le domande a cui il redattore deve rispondere. La sezione compilata potrebbe riferirsi ad un soggetto diverso dal redattore."@it .

