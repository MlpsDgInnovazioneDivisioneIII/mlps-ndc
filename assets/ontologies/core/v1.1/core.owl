  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/esprimeAtto">
    <rdfs:label xml:lang="it">esprime atto</rdfs:label>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf>
          <rdf:Description>
            <rdf:first rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            <rdf:rest>
              <rdf:Description>
                <rdf:first>
                  <owl:Restriction>
                    <owl:onProperty>
                      <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                      </rdf:Description>
                    </owl:onProperty>

                    <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
                  </owl:Restriction>
                </rdf:first>

                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </rdf:rest>

          </rdf:Description>
        </owl:unionOf>

      </owl:Class>
    </rdfs:domain>

    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
    <rdfs:comment xml:lang="it">Lega un atto all'agente (o ruolo di agente) che lo ha espresso.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haAccreditamentoPerFormazione">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha accreditamento per formazione</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/EnteFormativo"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AccreditamentoPerFormazione"/>
    <rdfs:comment xml:lang="it">Lega un Ente formatore o un Intermediario formativo al suo atto di accreditamento riconosciuto da un ente pubblico.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haAnalisiPreliminareNucleo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha analisi preliminare nucleo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AnalisiPreliminareNucleoFamiliare"/>
    <rdfs:comment xml:lang="it">Lega un Percorso d'inclusione di un nucleo familiare alla sua Analisi preliminare.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haAttivatoPUC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha attivato PUC</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/onto/COV/PublicOrganization"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/ProgettoDiUtilitàCollettiva"/>
    <rdfs:comment xml:lang="it">Lega un ente pubblico a un Progetto di utilità collettiva da lui promosso.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haBeneficiarioPrestazioneDiSostegno">
    <rdfs:label xml:lang="it">ha beneficiario prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/BeneficiarioPrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Lega una prestazione di sostegno con un beneficiario della prestazione.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haComponenteDiATS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha componente di ATS</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmbitoTerritorialeSociale"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/onto/COV/PublicOrganization"/>
    <rdfs:comment xml:lang="it">Lega un ATS ad un ente pubblico che ne fa parte.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haConferenteAttoDiNomina">
    <rdfs:label xml:lang="it">ha conferente atto di nomina</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AttoDiNominaRappresentanteLegale"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf>
          <rdf:Description>
            <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/BeneficiarioPrestazioneDiSostegno"/>
            <rdf:rest>
              <rdf:Description>
                <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/TitolarePrestazioneDiSostegno"/>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </rdf:rest>

          </rdf:Description>
        </owl:unionOf>

      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega un atto di nomina del rappresentante legale ai conferenti la nomina.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:FunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haDesignatoAttoDiNomina">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha designato atto di nomina</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AttoDiNominaRappresentanteLegale"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/RappresentanteLegale"/>
    <rdfs:comment xml:lang="it">Lega un atto di nomina al relativo rappresentante che viene nominato.</rdfs:comment>
  </owl:FunctionalProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haDirittoAPrestazioneDiSostegno">
    <rdfs:label xml:lang="it">ha diritto a prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/TitolarePrestazioneDiSostegno"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Lega un Titolare di prestazione di sostegno ovvero un avente diritto a tale prestazione alla domanda inoltrata per ottenere il beneficio della prestazione.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:FunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haDomandaPrestazioneDiSostegno">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha domanda prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Lega una prestazione di sostegno alla domanda presentata per l'ottenimento della prestazione stessa.</rdfs:comment>
  </owl:FunctionalProperty>

  <owl:FunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haEnteCapofilaDiATS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha ente capofila di ATS</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmbitoTerritorialeSociale"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/onto/COV/PublicOrganization"/>
    <rdfs:comment xml:lang="it">Lega un ATS all'ente pubblico che ne è capofila.</rdfs:comment>
  </owl:FunctionalProperty>

  <owl:FunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haEnteDiATS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha ente di ATS</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmbitoTerritorialeSociale"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf>
          <rdf:Description>
            <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/ProvinciaAutonomaItaliana"/>
            <rdf:rest>
              <rdf:Description>
                <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/RegioneItaliana"/>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </rdf:rest>

          </rdf:Description>
        </owl:unionOf>

      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega un ATS alla suo ente amministrativo sovraordinato che può essere una Regione italiana o una Provincia autonoma italiana.</rdfs:comment>
  </owl:FunctionalProperty>

  <owl:FunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haFascicoloSocialeLavorativo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha fascicolo sociale e lavorativo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/FascicoloSocialeLavorativoDelCittadino"/>
    <rdfs:comment xml:lang="it">Lega un Cittadino al suo Fascicolo sociale e lavorativo.</rdfs:comment>
  </owl:FunctionalProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haPADDiCasoDiNucleo">
    <rdfs:label xml:lang="it">ha PAD di caso di nucleo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/PattoAttivazioneDigitaleNucleo"/>
    <rdfs:comment xml:lang="it">Lega un caso di nucleo familiare fragile o in povertà al relativo PAD del nucleo sottoscritto.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haPattoInclusioneSocialeNucleo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha patto inclusione sociale nucleo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/PattoInclusioneSocialeDelCaso"/>
    <rdfs:comment xml:lang="it">Lega un Percorso d'inclusione di un nucleo familiare al suo PaIS nucleo.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haQuadroDiAnalisiNucleoFamiliare">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha quadro di analisi nucleo familiare</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/QuadroDiAnalisiNucleoFamiliare"/>
    <rdfs:comment xml:lang="it">Lega un Percorso d'inclusione di un nucleo familiare al suo Quadro di analisi.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:FunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/haTipoPrestazioneDiSostegno">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">ha tipo prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:range>
      <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/TipoPrestazioneDiSostegno">
        <rdfs:label xml:lang="it">Tipo prestazione di sostegno</rdfs:label>
        <rdfs:comment xml:lang="it">Classifica la tipologia di una prestazione di sostegno.</rdfs:comment>
      </owl:Class>
    </rdfs:range>

    <rdfs:comment xml:lang="it">Lega una prestazione di sostegno al suo tipo.</rdfs:comment>
  </owl:FunctionalProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/indicaBeneficiarioPrestazioneDiSostegno">
    <rdfs:label xml:lang="it">indica beneficiario prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegno"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/BeneficiarioPrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Lega una richiesta di prestazione di sostegno a un beneficiario della prestazione.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/presentaDomandaPrestazioneDiSostegno">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">presenta domanda prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/RichiedentePrestazioneDiSostegno"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Lega un richiedente a una sua domanda di prestazione di sostegno.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/riferisceAnalisiPreliminareNucleo">
    <rdfs:label xml:lang="it">riferisce analisi preliminare nucleo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/FascicoloSocialeLavorativoDelCittadino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AnalisiPreliminareNucleoFamiliare"/>
    <rdfs:comment xml:lang="it">Lega il fascicolo di un Cittadino ad un'Analisi preliminare relativa al nucleo familiare di cui è componente.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/riferiscePADNucleo">
    <rdfs:label xml:lang="it">riferisce PAD nucleo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/FascicoloSocialeLavorativoDelCittadino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/PattoAttivazioneDigitaleNucleo"/>
    <rdfs:comment xml:lang="it">Lega il fascicolo di un Cittadino al PAD nucleo relativo al nucleo familiare di cui è componente.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/riferiscePattoInclusioneSocialeNucleo">
    <rdfs:label xml:lang="it">riferisce patto inclusione sociale nucleo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/FascicoloSocialeLavorativoDelCittadino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/PattoInclusioneSocialeDelCaso"/>
    <rdfs:comment xml:lang="it">Lega il fascicolo di un Cittadino al PaIS relativo al nucleo familiare di cui è componente.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/riferiscePattoServizioPersonalizzato">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">riferisce patto servizio personalizzato</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/labour/PattoServizioPersonalizzato"/>
    <rdfs:comment xml:lang="it">Lega un Percorso d'inclusione di un nucleo familiare al PSP di un suo componente attivabile al lavoro, obbligatorio o volontario.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/riferiscePercorsoNucleoFamiliare">
    <rdfs:label xml:lang="it">riferisce percorso nucleo familiare</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/FascicoloSocialeLavorativoDelCittadino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/CasoDiNucleoFragileOInPovertà"/>
    <rdfs:comment xml:lang="it">Lega il fascicolo di un Cittadino ad un Percorso d'inclusione sociale relativo al nucleo familiare di cui è componente.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/riferiscePrestazioneDiSostegno">
    <rdfs:label xml:lang="it">riferisce prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/FascicoloSocialeLavorativoDelCittadino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Lega il fascicolo di un Cittadino ad una prestazione di sostegno. Il Cittadino può partecpare al legame in qualità di beneficiario di una prestazione individuel o come componente di un nucleo familiare beneficiario.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/riferisceQuadroDiAnalisiNucleo">
    <rdfs:label xml:lang="it">riferisce quadro di analisi nucleo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/FascicoloSocialeLavorativoDelCittadino"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/QuadroDiAnalisiNucleoFamiliare"/>
    <rdfs:comment xml:lang="it">Lega il fascicolo di un Cittadino ad un Quadro di analisi relativo al nucleo familiare di cui è componente.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:InverseFunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/stipulaPattoInclusioneSocialeNucleo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">stipula patto inclusione sociale nucleo</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmministrazioneServizioSociale"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/PattoInclusioneSocialeDelCaso"/>
    <rdfs:comment xml:lang="it">Lega un Gestore servizio sociale ad un PaIS di un nucleo familiare da lui formalizzato.</rdfs:comment>
  </owl:InverseFunctionalProperty>

  <owl:FunctionalProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/èRinnovoDiDomandaDiSostegno">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="it">è rinnovo di domanda di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegno"/>
    <rdfs:range rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Lega una domanda di prestazione di sostegno ad una e una sola altra domanda antecedente di cui rappresenta il rinnovo o prolugamento.</rdfs:comment>
  </owl:FunctionalProperty>

