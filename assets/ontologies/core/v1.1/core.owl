    <rdfs:label xml:lang="it">ambito accreditamento altro</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/EnteFormativo"/>
    <rdfs:comment xml:lang="it">Altro ambito di accreditamento</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/avvisoDeclaratoriaFirmata">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">avviso declaratoria firmata</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/social/PattoAttivazioneDigitaleNucleo"/>
    <rdfs:comment xml:lang="it">Booleano che indica se la declaratoria è stata firmata</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/codiceAgenziaPerIlLavoro">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
