        <dc:identifier>TD</dc:identifier>
        <foaf:name xml:lang="en">Digital Transformation Team</foaf:name>
        <foaf:name xml:lang="it">Team per la Trasformazione Digitale</foaf:name>
      </rdf:Description>
    </ns0:hasContributor>

