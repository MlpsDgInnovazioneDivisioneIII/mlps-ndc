    <ns0:hasSemanticAssetDistribution>
      <ns0:SemanticAssetDistribution rdf:about="https://w3id.org/italia/labour-social-policies/data/core/distribution/MLPSCORE-N-TRIPLES">
        <rdf:type rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdf:type rdf:resource="http://dati.gov.it/onto/dcatapit#Distribution"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcat:accessURL rdf:resource="https://github.com/MlpsDgInnovazioneDivisioneIII/mlps-ndc/tree/main/assets/ontologies/core/latest"/>
        <dcat:downloadURL rdf:resource="https://raw.githubusercontent.com/MlpsDgInnovazioneDivisioneIII/mlps-ndc/main/assets/ontologies/core/latest/core.n3"/>
        <dc:description xml:lang="it">Questa è la distribuzione N-TRIPLES dell'ontologia del Ministero del Lavoro e delle Politche Sociali relativa al Fascicolo sociale e lavorativo del cittadino nell'ambito del sistema informativo pubblico e la sua funzione di hub di accesso alle informazioni sul cittadino in special modo quelle inerenti il suo coinvolgimento in iniziative di inclusione originate dalla necessità di sopperire alle fragilità sociali e lavorative sue proprie o del suo nucleo familiare.</dc:description>
        <dc:description xml:lang="en">This is the distribution in N-TRIPLES of the Labour and Social Policy Ministry Ontology about the citizen's social and employment record within the public information system and its function as a hub for accessing information on citizens, especially those relating to their involvement in inclusion initiatives arising from the need to address their own or their family's social and employment vulnerabilities.</dc:description>
        <dc:format rdf:resource="http://publications.europa.eu/resource/authority/file-type/RDF_N_TRIPLES"/>
        <dc:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
        <dc:title xml:lang="it">Distribuzione N-TRIPLES dell'ontologia del Ministero del Lavoro e delle Politiche Sociali - Core</dc:title>
        <dc:title xml:lang="en">N-TRIPLES distribution of the Labour and Social Policies Ministry ontology - Core</dc:title>
      </ns0:SemanticAssetDistribution>
    </ns0:hasSemanticAssetDistribution>

