    <rdfs:comment xml:lang="it">Codice identificativo interno di una Agenzia per il lavoro.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/codiceATS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">codice ATS</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmbitoTerritorialeSociale"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="it">Codice amministrativo univoco di un ATS.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/codiceDiAccreditamento">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">codice di accreditamento</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AccreditamentoPerFormazione"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="it">È il codice attribuito da un Ente pubblico che certifica il possesso dei requisiti necessari e obbligatori affinche il soggetto che lo possiede possa erogare servizi formativi.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/dataAtto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">data atto</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:comment xml:lang="it">È la data di emissione di un atto.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/dataFineAttivita">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">data fine attività</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AgenziaPerIlLavoro"/>
    <rdfs:comment xml:lang="it">Indica la data di fine attività</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/fax">
    <rdfs:label xml:lang="it">fax</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CPV/Alive"/>
    <rdfs:comment xml:lang="it">Numerazione telefonica dedicata, strutturata come un numero fisso standard, utilizzata per trasmettere e ricevere immagini di documenti tramite apparecchiature fax o servizi online</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/identificativoAtto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">identificativo atto</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
    <rdfs:comment xml:lang="it">È l'identificatore univoco di un atto.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/protocolloMisuraDomandaPrestazioneDiSostegno">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">protocollo misura domanda prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Protocolli domande ADI e RDC correlate al caso</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/protocolloPrestazioneDiSostegno">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">protocollo prestazione di sostegno</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">È l'identificatore univoco di una prestazione di sostegno.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/statoBeneficioPrestazioneDiSostegno">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">stato beneficio prestazione di sostegno</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Stato del beneficio erogato</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/statusATS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">status ATS</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmbitoTerritorialeSociale"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="it">Status di validità di un ATS.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/titoloPUC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="it">titolo PUC</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/name"/>
    <rdfs:domain rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/ProgettoDiUtilitàCollettiva"/>
    <rdfs:comment xml:lang="it">Denominazione del Progetto di utilità collettiva.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:Class rdf:about="https://w3id.org/italia/onto/CLV/City">
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/onto/CLV/Region">
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/onto/COV/Organization">
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/onto/COV/PublicOrganization">
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/onto/CPV/Alive">
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/onto/CPV/Dead">
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/onto/CPV/Person">
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/onto/l0/Agent">
    <owl:disjointWith>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
      </owl:Restriction>
    </owl:disjointWith>

  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/AccreditamentoPerFormazione">
    <rdfs:label xml:lang="it">Accreditamento per formazione</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/codiceDiAccreditamento"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haAccreditamentoPerFormazione"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">L’accreditamento è l’atto con cui un soggetto pubblico riconosce l’idoneità di soggetti pubblici e privati, con sedi operative presenti sul proprio territorio e in possesso dei requisiti necessari, a realizzare interventi di formazione finanziati con risorse pubbliche o autorizzati e non finanziati ai sensi del Titolo V della legge regionale n. 23 del 25.2.1992. L’accreditamento è il presupposto di idoneità obbligatorio e propedeutico per la partecipazione agli avvisi pubblici periodici e/o per la presentazione della domanda di autorizzazione per la realizzazione di corsi riconosciuti dalle regioni o altri soggetti pubblici. Destinatari della procedura di accreditamento sono i soggetti pubblici o privati che, indipendentemente dalla propria natura giuridica, abbiano tra i propri scopi e fini istituzionali espressamente dichiarati l’attività di formazione. L’accreditamento, una volta ottenuto, è soggetto a manutenzione periodica, quindi ha un periodo di validità che può essere rinnovato, così da garantire che i requisiti di idoneità e qualità richiesti siano sempre aggiornati e attuali. Con l’accreditamento si instaura un rapporto fiduciario tra ente pubblico e soggetto accreditato, che implica l’osservanza puntuale – formale e sostanziale - delle disposizioni rilevanti e l’utilizzo di approcci comportamentali orientati prioritariamente al raggiungimento delle finalità di interesse generale insite nei servizi offerti all’utenza (fonte: Regione Lazio).</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/AgenziaPerIlLavoro">
    <rdfs:label xml:lang="it">Agenzia per il lavoro</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di Organizzazione attribuito a chi offre servizi di intermediazione tra domanda e offerta di lavoro. L'iscrizione dell'agenzia allo specifico Albo gestito dal MLPS ne certifica l'autorizzazione a svolgere l'attività.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/AmbitoTerritorialeSociale">
    <rdfs:label xml:lang="it">Ambito territoriale sociale</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/appartieneAdAmbitoTerritoriale"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/codiceATS"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haEnteCapofilaDiATS"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haEnteDiATS"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/statusATS"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmministrazioneServizioSociale"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">L'Ambito Territoriale Sociale (ATS) è un'organizzazione deputata alla programmazione locale, progettazione, concertazione e coordinamento degli interventi e dei servizi sociali e di altre prestazioni integrate, attive a livello locale. Può esplicitarsi sia in una forma giuridica associativa tra diversi enti, principalmente i Comuni, a cui questi ultimi trasferiscono specifiche funzioni sul territorio, sia come articolazione strumentale di un ente con autonomia gestionale ma non giuridica e imprenditoriale.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/AmministrazioneServizioSociale">
    <rdfs:label xml:lang="it">Amministrazione servizio sociale</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di una organizzazione attribuito a chi partecipa al sistema di welfare locale per attivare nel territorio risorse e servizi, pubblici o privati dedicati alla rilevazione dei fabbisogni delle persone e/o dei nuclei familiari in condizione di disagio sociale e lavorativi e in grado di programmare, avviare e gestire un percorso personalizzato di accompagnamento all’inclusione sociale e all’inserimento lavorativo.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/AnalisiPreliminareNucleoFamiliare">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/esegueAnalisiPreliminareNucleo"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haAnalisiPreliminareNucleo"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/AssegnoDiInclusione">
    <rdfs:label xml:lang="it">Assegno di inclusione</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegnoNucleoFamiliare"/>
    <rdfs:comment xml:lang="it">L’Assegno Di Inclusione (ADI) è una misura nazionale di contrasto alla povertà, alla fragilità e all’esclusione sociale delle fasce deboli attraverso percorsi di inserimento sociale, nonché di formazione, di lavoro e di politica attiva del lavoro. Nel dettaglio è un beneficio economico volto all'integrazione del reddito familiare che varia in base al numero dei componenti il nucleo familiare e alle risorse economiche già possedute dal nucleo medesimo, con una componente aggiuntiva per i nuclei familiari residenti in abitazione in locazione, subordinato alla partecipazione a un percorso personalizzato di attivazione e di inclusione sociale e lavorativa che costituisce condizione abilitante per l'ottenimento e il mantenimento del suddetto beneficio.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/Atto">
    <rdfs:label xml:lang="it">Atto</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/dataAtto"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Classifica in modo generalista un qualsiasi atto ovvero una volizione formale di un soggetto che la esprime in modo volontario e responsabile. Nell'ambito di un processo l'atto si concretizza in una asserzione e/o disposizione che viene espressa da un agente mediante le forme previste dal processo stesso che possono essere la forma scritta contenuta in un documento o una registrazione strutturata e formale nell'ambito di un sistema informativo.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/AttoDiNominaRappresentanteLegale">
    <rdfs:label xml:lang="it">Atto di nomina rappresentante legale</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haConferenteAttoDiNomina"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haDesignatoAttoDiNomina"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Atto di nomina di un rappresentante legale per un soggetto inabile o minorenne.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/BeneficiarioPrestazioneDiSostegno">
    <rdfs:label xml:lang="it">Beneficiario prestazione di sostegno</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <owl:disjointWith rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/TitolarePrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Ruolo di persona riferito a chi beneficia di una prestazione di sostegno ovvero colui che ha il godimento della prestazione.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/CentroPerImpiego">
    <rdfs:label xml:lang="it">Centro per l'impiego</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/COV/hasSupportUnit"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/COV/PublicOrganization"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">È un ufficio locale della Pubblica Amministrazione, di competenza regionale e/o provinciale, a cui è demandata la funzione di attuare politiche pubbliche in materia di lavoro ed erogare servizi per favorire la ricollocazione di lavoratori idisoccupati o inoccupati tramite la stipula di un Patto di Servizio Personalizzato (PSP) ovvero di un percorso specifico di accompagnamento all'inserimento lavorativo che prevede la redazione del bilancio delle competenze e attività finalizzate alla ricerca attiva di lavoro e alla formazione o riqualificazione professionale.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/ComuneItaliano">
    <rdfs:label xml:lang="it">Comune italiano</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/City"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/COV/PublicOrganization"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CLV/hasHigherRank"/>
        <owl:someValuesFrom>
          <owl:Class>
            <owl:oneOf>
              <rdf:Description>
                <rdf:first rdf:resource="http://w3id.org/italia/controlled-vocabulary/territorial-classifications/countries/Italy"/>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </owl:oneOf>

          </owl:Class>
        </owl:someValuesFrom>

      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmministrazioneServizioSociale"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Un comune è, dal punto di vista del diritto pubblico, un ente territoriale, ovverosia un'entità geografica amministrativa composta dal territorio comunale e dall'ente pubblico, dotato di personalità giuridica, detto anch'esso comune, che amministra, per competenza territoriale, e che possiede, almeno in parte, il territorio comunale (fonte: Wikipedia). In questo dominio sono considerati solo i comuni italiani.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/CoordinatoreServizioSociale">
    <rdfs:label xml:lang="it">Coordinatore servizio sociale</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CPV/Alive"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/COV/holdEmployment"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom>
          <owl:Class>
            <owl:unionOf>
              <rdf:Description>
                <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmbitoTerritorialeSociale"/>
                <rdf:rest>
                  <rdf:Description>
                    <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/ComuneItaliano"/>
                    <rdf:rest>
                      <rdf:Description>
                        <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/ProvinciaAutonomaItaliana"/>
                        <rdf:rest>
                          <rdf:Description>
                            <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/RegioneItaliana"/>
                            <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                          </rdf:Description>
                        </rdf:rest>

                      </rdf:Description>
                    </rdf:rest>

                  </rdf:Description>
                </rdf:rest>

              </rdf:Description>
            </owl:unionOf>

          </owl:Class>
        </owl:someValuesFrom>

      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di persona attribuito a chi coordina dapprima le attività di accertamento e valutazione delle condizioni di necessità manifestate da chi si rivolge ad un servizio sociale erogato da una amministrazione allo scopo preposta, anche tramite la presentazione di domande di accesso a prestazioni di sostegno e, successivamente, le azioni concertate per il superamento di tali necessità.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/DatoreDiLavoro">
    <rdfs:label xml:lang="it">Datore di lavoro</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di una organizzazione attribuito a chi retribuisce, nell'ambito di un rapporto di lavoro, una prestazione lavorativa erogata da un lavoratore.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegno">
    <rdfs:label xml:lang="it">Domanda prestazione di sostegno</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/Atto"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/protocolloMisuraDomandaPrestazioneDiSostegno"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Sottoclasse di Atto che classifica le domande di prestazioni di sostegno presentate a vario titolo da soggetti che possiedono i requisti per ottenere la prestazione richiesta.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegnoNucleoFamiliare">
    <rdfs:label xml:lang="it">Domanda prestazione di sostegno nucleo familiare</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haDomandaPrestazioneDiSostegno"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegnoNucleoFamiliare"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Sottoclasse di Domanda di prestazione di sostegno relative alle prestazioni di sostegno dedicate all'intero nucleo familiare.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/EnteFormativo">
    <rdfs:label xml:lang="it">Ente formativo</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di Organizzazione attribuito a chi gestisce ed eroga corsi e attività di formazione. Nell'ambito di percorsi di inclusione lavorativa e sociale, gli enti formativi risultano accreditati ovvero ottengono tramite opportuni criteri di selezione una certificazione da parte di un'autorità pubblica che ne attesta la qualità, l'affidabilità e la capacità di erogare corsi di formazione validi e conformi a specifici standard.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/FascicoloSocialeLavorativoDelCittadino">
    <rdfs:label xml:lang="it">Fascicolo sociale e lavorativo del cittadino</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haFascicoloSocialeLavorativo"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Rappresenta la condizione sociale e lavorativa di un cittadino tramite i suoi legami con le diverse entità che esprimono tale condizione. In particolare, tramite il fascicolo è possibile esplorare la condizione sociale, lavorativa e formativa di un cittadino potendone osservare eventuali disagi, fragilità e criticità nonchè gli strumenti di sostegno e i percorsi di inclusione attivati nell'ambito delle politiche attive previste dalla normativa e pianificate dai diversi enti preposti.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/GestoreServizioSociale">
    <rdfs:label xml:lang="it">Gestore servizio sociale</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CPV/Alive"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/COV/holdEmployment"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom>
          <owl:Class>
            <owl:unionOf>
              <rdf:Description>
                <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmbitoTerritorialeSociale"/>
                <rdf:rest>
                  <rdf:Description>
                    <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/ComuneItaliano"/>
                    <rdf:rest>
                      <rdf:Description>
                        <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/ProvinciaAutonomaItaliana"/>
                        <rdf:rest>
                          <rdf:Description>
                            <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/RegioneItaliana"/>
                            <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                          </rdf:Description>
                        </rdf:rest>

                      </rdf:Description>
                    </rdf:rest>

                  </rdf:Description>
                </rdf:rest>

              </rdf:Description>
            </owl:unionOf>

          </owl:Class>
        </owl:someValuesFrom>

      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di persona attribuito a chi gestisce nell'ambito di uno specifico servizio sociale e sotto la supervisione di un coordinatore, le singole situazioni di necessità sociale e/o lavorativa manifestate da cittadini in stato di bisogno.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno">
    <rdfs:label xml:lang="it">Prestazione di sostegno</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haTipoPrestazioneDiSostegno"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/statoBeneficioPrestazioneDiSostegno"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Classifica in modo generalista le prestazioni, i sussidi e le indennità stabilite normativamente ed erogate dagli enti preposti a vantaggio di persone o nuclei familiari in stato di difficoltà lavorativa, economica, sociale e sanitaria.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegnoIndividuale">
    <rdfs:label xml:lang="it">Prestazione di sostegno individuale</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <owl:disjointWith rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegnoNucleoFamiliare"/>
    <rdfs:comment xml:lang="it">Generalizzazione delle prestazioni di sostegno dedicate ai singoli individui.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegnoNucleoFamiliare">
    <rdfs:label xml:lang="it">Prestazione di sostegno nucleo familiare</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegno"/>
    <rdfs:comment xml:lang="it">Generalizzazione delle prestazioni di sostegno dedicate ai nuclei familiari  e quindi ai relativi componenti.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/ProgettoDiUtilitàCollettiva">
    <rdfs:label xml:lang="it">Progetto di utilità collettiva</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/titoloPUC"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haAttivatoPUC"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">I Progetti di utilità collettiva (PUC) sono strumenti introdotti dal decreto-legge 28 gennaio 2019, n. 4 e successive modificazioni, per arricchire la strumentazione volta a favorire l’inserimento sociale o lavorativo dei soggetti beneficiari di sussidi (RdC e successivamente ADI) e sottoscrittori del Patto per l’inclusione sociale o del Patto per il Lavoro nell’ambito del loro percorso personalizzato. Tali progetti, a titolarità dei Comuni o di altre amministrazioni pubbliche a tal fine convenzionate con i Comuni, possono essere realizzati in ambito culturale, sociale, artistico, ambientale, formativo e di tutela dei beni comuni e svolti presso il Comune di residenza del beneficiario, compatibilmente con le altre attività svolte dallo stesso, prevedendo un suo impegno in ogni caso non inferiore a otto ore settimanali, fino a un massimo di sedici ore settimanali, previo accordo tra le parti. A questo scopo, i Comuni possono anche attivare collaborazioni con gli enti del Terzo settore per la progettazione e la realizzazione dei PUC. Tali attività sono svolte a titolo gratuito, non sono assimilabili a una prestazione di lavoro subordinato o parasubordinato e non determinano l’instaurazione di un rapporto di pubblico impiego con le amministrazioni pubbliche.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/ProvinciaAutonomaItaliana">
    <rdfs:label xml:lang="it">Provincia autonoma italiana</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/COV/PublicOrganization"/>
    <rdfs:subClassOf>
      <owl:Class>
        <owl:oneOf>
          <rdf:Description>
            <rdf:first>
              <owl:NamedIndividual rdf:about="https://w3id.org/italia/controlled-vocabulary/territorial-classifications/provinces/Bolzano">
              </owl:NamedIndividual>
            </rdf:first>

            <rdf:rest>
              <rdf:Description>
                <rdf:first>
                  <owl:NamedIndividual rdf:about="https://w3id.org/italia/controlled-vocabulary/territorial-classifications/provinces/Trento">
                  </owl:NamedIndividual>
                </rdf:first>

                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </rdf:rest>

          </rdf:Description>
        </owl:oneOf>

      </owl:Class>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmministrazioneServizioSociale"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Una provincia, in Italia, è un ente locale territoriale di area vasta, di livello inferiore alla regione e superiore a quello del comune. In particolare, ci sono due province autonome: quelle di Trento e di Bolzano. Sono autonome in virtù di uno statuto speciale che attribuisce loro particolari forme di autonomia, compresa quella legislativa. Quest'autonomia le rende assimilabili alle regioni e le differenzia dalle altre province, che hanno compiti molto più ridotti.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/QuadroDiAnalisiNucleoFamiliare">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/esegueQuadroDiAnalisiNucleo"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haQuadroDiAnalisiNucleoFamiliare"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/RappresentanteLegale">
    <rdfs:label xml:lang="it">Rappresentante legale</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haDesignatoAttoDiNomina"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di agente riferito al soggetto che funge da rappresentante di un titolare di un diritto a una prestazione di sostegno e/o di un beneficiario di tale prestazione in virtu dell'incapacità di questi di esercitare o gestire tale diritto e/o prestazione.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/RegioneItaliana">
    <rdfs:label xml:lang="it">Regione italiana</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/Region"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/COV/PublicOrganization"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CLV/hasHigherRank"/>
        <owl:someValuesFrom>
          <owl:Class>
            <owl:oneOf>
              <rdf:Description>
                <rdf:first rdf:resource="http://w3id.org/italia/controlled-vocabulary/territorial-classifications/countries/Italy"/>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
              </rdf:Description>
            </owl:oneOf>

          </owl:Class>
        </owl:someValuesFrom>

      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/AmministrazioneServizioSociale"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Una regione italiana rappresenta il primo livello di suddivisione territoriale della Repubblica Italiana, nonché un ente pubblico dotato di autonomia politica e amministrativa sancita e limitata principalmente dalla Costituzione (fonte: Wikipedia).</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/RichiedentePrestazioneDiSostegno">
    <rdfs:label xml:lang="it">Richiedente prestazione di sostegno</rdfs:label>
    <rdfs:subClassOf>
      <owl:Class>
        <owl:unionOf>
          <rdf:Description>
            <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/RappresentanteLegale"/>
            <rdf:rest>
              <rdf:Description>
                <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/SuperstiteDiTitolareDiPrestazioneDiSostegno"/>
                <rdf:rest>
                  <rdf:Description>
                    <rdf:first rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/TitolarePrestazioneDiSostegno"/>
                    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                  </rdf:Description>
                </rdf:rest>

              </rdf:Description>
            </rdf:rest>

          </rdf:Description>
        </owl:unionOf>

      </owl:Class>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di agente riferito a chi presenta, anche per delega, una domanda per l'ottenimento di una prestazione di sostegno per se stesso e/o per altri.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/RichiedentePrestazioneDiSostegnoNucleoFamiliare">
    <rdfs:label xml:lang="it">Richiedente prestazione di sostegno nucleo familiare</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/presentaDomandaPrestazioneDiSostegno"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegnoNucleoFamiliare"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Sottoclasse di Richiedente prestazione di sostegno riferita a prestazioni di sostegno dedicate ad un nucleo familiare. In questo caso il richiedente è un componente del nucleo familiare, o un suo delegato, idoneo alla presentazione della relativa domanda.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/SuperstiteDiTitolareDiPrestazioneDiSostegno">
    <rdfs:label xml:lang="it">Superstite di titolare di prestazione di sostegno</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di persona viva e residente che ha diritto ad una prestazione di sostegno in quanto superstite un titolare o dante causa.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/SupportoFormazioneLavoro">
    <rdfs:label xml:lang="it">Supporto formazione lavoro</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/PrestazioneDiSostegnoIndividuale"/>
    <rdfs:comment xml:lang="it">Il Supporto per la Formazione e il Lavoro (SFL) è una misura finalizzata a favorire l’attivazione nel mondo del lavoro delle persone a rischio di esclusione sociale e lavorativa, mediante la partecipazione a progetti di formazione, di qualificazione e riqualificazione professionale, di orientamento, di accompagnamento al lavoro e di politiche attive del lavoro, nonché dei progetti utili alla collettività e del servizio civile universale e prevede la corresponsione di una indennità di partecipazione alle misure di attivazione lavorativa, condizionato all’effettiva partecipazione alle attività sopra indicate.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/TitolarePrestazioneDiSostegno">
    <rdfs:label xml:lang="it">Titolare prestazione di sostegno</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <rdf:Description>
            <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
          </rdf:Description>
        </owl:onProperty>

        <owl:someValuesFrom>
          <owl:Class>
            <owl:unionOf>
              <rdf:Description>
                <rdf:first rdf:resource="https://w3id.org/italia/onto/CPV/Dead"/>
                <rdf:rest>
                  <rdf:Description>
                    <rdf:first rdf:resource="https://w3id.org/italia/onto/RPO/RegisteredResidentPerson"/>
                    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                  </rdf:Description>
                </rdf:rest>

              </rdf:Description>
            </owl:unionOf>

          </owl:Class>
        </owl:someValuesFrom>

      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Ruolo di persona viva e residente o deceduta riferito a colui che ha diritto alla prestazione di sostegno ed è quindi titolato a presentare la relativa domanda, eventualmente tramite un delegato o un suo superstite.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://w3id.org/italia/labour-social-policies/onto/core/TitolarePrestazioneDiSostegnoNucleoFamiliare">
    <rdfs:label xml:lang="it">Titolare prestazione di sostegno nucleo familiare</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/haDirittoAPrestazioneDiSostegno"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/labour-social-policies/onto/core/DomandaPrestazioneDiSostegnoNucleoFamiliare"/>
      </owl:Restriction>
    </rdfs:subClassOf>

    <rdfs:comment xml:lang="it">Sottoclasse di Titolare prestazione di sostegno riferita a prestazioni di sostegno dedicate ad un nucleo familiare. In questo caso il tirolare è un componente del nucleo familiare.</rdfs:comment>
  </owl:Class>

