### Axioms

[] a owl:AllDisjointClasses ;
    owl:members (
            lsp-core:AccreditamentoPerFormazione
            lsp-core:DomandaPrestazioneDiSostegno
            lsp-labour:PattoAttivazioneDigitaleIndividuale
            lsp-labour:PattoServizioPersonalizzato
            lsp-social:PattoAttivazioneDigitaleNucleo
            lsp-social:PattoInclusioneSocialeDelCaso ) .

[] a owl:AllDisjointClasses ;
    owl:members (
            lsp-core:AgenziaPerIlLavoro
            lsp-core:AmministrazioneServizioSociale
            lsp-core:DatoreDiLavoro
            lsp-core:EnteFormativo ) .

[] a owl:AllDisjointClasses ;
    owl:members (
            lsp-core:AmbitoTerritorialeSociale
            lsp-core:ComuneItaliano
            lsp-core:ProvinciaAutonomaItaliana
            lsp-core:RegioneItaliana ) .

[] a owl:AllDisjointClasses ;
    owl:members (
            lsp-core:ComuneItaliano
            lsp-core:ProvinciaAutonomaItaliana
            lsp-core:RegioneItaliana ) .

[] a owl:AllDisjointClasses ;
    owl:members (
            lsp-core:RappresentanteLegale
            lsp-core:SuperstiteDiTitolareDiPrestazioneDiSostegno
            lsp-core:TitolarePrestazioneDiSostegno ) .

[] a owl:Restriction ;
    owl:onProperty lsp-core:esprimeAtto ;
    owl:someValuesFrom lsp-core:AccreditamentoPerFormazione ;
    rdfs:subClassOf COV:PublicOrganization .

[] a owl:Restriction ;
    owl:onProperty lsp-core:haDirittoAPrestazioneDiSostegno ;
    owl:someValuesFrom lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare ;
    rdfs:subClassOf lsp-core:TitolarePrestazioneDiSostegnoNucleoFamiliare .

[] a owl:Restriction ;
    owl:onProperty lsp-core:presentaDomandaPrestazioneDiSostegno ;
    owl:someValuesFrom lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare ;
    rdfs:subClassOf lsp-core:RichiedentePrestazioneDiSostegnoNucleoFamiliare .

[] a owl:Restriction ;
    owl:onProperty RO:holdsRoleInTime ;
    owl:someValuesFrom lsp-core:RichiedentePrestazioneDiSostegno ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty smapit:hasOnlineContactPoint ;
            owl:someValuesFrom owl:Thing ] .

[] a owl:Restriction ;
    owl:onProperty [ owl:inverseOf lsp-core:haDomandaPrestazioneDiSostegno ] ;
    owl:someValuesFrom lsp-core:PrestazioneDiSostegnoNucleoFamiliare ;
    rdfs:subClassOf lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare .

