@prefix CLV: <https://w3id.org/italia/onto/CLV/> .
@prefix countries: <http://w3id.org/italia/controlled-vocabulary/territorial-classifications/countries/> .
@prefix COV: <https://w3id.org/italia/onto/COV/> .
@prefix CPV: <https://w3id.org/italia/onto/CPV/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcatapit: <http://dati.gov.it/onto/dcatapit#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix L0: <https://w3id.org/italia/onto/l0/> .
@prefix lsp-core: <https://w3id.org/italia/labour-social-policies/onto/core/> .
@prefix lsp-labour: <https://w3id.org/italia/labour-social-policies/onto/labour/> .
@prefix lsp-social: <https://w3id.org/italia/labour-social-policies/onto/social/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix provinces: <https://w3id.org/italia/controlled-vocabulary/territorial-classifications/provinces/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix RO: <https://w3id.org/italia/onto/RO/> .
@prefix rpo: <https://w3id.org/italia/onto/RPO/> .
@prefix smapit: <https://w3id.org/italia/onto/SM/> .
@prefix TI: <https://w3id.org/italia/onto/TI/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

lsp-core: a owl:Ontology ;
    owl:versionIRI lsp-core:1.1 ;
    owl:imports CLV:,
        COV:,
        CPV:,
        L0:,
        RO: ;
    rdfs:label "Core Labour and Social Policies Ministry Ontology"@en,
        "Ontologia Core del Ministero del Lavoro e delle Politiche Sociali"@it ;
    rdfs:comment "Ontologia del Ministero del Lavoro e delle Politiche Sociali relativa al Fascicolo sociale e lavorativo del cittadino nell'ambito del sistema informativo pubblico e la sua funzione di hub di accesso alle informazioni sul cittadino in special modo quelle inerenti il suo coinvolgimento in iniziative di inclusione originate dalla necessità di sopperire alle fragilità sociali e lavorative sue proprie o del suo nucleo familiare."@it,
        "This is the ontology of the Labour and Social Policies Ministry about the citizen's social and employment record within the public information system and its function as a hub for accessing information on citizens, especially those relating to their involvement in inclusion initiatives arising from the need to address their own or their family's social and employment vulnerabilities.."@en ;
    owl:versionInfo "0.2 - Modificata il 26 Febbraio 2026"@it,
        "0.2 - Modified on 26 February 2026"@en ;
    rdfs:isDefinedBy lsp-core: ;
    adms:acronym "lsp" ;
    adms:hasContributor <https://w3id.org/italia/data/organization/public-organization/td> ;
    adms:hasFormalityLevel adms:Formal ;
    adms:hasKeyClass lsp-core:FascicoloSocialeLavorativoDelCittadino,
        lsp-core:PrestazioneDiSostegno ;
    adms:hasOntologyLanguage adms:OWL ;
    adms:hasSemanticAssetDistribution <https://w3id.org/italia/labour-social-policies/data/core/distribution/MLPSCORE-N-TRIPLES>,
        <https://w3id.org/italia/labour-social-policies/data/core/distribution/MLPSCORE-RDF-TURTLE>,
        <https://w3id.org/italia/labour-social-policies/data/core/distribution/MLPSCORE-RDF-XML> ;
    adms:hasTask adms:AnnotationTask,
        adms:QueryFormulationTask,
        adms:SearchTask ;
    adms:last lsp-core:1.1 ;
    adms:officialURI "https://w3id.org/italia/labour-social-policies/onto/core/"^^xsd:anyURI ;
    adms:prefix "lsp-core" ;
    adms:semanticAssetInUse <https://w3id.org/italia/data/project/NDC> ;
    adms:status "draft" ;
    adms:target "Cittadini"@it,
        "Imprese"@it,
        "Pubbliche Amministrazioni"@it ;
    adms:type adms:ServiceOnytology ;
    dcat:contactPoint <https://w3id.org/italia/labour-social-policies/data/organization/DGInnovazioneDiv3> ;
    dcat:keyword "Citizen's social and employment file"@en,
        "Fascicolo sociale e lavorativo del cittadino"@it,
        "Prestazione Di Sostegno"@it,
        "Support Performance"@en ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/SOCI> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:creator <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:description "Ontologia del Ministero del Lavoro e delle Politiche Sociali relativa al Fascicolo sociale e lavorativo del cittadino nell'ambito del sistema informativo pubblico e la sua funzione di hub di accesso alle informazioni sul cittadino in special modo quelle inerenti il suo coinvolgimento in iniziative di inclusione originate dalla necessità di sopperire alle fragilità sociali e lavorative sue proprie o del suo nucleo familiare."@it,
        "This is the ontology of the Labour and Social Policies Ministry about the citizen's social and employment record within the public information system and its function as a hub for accessing information on citizens, especially those relating to their involvement in inclusion initiatives arising from the need to address their own or their family's social and employment vulnerabilities."@en ;
    dct:identifier "https://w3id.org/italia/labour-social-policies/onto/core" ;
    dct:issued "2025-12-09T00:00:00+00:00"^^xsd:dateTime ;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG>,
        <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-02-26T00:00:00+00:00"^^xsd:dateTime ;
    dct:publisher <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:rightsHolder <https://w3id.org/italia/labour-social-policies/data/organization/mlps> ;
    dct:title "Core Labour and Social Policies Ministry Ontology"@en,
        "Ontologia Core del Ministero del Lavoro e delle Politiche Sociali"@it .

### Object Properties

CLV:hasHigherRank a owl:ObjectProperty .

COV:hasSupportUnit a owl:ObjectProperty .

COV:holdEmployment a owl:ObjectProperty .

lsp-core:appartieneAdAmbitoTerritoriale a owl:ObjectProperty ;
    rdfs:label "appartiene ad ambito territoriale"@it ;
    rdfs:domain CLV:City ;
    rdfs:range lsp-core:AmbitoTerritorialeSociale ;
    rdfs:comment "Relazione che collega la classe Ambito Territoriale Sociale con la classe CLV:City"@it .

lsp-core:contieneCVCittadino a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "contiene CV cittadino"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-labour:CurriculumVitaeCittadino ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad un suo CV."@it .

lsp-core:contieneInteresseCorsoDiFormazione a owl:ObjectProperty ;
    rdfs:label "contiene interesse corso di formazione"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-labour:OffertaFormativa ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad un Corso di formazione verso cui ha manifestato interesse."@it .

lsp-core:contieneInteresseOffertaDiLavoro a owl:ObjectProperty ;
    rdfs:label "contiene interesse offerta di lavoro"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-labour:OffertaDiLavoro ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad una Offerta di lavoro verso cui ha manifestato interesse."@it .

lsp-core:contieneIscrizioneCorsoDiFormazione a owl:ObjectProperty ;
    rdfs:label "contiene iscrizione corso di formazione"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-labour:OffertaFormativa ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad un Corso di formazione a cui si è iscritto."@it .

lsp-core:contienePADIndividuale a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "contiene PAD individuale"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-labour:PattoAttivazioneDigitaleIndividuale ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad un suo PAD individuale."@it .

lsp-core:contienePattoServizioPersonalizzato a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "contiene patto servizio personalizzato"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-labour:PattoServizioPersonalizzato ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad un suo PSP."@it .

lsp-core:contieneRispostaOffertaDiLavoro a owl:ObjectProperty ;
    rdfs:label "contiene risposta offerta di lavoro"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-labour:OffertaDiLavoro ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad una Offerta di lavoro verso cui a fatto domanda."@it .

lsp-core:esegueAnalisiPreliminareNucleo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "esegue analisi preliminare nucleo"@it ;
    rdfs:domain lsp-core:AmministrazioneServizioSociale ;
    rdfs:range lsp-core:AnalisiPreliminareNucleoFamiliare ;
    rdfs:comment "Lega un Gestore servizio sociale ad una Analisi preliminare di un nucleo familiare da lui eseguita."@it .

lsp-core:esegueQuadroDiAnalisiNucleo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "esegue quadro di analisi nucleo"@it ;
    rdfs:domain lsp-core:AmministrazioneServizioSociale ;
    rdfs:range lsp-core:QuadroDiAnalisiNucleoFamiliare ;
    rdfs:comment "Lega un Gestore servizio sociale ad un Quadro di analisi di un nucleo familiare da lui eseguito."@it .

lsp-core:esprimeAtto a owl:ObjectProperty ;
    rdfs:label "esprime atto"@it ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf (
                    L0:Agent
                    [ a owl:Restriction ;
                        owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
                        owl:someValuesFrom L0:Agent ] ) ] ;
    rdfs:range lsp-core:Atto ;
    rdfs:comment "Lega un atto all'agente (o ruolo di agente) che lo ha espresso."@it .

lsp-core:haAccreditamentoPerFormazione a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha accreditamento per formazione"@it ;
    rdfs:domain lsp-core:EnteFormativo ;
    rdfs:range lsp-core:AccreditamentoPerFormazione ;
    rdfs:comment "Lega un Ente formatore o un Intermediario formativo al suo atto di accreditamento riconosciuto da un ente pubblico."@it .

lsp-core:haAnalisiPreliminareNucleo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha analisi preliminare nucleo"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-core:AnalisiPreliminareNucleoFamiliare ;
    rdfs:comment "Lega un Percorso d'inclusione di un nucleo familiare alla sua Analisi preliminare."@it .

lsp-core:haAttivatoPUC a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha attivato PUC"@it ;
    rdfs:domain COV:PublicOrganization ;
    rdfs:range lsp-core:ProgettoDiUtilitàCollettiva ;
    rdfs:comment "Lega un ente pubblico a un Progetto di utilità collettiva da lui promosso."@it .

lsp-core:haBeneficiarioPrestazioneDiSostegno a owl:ObjectProperty ;
    rdfs:label "ha beneficiario prestazione di sostegno"@it ;
    rdfs:domain lsp-core:PrestazioneDiSostegno ;
    rdfs:range lsp-core:BeneficiarioPrestazioneDiSostegno ;
    rdfs:comment "Lega una prestazione di sostegno con un beneficiario della prestazione."@it .

lsp-core:haComponenteDiATS a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha componente di ATS"@it ;
    rdfs:domain lsp-core:AmbitoTerritorialeSociale ;
    rdfs:range COV:PublicOrganization ;
    rdfs:comment "Lega un ATS ad un ente pubblico che ne fa parte."@it .

lsp-core:haConferenteAttoDiNomina a owl:ObjectProperty ;
    rdfs:label "ha conferente atto di nomina"@it ;
    rdfs:domain lsp-core:AttoDiNominaRappresentanteLegale ;
    rdfs:range [ a owl:Class ;
            owl:unionOf (
                    lsp-core:BeneficiarioPrestazioneDiSostegno
                    lsp-core:TitolarePrestazioneDiSostegno ) ] ;
    rdfs:comment "Lega un atto di nomina del rappresentante legale ai conferenti la nomina."@it .

lsp-core:haDesignatoAttoDiNomina a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha designato atto di nomina"@it ;
    rdfs:domain lsp-core:AttoDiNominaRappresentanteLegale ;
    rdfs:range lsp-core:RappresentanteLegale ;
    rdfs:comment "Lega un atto di nomina al relativo rappresentante che viene nominato."@it .

lsp-core:haDirittoAPrestazioneDiSostegno a owl:ObjectProperty ;
    rdfs:label "ha diritto a prestazione di sostegno"@it ;
    rdfs:domain lsp-core:TitolarePrestazioneDiSostegno ;
    rdfs:range lsp-core:DomandaPrestazioneDiSostegno ;
    rdfs:comment "Lega un Titolare di prestazione di sostegno ovvero un avente diritto a tale prestazione alla domanda inoltrata per ottenere il beneficio della prestazione."@it .

lsp-core:haDomandaPrestazioneDiSostegno a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha domanda prestazione di sostegno"@it ;
    rdfs:domain lsp-core:PrestazioneDiSostegno ;
    rdfs:range lsp-core:DomandaPrestazioneDiSostegno ;
    rdfs:comment "Lega una prestazione di sostegno alla domanda presentata per l'ottenimento della prestazione stessa."@it .

lsp-core:haEnteCapofilaDiATS a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha ente capofila di ATS"@it ;
    rdfs:domain lsp-core:AmbitoTerritorialeSociale ;
    rdfs:range COV:PublicOrganization ;
    rdfs:comment "Lega un ATS all'ente pubblico che ne è capofila."@it .

lsp-core:haEnteDiATS a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha ente di ATS"@it ;
    rdfs:domain lsp-core:AmbitoTerritorialeSociale ;
    rdfs:range [ a owl:Class ;
            owl:unionOf (
                    lsp-core:ProvinciaAutonomaItaliana
                    lsp-core:RegioneItaliana ) ] ;
    rdfs:comment "Lega un ATS alla suo ente amministrativo sovraordinato che può essere una Regione italiana o una Provincia autonoma italiana."@it .

lsp-core:haFascicoloSocialeLavorativo a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha fascicolo sociale e lavorativo"@it ;
    rdfs:domain rpo:RegisteredResidentPerson ;
    rdfs:range lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:comment "Lega un Cittadino al suo Fascicolo sociale e lavorativo."@it .

lsp-core:haPADDiCasoDiNucleo a owl:ObjectProperty ;
    rdfs:label "ha PAD di caso di nucleo"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-social:PattoAttivazioneDigitaleNucleo ;
    rdfs:comment "Lega un caso di nucleo familiare fragile o in povertà al relativo PAD del nucleo sottoscritto."@it .

lsp-core:haPattoInclusioneSocialeNucleo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha patto inclusione sociale nucleo"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-social:PattoInclusioneSocialeDelCaso ;
    rdfs:comment "Lega un Percorso d'inclusione di un nucleo familiare al suo PaIS nucleo."@it .

lsp-core:haQuadroDiAnalisiNucleoFamiliare a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha quadro di analisi nucleo familiare"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-core:QuadroDiAnalisiNucleoFamiliare ;
    rdfs:comment "Lega un Percorso d'inclusione di un nucleo familiare al suo Quadro di analisi."@it .

lsp-core:haTipoPrestazioneDiSostegno a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ha tipo prestazione di sostegno"@it ;
    rdfs:domain lsp-core:PrestazioneDiSostegno ;
    rdfs:range lsp-core:TipoPrestazioneDiSostegno ;
    rdfs:comment "Lega una prestazione di sostegno al suo tipo."@it .

lsp-core:indicaBeneficiarioPrestazioneDiSostegno a owl:ObjectProperty ;
    rdfs:label "indica beneficiario prestazione di sostegno"@it ;
    rdfs:domain lsp-core:DomandaPrestazioneDiSostegno ;
    rdfs:range lsp-core:BeneficiarioPrestazioneDiSostegno ;
    rdfs:comment "Lega una richiesta di prestazione di sostegno a un beneficiario della prestazione."@it .

lsp-core:presentaDomandaPrestazioneDiSostegno a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "presenta domanda prestazione di sostegno"@it ;
    rdfs:domain lsp-core:RichiedentePrestazioneDiSostegno ;
    rdfs:range lsp-core:DomandaPrestazioneDiSostegno ;
    rdfs:comment "Lega un richiedente a una sua domanda di prestazione di sostegno."@it .

lsp-core:riferisceAnalisiPreliminareNucleo a owl:ObjectProperty ;
    rdfs:label "riferisce analisi preliminare nucleo"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-core:AnalisiPreliminareNucleoFamiliare ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad un'Analisi preliminare relativa al nucleo familiare di cui è componente."@it .

lsp-core:riferiscePADNucleo a owl:ObjectProperty ;
    rdfs:label "riferisce PAD nucleo"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-social:PattoAttivazioneDigitaleNucleo ;
    rdfs:comment "Lega il fascicolo di un Cittadino al PAD nucleo relativo al nucleo familiare di cui è componente."@it .

lsp-core:riferiscePattoInclusioneSocialeNucleo a owl:ObjectProperty ;
    rdfs:label "riferisce patto inclusione sociale nucleo"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-social:PattoInclusioneSocialeDelCaso ;
    rdfs:comment "Lega il fascicolo di un Cittadino al PaIS relativo al nucleo familiare di cui è componente."@it .

lsp-core:riferiscePattoServizioPersonalizzato a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "riferisce patto servizio personalizzato"@it ;
    rdfs:domain lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:range lsp-labour:PattoServizioPersonalizzato ;
    rdfs:comment "Lega un Percorso d'inclusione di un nucleo familiare al PSP di un suo componente attivabile al lavoro, obbligatorio o volontario."@it .

lsp-core:riferiscePercorsoNucleoFamiliare a owl:ObjectProperty ;
    rdfs:label "riferisce percorso nucleo familiare"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-social:CasoDiNucleoFragileOInPovertà ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad un Percorso d'inclusione sociale relativo al nucleo familiare di cui è componente."@it .

lsp-core:riferiscePrestazioneDiSostegno a owl:ObjectProperty ;
    rdfs:label "riferisce prestazione di sostegno"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-core:PrestazioneDiSostegno ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad una prestazione di sostegno. Il Cittadino può partecpare al legame in qualità di beneficiario di una prestazione individuel o come componente di un nucleo familiare beneficiario."@it .

lsp-core:riferisceQuadroDiAnalisiNucleo a owl:ObjectProperty ;
    rdfs:label "riferisce quadro di analisi nucleo"@it ;
    rdfs:domain lsp-core:FascicoloSocialeLavorativoDelCittadino ;
    rdfs:range lsp-core:QuadroDiAnalisiNucleoFamiliare ;
    rdfs:comment "Lega il fascicolo di un Cittadino ad un Quadro di analisi relativo al nucleo familiare di cui è componente."@it .

lsp-core:stipulaPattoInclusioneSocialeNucleo a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "stipula patto inclusione sociale nucleo"@it ;
    rdfs:domain lsp-core:AmministrazioneServizioSociale ;
    rdfs:range lsp-social:PattoInclusioneSocialeDelCaso ;
    rdfs:comment "Lega un Gestore servizio sociale ad un PaIS di un nucleo familiare da lui formalizzato."@it .

lsp-core:èRinnovoDiDomandaDiSostegno a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "è rinnovo di domanda di sostegno"@it ;
    rdfs:domain lsp-core:DomandaPrestazioneDiSostegno ;
    rdfs:range lsp-core:DomandaPrestazioneDiSostegno ;
    rdfs:comment "Lega una domanda di prestazione di sostegno ad una e una sola altra domanda antecedente di cui rappresenta il rinnovo o prolugamento."@it .

RO:holdsRoleInTime a owl:ObjectProperty .

smapit:hasOnlineContactPoint a owl:ObjectProperty .

TI:atTime a owl:ObjectProperty .

### Datatypes

xsd:dateTime a rdfs:Datatype .

xsd:string a rdfs:Datatype .

### Data Properties

L0:identifier a owl:DatatypeProperty .

L0:name a owl:DatatypeProperty .

lsp-core:ambitoAccreditamentoAltro a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "ambito accreditamento altro"@it ;
    rdfs:domain lsp-core:EnteFormativo ;
    rdfs:comment "Altro ambito di accreditamento"@it .

lsp-core:avvisoDeclaratoriaFirmata a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "avviso declaratoria firmata"@it ;
    rdfs:domain lsp-social:PattoAttivazioneDigitaleNucleo ;
    rdfs:comment "Booleano che indica se la declaratoria è stata firmata"@it .

lsp-core:codiceAgenziaPerIlLavoro a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "codice agenzia per il lavoro"@it ;
    rdfs:subPropertyOf L0:identifier ;
    rdfs:domain lsp-core:AgenziaPerIlLavoro ;
    rdfs:comment "Codice identificativo interno di una Agenzia per il lavoro."@it .

lsp-core:codiceATS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "codice ATS"@it ;
    rdfs:domain lsp-core:AmbitoTerritorialeSociale ;
    rdfs:range xsd:string ;
    rdfs:comment "Codice amministrativo univoco di un ATS."@it .

lsp-core:codiceDiAccreditamento a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "codice di accreditamento"@it ;
    rdfs:domain lsp-core:AccreditamentoPerFormazione ;
    rdfs:range xsd:string ;
    rdfs:comment "È il codice attribuito da un Ente pubblico che certifica il possesso dei requisiti necessari e obbligatori affinche il soggetto che lo possiede possa erogare servizi formativi."@it .

lsp-core:dataAtto a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data atto"@it ;
    rdfs:domain lsp-core:Atto ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "È la data di emissione di un atto."@it .

lsp-core:dataFineAttivita a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "data fine attività"@it ;
    rdfs:domain lsp-core:AgenziaPerIlLavoro ;
    rdfs:comment "Indica la data di fine attività"@it .

lsp-core:fax a owl:DatatypeProperty ;
    rdfs:label "fax"@it ;
    rdfs:domain CPV:Alive ;
    rdfs:comment "Numerazione telefonica dedicata, strutturata come un numero fisso standard, utilizzata per trasmettere e ricevere immagini di documenti tramite apparecchiature fax o servizi online"@it .

lsp-core:identificativoAtto a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "identificativo atto"@it ;
    rdfs:subPropertyOf L0:identifier ;
    rdfs:domain lsp-core:Atto ;
    rdfs:comment "È l'identificatore univoco di un atto."@it .

lsp-core:protocolloMisuraDomandaPrestazioneDiSostegno a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "protocollo misura domanda prestazione di sostegno"@it ;
    rdfs:domain lsp-core:DomandaPrestazioneDiSostegno ;
    rdfs:comment "Protocolli domande ADI e RDC correlate al caso"@it .

lsp-core:protocolloPrestazioneDiSostegno a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "protocollo prestazione di sostegno"@it ;
    rdfs:subPropertyOf L0:identifier ;
    rdfs:domain lsp-core:PrestazioneDiSostegno ;
    rdfs:comment "È l'identificatore univoco di una prestazione di sostegno."@it .

lsp-core:statoBeneficioPrestazioneDiSostegno a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "stato beneficio prestazione di sostegno"@it ;
    rdfs:domain lsp-core:PrestazioneDiSostegno ;
    rdfs:comment "Stato del beneficio erogato"@it .

lsp-core:statusATS a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "status ATS"@it ;
    rdfs:domain lsp-core:AmbitoTerritorialeSociale ;
    rdfs:range xsd:string ;
    rdfs:comment "Status di validità di un ATS."@it .

lsp-core:titoloPUC a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "titolo PUC"@it ;
    rdfs:subPropertyOf L0:name ;
    rdfs:domain lsp-core:ProgettoDiUtilitàCollettiva ;
    rdfs:comment "Denominazione del Progetto di utilità collettiva."@it .

### Classes

CLV:City a owl:Class .

CLV:Region a owl:Class .

COV:Organization a owl:Class .

COV:PublicOrganization a owl:Class .

CPV:Alive a owl:Class .

CPV:Dead a owl:Class .

CPV:Person a owl:Class .

L0:Agent a owl:Class ;
    owl:disjointWith [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom L0:Agent ] .

lsp-core:AccreditamentoPerFormazione a owl:Class ;
    rdfs:label "Accreditamento per formazione"@it ;
    rdfs:subClassOf lsp-core:Atto,
        [ a owl:Restriction ;
            owl:onProperty lsp-core:codiceDiAccreditamento ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty TI:atTime ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haAccreditamentoPerFormazione ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "L’accreditamento è l’atto con cui un soggetto pubblico riconosce l’idoneità di soggetti pubblici e privati, con sedi operative presenti sul proprio territorio e in possesso dei requisiti necessari, a realizzare interventi di formazione finanziati con risorse pubbliche o autorizzati e non finanziati ai sensi del Titolo V della legge regionale n. 23 del 25.2.1992. L’accreditamento è il presupposto di idoneità obbligatorio e propedeutico per la partecipazione agli avvisi pubblici periodici e/o per la presentazione della domanda di autorizzazione per la realizzazione di corsi riconosciuti dalle regioni o altri soggetti pubblici. Destinatari della procedura di accreditamento sono i soggetti pubblici o privati che, indipendentemente dalla propria natura giuridica, abbiano tra i propri scopi e fini istituzionali espressamente dichiarati l’attività di formazione. L’accreditamento, una volta ottenuto, è soggetto a manutenzione periodica, quindi ha un periodo di validità che può essere rinnovato, così da garantire che i requisiti di idoneità e qualità richiesti siano sempre aggiornati e attuali. Con l’accreditamento si instaura un rapporto fiduciario tra ente pubblico e soggetto accreditato, che implica l’osservanza puntuale – formale e sostanziale - delle disposizioni rilevanti e l’utilizzo di approcci comportamentali orientati prioritariamente al raggiungimento delle finalità di interesse generale insite nei servizi offerti all’utenza (fonte: Regione Lazio)."@it .

lsp-core:AgenziaPerIlLavoro a owl:Class ;
    rdfs:label "Agenzia per il lavoro"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty TI:atTime ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom COV:Organization ] ;
    rdfs:comment "Ruolo di Organizzazione attribuito a chi offre servizi di intermediazione tra domanda e offerta di lavoro. L'iscrizione dell'agenzia allo specifico Albo gestito dal MLPS ne certifica l'autorizzazione a svolgere l'attività."@it .

lsp-core:AmbitoTerritorialeSociale a owl:Class ;
    rdfs:label "Ambito territoriale sociale"@it ;
    rdfs:subClassOf COV:Organization,
        [ a owl:Restriction ;
            owl:onProperty lsp-core:appartieneAdAmbitoTerritoriale ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-core:codiceATS ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty lsp-core:haEnteCapofilaDiATS ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-core:haEnteDiATS ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-core:statusATS ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty RO:holdsRoleInTime ;
            owl:someValuesFrom lsp-core:AmministrazioneServizioSociale ],
        [ a owl:Restriction ;
            owl:onProperty TI:atTime ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "L'Ambito Territoriale Sociale (ATS) è un'organizzazione deputata alla programmazione locale, progettazione, concertazione e coordinamento degli interventi e dei servizi sociali e di altre prestazioni integrate, attive a livello locale. Può esplicitarsi sia in una forma giuridica associativa tra diversi enti, principalmente i Comuni, a cui questi ultimi trasferiscono specifiche funzioni sul territorio, sia come articolazione strumentale di un ente con autonomia gestionale ma non giuridica e imprenditoriale."@it .

lsp-core:AmministrazioneServizioSociale a owl:Class ;
    rdfs:label "Amministrazione servizio sociale"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom COV:Organization ] ;
    rdfs:comment "Ruolo di una organizzazione attribuito a chi partecipa al sistema di welfare locale per attivare nel territorio risorse e servizi, pubblici o privati dedicati alla rilevazione dei fabbisogni delle persone e/o dei nuclei familiari in condizione di disagio sociale e lavorativi e in grado di programmare, avviare e gestire un percorso personalizzato di accompagnamento all’inclusione sociale e all’inserimento lavorativo."@it .

lsp-core:AnalisiPreliminareNucleoFamiliare a owl:Class ;
    rdfs:label "Analisi preliminare del nucleo familiare"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:esegueAnalisiPreliminareNucleo ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haAnalisiPreliminareNucleo ] ;
            owl:someValuesFrom owl:Thing ] .

lsp-core:AssegnoDiInclusione a owl:Class ;
    rdfs:label "Assegno di inclusione"@it ;
    rdfs:subClassOf lsp-core:PrestazioneDiSostegnoNucleoFamiliare ;
    rdfs:comment "L’Assegno Di Inclusione (ADI) è una misura nazionale di contrasto alla povertà, alla fragilità e all’esclusione sociale delle fasce deboli attraverso percorsi di inserimento sociale, nonché di formazione, di lavoro e di politica attiva del lavoro. Nel dettaglio è un beneficio economico volto all'integrazione del reddito familiare che varia in base al numero dei componenti il nucleo familiare e alle risorse economiche già possedute dal nucleo medesimo, con una componente aggiuntiva per i nuclei familiari residenti in abitazione in locazione, subordinato alla partecipazione a un percorso personalizzato di attivazione e di inclusione sociale e lavorativa che costituisce condizione abilitante per l'ottenimento e il mantenimento del suddetto beneficio."@it .

lsp-core:Atto a owl:Class ;
    rdfs:label "Atto"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-core:dataAtto ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Classifica in modo generalista un qualsiasi atto ovvero una volizione formale di un soggetto che la esprime in modo volontario e responsabile. Nell'ambito di un processo l'atto si concretizza in una asserzione e/o disposizione che viene espressa da un agente mediante le forme previste dal processo stesso che possono essere la forma scritta contenuta in un documento o una registrazione strutturata e formale nell'ambito di un sistema informativo."@it .

lsp-core:AttoDiNominaRappresentanteLegale a owl:Class ;
    rdfs:label "Atto di nomina rappresentante legale"@it ;
    rdfs:subClassOf lsp-core:Atto,
        [ a owl:Restriction ;
            owl:onProperty lsp-core:haConferenteAttoDiNomina ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-core:haDesignatoAttoDiNomina ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Atto di nomina di un rappresentante legale per un soggetto inabile o minorenne."@it .

lsp-core:BeneficiarioPrestazioneDiSostegno a owl:Class ;
    rdfs:label "Beneficiario prestazione di sostegno"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom rpo:RegisteredResidentPerson ] ;
    owl:disjointWith lsp-core:TitolarePrestazioneDiSostegno ;
    rdfs:comment "Ruolo di persona riferito a chi beneficia di una prestazione di sostegno ovvero colui che ha il godimento della prestazione."@it .

lsp-core:CentroPerImpiego a owl:Class ;
    rdfs:label "Centro per l'impiego"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf COV:hasSupportUnit ] ;
            owl:someValuesFrom COV:PublicOrganization ] ;
    rdfs:comment "È un ufficio locale della Pubblica Amministrazione, di competenza regionale e/o provinciale, a cui è demandata la funzione di attuare politiche pubbliche in materia di lavoro ed erogare servizi per favorire la ricollocazione di lavoratori idisoccupati o inoccupati tramite la stipula di un Patto di Servizio Personalizzato (PSP) ovvero di un percorso specifico di accompagnamento all'inserimento lavorativo che prevede la redazione del bilancio delle competenze e attività finalizzate alla ricerca attiva di lavoro e alla formazione o riqualificazione professionale."@it .

lsp-core:ComuneItaliano a owl:Class ;
    rdfs:label "Comune italiano"@it ;
    rdfs:subClassOf CLV:City,
        COV:PublicOrganization,
        [ a owl:Restriction ;
            owl:onProperty CLV:hasHigherRank ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            countries:Italy ) ] ],
        [ a owl:Restriction ;
            owl:onProperty RO:holdsRoleInTime ;
            owl:someValuesFrom lsp-core:AmministrazioneServizioSociale ] ;
    rdfs:comment "Un comune è, dal punto di vista del diritto pubblico, un ente territoriale, ovverosia un'entità geografica amministrativa composta dal territorio comunale e dall'ente pubblico, dotato di personalità giuridica, detto anch'esso comune, che amministra, per competenza territoriale, e che possiede, almeno in parte, il territorio comunale (fonte: Wikipedia). In questo dominio sono considerati solo i comuni italiani."@it .

lsp-core:CoordinatoreServizioSociale a owl:Class ;
    rdfs:label "Coordinatore servizio sociale"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom CPV:Alive ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf COV:holdEmployment ] ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf (
                            lsp-core:AmbitoTerritorialeSociale
                            lsp-core:ComuneItaliano
                            lsp-core:ProvinciaAutonomaItaliana
                            lsp-core:RegioneItaliana ) ] ] ;
    rdfs:comment "Ruolo di persona attribuito a chi coordina dapprima le attività di accertamento e valutazione delle condizioni di necessità manifestate da chi si rivolge ad un servizio sociale erogato da una amministrazione allo scopo preposta, anche tramite la presentazione di domande di accesso a prestazioni di sostegno e, successivamente, le azioni concertate per il superamento di tali necessità."@it .

lsp-core:DatoreDiLavoro a owl:Class ;
    rdfs:label "Datore di lavoro"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom COV:Organization ] ;
    rdfs:comment "Ruolo di una organizzazione attribuito a chi retribuisce, nell'ambito di un rapporto di lavoro, una prestazione lavorativa erogata da un lavoratore."@it .

lsp-core:DomandaPrestazioneDiSostegno a owl:Class ;
    rdfs:label "Domanda prestazione di sostegno"@it ;
    rdfs:subClassOf lsp-core:Atto,
        [ a owl:Restriction ;
            owl:onProperty lsp-core:protocolloMisuraDomandaPrestazioneDiSostegno ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Sottoclasse di Atto che classifica le domande di prestazioni di sostegno presentate a vario titolo da soggetti che possiedono i requisti per ottenere la prestazione richiesta."@it .

lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare a owl:Class ;
    rdfs:label "Domanda prestazione di sostegno nucleo familiare"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haDomandaPrestazioneDiSostegno ] ;
            owl:someValuesFrom lsp-core:PrestazioneDiSostegnoNucleoFamiliare ] ;
    rdfs:comment "Sottoclasse di Domanda di prestazione di sostegno relative alle prestazioni di sostegno dedicate all'intero nucleo familiare."@it .

lsp-core:EnteFormativo a owl:Class ;
    rdfs:label "Ente formativo"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom COV:Organization ] ;
    rdfs:comment "Ruolo di Organizzazione attribuito a chi gestisce ed eroga corsi e attività di formazione. Nell'ambito di percorsi di inclusione lavorativa e sociale, gli enti formativi risultano accreditati ovvero ottengono tramite opportuni criteri di selezione una certificazione da parte di un'autorità pubblica che ne attesta la qualità, l'affidabilità e la capacità di erogare corsi di formazione validi e conformi a specifici standard."@it .

lsp-core:FascicoloSocialeLavorativoDelCittadino a owl:Class ;
    rdfs:label "Fascicolo sociale e lavorativo del cittadino"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haFascicoloSocialeLavorativo ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Rappresenta la condizione sociale e lavorativa di un cittadino tramite i suoi legami con le diverse entità che esprimono tale condizione. In particolare, tramite il fascicolo è possibile esplorare la condizione sociale, lavorativa e formativa di un cittadino potendone osservare eventuali disagi, fragilità e criticità nonchè gli strumenti di sostegno e i percorsi di inclusione attivati nell'ambito delle politiche attive previste dalla normativa e pianificate dai diversi enti preposti."@it .

lsp-core:GestoreServizioSociale a owl:Class ;
    rdfs:label "Gestore servizio sociale"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom CPV:Alive ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf COV:holdEmployment ] ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf (
                            lsp-core:AmbitoTerritorialeSociale
                            lsp-core:ComuneItaliano
                            lsp-core:ProvinciaAutonomaItaliana
                            lsp-core:RegioneItaliana ) ] ] ;
    rdfs:comment "Ruolo di persona attribuito a chi gestisce nell'ambito di uno specifico servizio sociale e sotto la supervisione di un coordinatore, le singole situazioni di necessità sociale e/o lavorativa manifestate da cittadini in stato di bisogno."@it .

lsp-core:PrestazioneDiSostegno a owl:Class ;
    rdfs:label "Prestazione di sostegno"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-core:haTipoPrestazioneDiSostegno ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty lsp-core:statoBeneficioPrestazioneDiSostegno ;
            owl:someValuesFrom rdfs:Literal ] ;
    rdfs:comment "Classifica in modo generalista le prestazioni, i sussidi e le indennità stabilite normativamente ed erogate dagli enti preposti a vantaggio di persone o nuclei familiari in stato di difficoltà lavorativa, economica, sociale e sanitaria."@it .

lsp-core:PrestazioneDiSostegnoIndividuale a owl:Class ;
    rdfs:label "Prestazione di sostegno individuale"@it ;
    rdfs:subClassOf lsp-core:PrestazioneDiSostegno ;
    owl:disjointWith lsp-core:PrestazioneDiSostegnoNucleoFamiliare ;
    rdfs:comment "Generalizzazione delle prestazioni di sostegno dedicate ai singoli individui."@it .

lsp-core:PrestazioneDiSostegnoNucleoFamiliare a owl:Class ;
    rdfs:label "Prestazione di sostegno nucleo familiare"@it ;
    rdfs:subClassOf lsp-core:PrestazioneDiSostegno ;
    rdfs:comment "Generalizzazione delle prestazioni di sostegno dedicate ai nuclei familiari  e quindi ai relativi componenti."@it .

lsp-core:ProgettoDiUtilitàCollettiva a owl:Class ;
    rdfs:label "Progetto di utilità collettiva"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-core:titoloPUC ;
            owl:someValuesFrom rdfs:Literal ],
        [ a owl:Restriction ;
            owl:onProperty TI:atTime ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haAttivatoPUC ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "I Progetti di utilità collettiva (PUC) sono strumenti introdotti dal decreto-legge 28 gennaio 2019, n. 4 e successive modificazioni, per arricchire la strumentazione volta a favorire l’inserimento sociale o lavorativo dei soggetti beneficiari di sussidi (RdC e successivamente ADI) e sottoscrittori del Patto per l’inclusione sociale o del Patto per il Lavoro nell’ambito del loro percorso personalizzato. Tali progetti, a titolarità dei Comuni o di altre amministrazioni pubbliche a tal fine convenzionate con i Comuni, possono essere realizzati in ambito culturale, sociale, artistico, ambientale, formativo e di tutela dei beni comuni e svolti presso il Comune di residenza del beneficiario, compatibilmente con le altre attività svolte dallo stesso, prevedendo un suo impegno in ogni caso non inferiore a otto ore settimanali, fino a un massimo di sedici ore settimanali, previo accordo tra le parti. A questo scopo, i Comuni possono anche attivare collaborazioni con gli enti del Terzo settore per la progettazione e la realizzazione dei PUC. Tali attività sono svolte a titolo gratuito, non sono assimilabili a una prestazione di lavoro subordinato o parasubordinato e non determinano l’instaurazione di un rapporto di pubblico impiego con le amministrazioni pubbliche."@it .

lsp-core:ProvinciaAutonomaItaliana a owl:Class ;
    rdfs:label "Provincia autonoma italiana"@it ;
    rdfs:subClassOf COV:PublicOrganization,
        [ a owl:Class ;
            owl:oneOf (
                    provinces:Bolzano
                    provinces:Trento ) ],
        [ a owl:Restriction ;
            owl:onProperty RO:holdsRoleInTime ;
            owl:someValuesFrom lsp-core:AmministrazioneServizioSociale ] ;
    rdfs:comment "Una provincia, in Italia, è un ente locale territoriale di area vasta, di livello inferiore alla regione e superiore a quello del comune. In particolare, ci sono due province autonome: quelle di Trento e di Bolzano. Sono autonome in virtù di uno statuto speciale che attribuisce loro particolari forme di autonomia, compresa quella legislativa. Quest'autonomia le rende assimilabili alle regioni e le differenzia dalle altre province, che hanno compiti molto più ridotti."@it .

lsp-core:QuadroDiAnalisiNucleoFamiliare a owl:Class ;
    rdfs:label "Quadro di analisi nucleo familiare"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:esegueQuadroDiAnalisiNucleo ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haQuadroDiAnalisiNucleoFamiliare ] ;
            owl:someValuesFrom owl:Thing ] .

lsp-core:RappresentanteLegale a owl:Class ;
    rdfs:label "Rappresentante legale"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom L0:Agent ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haDesignatoAttoDiNomina ] ;
            owl:someValuesFrom owl:Thing ] ;
    rdfs:comment "Ruolo di agente riferito al soggetto che funge da rappresentante di un titolare di un diritto a una prestazione di sostegno e/o di un beneficiario di tale prestazione in virtu dell'incapacità di questi di esercitare o gestire tale diritto e/o prestazione."@it .

lsp-core:RegioneItaliana a owl:Class ;
    rdfs:label "Regione italiana"@it ;
    rdfs:subClassOf CLV:Region,
        COV:PublicOrganization,
        [ a owl:Restriction ;
            owl:onProperty CLV:hasHigherRank ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:oneOf (
                            countries:Italy ) ] ],
        [ a owl:Restriction ;
            owl:onProperty RO:holdsRoleInTime ;
            owl:someValuesFrom lsp-core:AmministrazioneServizioSociale ] ;
    rdfs:comment "Una regione italiana rappresenta il primo livello di suddivisione territoriale della Repubblica Italiana, nonché un ente pubblico dotato di autonomia politica e amministrativa sancita e limitata principalmente dalla Costituzione (fonte: Wikipedia)."@it .

lsp-core:RichiedentePrestazioneDiSostegno a owl:Class ;
    rdfs:label "Richiedente prestazione di sostegno"@it ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf (
                    lsp-core:RappresentanteLegale
                    lsp-core:SuperstiteDiTitolareDiPrestazioneDiSostegno
                    lsp-core:TitolarePrestazioneDiSostegno ) ] ;
    rdfs:comment "Ruolo di agente riferito a chi presenta, anche per delega, una domanda per l'ottenimento di una prestazione di sostegno per se stesso e/o per altri."@it .

lsp-core:RichiedentePrestazioneDiSostegnoNucleoFamiliare a owl:Class ;
    rdfs:label "Richiedente prestazione di sostegno nucleo familiare"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-core:presentaDomandaPrestazioneDiSostegno ;
            owl:someValuesFrom lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare ] ;
    rdfs:comment "Sottoclasse di Richiedente prestazione di sostegno riferita a prestazioni di sostegno dedicate ad un nucleo familiare. In questo caso il richiedente è un componente del nucleo familiare, o un suo delegato, idoneo alla presentazione della relativa domanda."@it .

lsp-core:SuperstiteDiTitolareDiPrestazioneDiSostegno a owl:Class ;
    rdfs:label "Superstite di titolare di prestazione di sostegno"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom rpo:RegisteredResidentPerson ] ;
    rdfs:comment "Ruolo di persona viva e residente che ha diritto ad una prestazione di sostegno in quanto superstite un titolare o dante causa."@it .

lsp-core:SupportoFormazioneLavoro a owl:Class ;
    rdfs:label "Supporto formazione lavoro"@it ;
    rdfs:subClassOf lsp-core:PrestazioneDiSostegnoIndividuale ;
    rdfs:comment "Il Supporto per la Formazione e il Lavoro (SFL) è una misura finalizzata a favorire l’attivazione nel mondo del lavoro delle persone a rischio di esclusione sociale e lavorativa, mediante la partecipazione a progetti di formazione, di qualificazione e riqualificazione professionale, di orientamento, di accompagnamento al lavoro e di politiche attive del lavoro, nonché dei progetti utili alla collettività e del servizio civile universale e prevede la corresponsione di una indennità di partecipazione alle misure di attivazione lavorativa, condizionato all’effettiva partecipazione alle attività sopra indicate."@it .

lsp-core:TipoPrestazioneDiSostegno a owl:Class ;
    rdfs:label "Tipo prestazione di sostegno"@it ;
    rdfs:comment "Classifica la tipologia di una prestazione di sostegno."@it .

lsp-core:TitolarePrestazioneDiSostegno a owl:Class ;
    rdfs:label "Titolare prestazione di sostegno"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf RO:holdsRoleInTime ] ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf (
                            CPV:Dead
                            rpo:RegisteredResidentPerson ) ] ] ;
    rdfs:comment "Ruolo di persona viva e residente o deceduta riferito a colui che ha diritto alla prestazione di sostegno ed è quindi titolato a presentare la relativa domanda, eventualmente tramite un delegato o un suo superstite."@it .

lsp-core:TitolarePrestazioneDiSostegnoNucleoFamiliare a owl:Class ;
    rdfs:label "Titolare prestazione di sostegno nucleo familiare"@it ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lsp-core:haDirittoAPrestazioneDiSostegno ;
            owl:someValuesFrom lsp-core:DomandaPrestazioneDiSostegnoNucleoFamiliare ] ;
    rdfs:comment "Sottoclasse di Titolare prestazione di sostegno riferita a prestazioni di sostegno dedicate ad un nucleo familiare. In questo caso il tirolare è un componente del nucleo familiare."@it .

lsp-labour:CurriculumVitaeCittadino a owl:Class .

lsp-labour:OffertaDiLavoro a owl:Class .

lsp-labour:OffertaFormativa a owl:Class .

lsp-labour:PattoAttivazioneDigitaleIndividuale a owl:Class ;
    rdfs:subClassOf lsp-core:Atto .

lsp-labour:PattoServizioPersonalizzato a owl:Class ;
    rdfs:subClassOf lsp-core:Atto .

lsp-social:CasoDiNucleoFragileOInPovertà a owl:Class .

lsp-social:PattoAttivazioneDigitaleNucleo a owl:Class ;
    rdfs:subClassOf lsp-core:Atto .

lsp-social:PattoInclusioneSocialeDelCaso a owl:Class ;
    rdfs:subClassOf lsp-core:Atto,
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:haPattoInclusioneSocialeNucleo ] ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf lsp-core:stipulaPattoInclusioneSocialeNucleo ] ;
            owl:someValuesFrom owl:Thing ] .

rpo:RegisteredResidentPerson a owl:Class ;
    rdfs:subClassOf CPV:Person .

